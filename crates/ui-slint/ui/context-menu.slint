//
// Menú propio dibujado en Slint con las acciones de Naygo y, al final, "Más opciones de
// Windows…" que invoca el menú del Shell (platform::context_menu). Overlay posicionado en
// el punto del clic; un velo cierra al hacer clic fuera. Sin glifos raros (solo texto).
import { ContextMenuVm } from "types.slint";
import { Tr } from "i18n.slint";
import { Theme } from "theme.slint";

component MenuRow inherits Rectangle {
    in property <string> label;
    callback clicked();
    height: 26px;
    background: t.has-hover ? Theme.selection-bg : transparent;
    border-radius: 3px;
    Text {
        text: root.label;
        color: Theme.text;
        vertical-alignment: center;
        x: 10px;
    }
    t := TouchArea { clicked => { root.clicked(); } }
}

export component ContextMenu inherits Rectangle {
    in property <ContextMenuVm> vm;
    callback open();
    callback open-with();
    callback copy();
    callback cut();
    callback paste();
    callback rename();
    callback delete();
    callback copy-names();   // copiar nombre(s) de la selección
    callback copy-path();    // copiar ruta(s) completa(s)
    callback compress();     // comprimir la selección en un .zip (abre el modal de nombre)
    callback extract-here(); // extraer el .zip seleccionado en una subcarpeta aquí
    callback extract-to();   // extraer el .zip seleccionado en una carpeta elegida
    callback terminal-ps();  // abrir PowerShell en la carpeta
    callback terminal-cmd(); // abrir CMD en la carpeta
    callback terminal-wt();  // abrir Windows Terminal en la carpeta
    callback explorer();     // abrir el Explorador de Windows en la carpeta (modo carpeta)
    callback new-folder();   // crear subcarpeta(s) en la carpeta (modo carpeta)
    callback native();      // "Más opciones de Windows…"
    callback dismiss();

    visible: root.vm.active;
    // Velo a pantalla completa: clic fuera cierra.
    veil := TouchArea {
        clicked => { root.dismiss(); }
    }
    // Tarjeta del menú posicionada en el clic (acotada para no salirse por la derecha/abajo).
    Rectangle {
        x: min(root.vm.x, root.width - self.width - 4px);
        y: min(root.vm.y, root.height - self.height - 4px);
        width: 210px;
        height: items.preferred-height + 8px;
        background: Theme.row-bg;
        border-color: Theme.selection-bg;
        border-width: 1px;
        border-radius: 6px;
        TouchArea {} // captura clics dentro de la tarjeta (no cierra)
        items := VerticalLayout {
            padding: 4px;
            spacing: 1px;
            // --- Modo CARPETA (clic derecho en zona vacía): acciones de la carpeta ---
            if root.vm.folder-mode: MenuRow { label: Tr.ctx-explorer; clicked => { root.explorer(); } }
            if root.vm.folder-mode: MenuRow { label: Tr.ctx-new-folder; clicked => { root.new-folder(); } }
            if root.vm.folder-mode: Rectangle { height: 1px; background: Theme.border; }
            if root.vm.folder-mode: MenuRow { label: Tr.ctx-paste; clicked => { root.paste(); } }
            if root.vm.folder-mode: Rectangle { height: 1px; background: Theme.border; }
            // --- Modo ARCHIVO (clic derecho en una fila): acciones del/los archivo(s) ---
            if !root.vm.folder-mode: MenuRow { label: Tr.ctx-open; clicked => { root.open(); } }
            if !root.vm.folder-mode: MenuRow { label: Tr.ctx-open-with; clicked => { root.open-with(); } }
            if !root.vm.folder-mode: Rectangle { height: 1px; background: Theme.border; }
            if !root.vm.folder-mode: MenuRow { label: Tr.ctx-copy; clicked => { root.copy(); } }
            if !root.vm.folder-mode: MenuRow { label: Tr.ctx-cut; clicked => { root.cut(); } }
            if !root.vm.folder-mode: MenuRow { label: Tr.ctx-paste; clicked => { root.paste(); } }
            if !root.vm.folder-mode: Rectangle { height: 1px; background: Theme.border; }
            if !root.vm.folder-mode: MenuRow { label: Tr.ctx-rename; clicked => { root.rename(); } }
            if !root.vm.folder-mode: MenuRow { label: Tr.ctx-delete; clicked => { root.delete(); } }
            if !root.vm.folder-mode: Rectangle { height: 1px; background: Theme.border; }
            if !root.vm.folder-mode: MenuRow { label: Tr.ctx-copy-names; clicked => { root.copy-names(); } }
            if !root.vm.folder-mode: MenuRow { label: Tr.ctx-copy-path; clicked => { root.copy-path(); } }
            if !root.vm.folder-mode: Rectangle { height: 1px; background: Theme.border; }
            // Comprimir/Extraer (.zip). "Comprimir en .zip…" siempre que haya selección; las
            // dos de extraer solo si la selección es exactamente un archivo .zip.
            // TODO Task 8: i18n (Tr.ctx-compress / Tr.ctx-extract-here / Tr.ctx-extract-to).
            if !root.vm.folder-mode: MenuRow { label: "Comprimir en .zip…"; clicked => { root.compress(); } }
            if !root.vm.folder-mode && root.vm.is-single-zip: MenuRow { label: "Extraer aquí"; clicked => { root.extract-here(); } }
            if !root.vm.folder-mode && root.vm.is-single-zip: MenuRow { label: "Extraer en…"; clicked => { root.extract-to(); } }
            if !root.vm.folder-mode: Rectangle { height: 1px; background: Theme.border; }
            // --- Común a ambos modos: terminales + menú nativo de Windows ---
            MenuRow { label: Tr.ctx-terminal-ps; clicked => { root.terminal-ps(); } }
            MenuRow { label: Tr.ctx-terminal-cmd; clicked => { root.terminal-cmd(); } }
            if root.vm.has-wt: MenuRow { label: Tr.ctx-terminal-wt; clicked => { root.terminal-wt(); } }
            if root.vm.has-native: Rectangle { height: 1px; background: Theme.border; }
            if root.vm.has-native: MenuRow {
                label: Tr.ctx-more-windows;
                clicked => { root.native(); }
            }
        }
    }
}
