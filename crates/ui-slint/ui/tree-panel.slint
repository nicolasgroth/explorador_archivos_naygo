// Naygo — panel Árbol (Fase 2b): árbol de carpetas aplanado con sangría.
// Copyright (c) 2026 Nicolás Groth / ISGroth. MIT License.
//
// El árbol se calcula en Rust (lazy, worker solo-directorios) y llega APLANADO a una
// lista: cada fila trae su `depth` (sangría = depth*14px), si está expandida y si tiene
// hijos (chevron ▶/▼). Clic en el chevron expande/colapsa; clic en el nombre navega el
// panel Files activo. Las raíces (unidades) muestran una barrita de uso de disco.
import { ListView } from "std-widgets.slint";
import { TreeRow } from "types.slint";
import { Tr } from "i18n.slint";
import { Theme } from "theme.slint";

export component TreePanel inherits Rectangle {
    in property <bool> active;
    in property <[TreeRow]> rows;
    callback toggle(string);    // expandir/colapsar la rama (por ruta)
    callback navigate(string);  // navegar el Files activo a esa carpeta
    callback focus-pane();

    background: Theme.panel-bg;
    border-width: root.active ? 1.5px : 0px;
    border-color: Theme.accent;

    VerticalLayout {
        padding: 4px;
        Text {
            text: Tr.tree-title;
            color: Theme.text-dim;
            font-weight: 700;
            height: 20px;
            vertical-alignment: center;
            x: 4px;
        }
        ListView {
            vertical-stretch: 1;
            for n[i] in root.rows: row-rect := Rectangle {
                height: 22px;
                background: n.active ? Theme.selection-bg : (node-touch.has-hover ? Theme.row-alt-bg : transparent);
                border-radius: 3px;
                // Sangría + ancho de la zona del chevron (los primeros 16px tras la sangría).
                // El clic dentro de esa zona expande/colapsa; fuera, navega. Antes había DOS
                // TouchAreas (chevron + fila): el de la fila, declarado último, quedaba ENCIMA y
                // se tragaba el clic del chevron → el árbol nunca expandía. Ahora es UN solo
                // TouchArea que decide por la x del clic.
                property <length> indent: 2px + n.depth * 14px;
                HorizontalLayout {
                    padding-left: row-rect.indent;
                    spacing: 2px;
                    // Chevron (o hueco si no tiene hijos).
                    Rectangle {
                        width: 16px;
                        Text {
                            // El renderizador por software no dibuja flechas/triángulos
                            // Unicode: usamos +/− (colapsado/expandido) que sí se ven.
                            text: n.has-children ? (n.expanded ? "−" : "+") : "";
                            color: Theme.text-dim;
                            font-size: 13px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                    // Ícono de color cacheado (carpeta o disco) + nombre con sufijo de estado.
                    Image {
                        source: n.icon;
                        width: 16px;
                        height: 16px;
                        vertical-alignment: center;
                        image-rendering: smooth;
                    }
                    Text {
                        text: " " + n.name + (n.loading ? "  ..." : (n.error ? "  (!)" : ""));
                        color: n.is-drive ? Theme.text : (n.error ? Theme.error : Theme.text);
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }
                    // Barrita de uso de disco (solo raíces con dato).
                    if n.disk-percent >= 0: Rectangle {
                        width: 42px;
                        height: 8px;
                        y: (parent.height - self.height) / 2;
                        background: Theme.row-bg;
                        border-radius: 4px;
                        Rectangle {
                            x: 0;
                            width: parent.width * (n.disk-percent / 100);
                            height: parent.height;
                            background: n.disk-percent > 90 ? Theme.error : (n.disk-percent > 75 ? Theme.highlight : Theme.accent);
                            border-radius: 4px;
                        }
                    }
                }
                // UN TouchArea por fila (el `clicked` no se dispara dentro de un ListView bajo
                // winit/software; detectamos press+release con pointer-event). Decide por la x:
                // clic en la zona del chevron (con hijos) → toggle; resto → navegar.
                node-touch := TouchArea {
                    property <bool> pressed-here: false;
                    pointer-event(ev) => {
                        if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left) {
                            self.pressed-here = true;
                        }
                        if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left && self.pressed-here) {
                            self.pressed-here = false;
                            root.focus-pane();
                            if (n.has-children && self.mouse-x >= row-rect.indent && self.mouse-x < row-rect.indent + 16px) {
                                root.toggle(n.path);
                            } else {
                                root.navigate(n.path);
                            }
                        }
                        if (ev.kind == PointerEventKind.cancel) {
                            self.pressed-here = false;
                        }
                    }
                }
            }
        }
    }
}
