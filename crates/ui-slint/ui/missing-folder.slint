// Naygo — modal "carpeta no encontrada": la carpeta de un panel dejó de existir (USB
// desconectado, red caída, carpeta borrada). En vez de mandar el panel a HOME en silencio, le
// damos opciones al usuario: reintentar, subir al ancestro existente, elegir otra, o cerrar el
// panel. Es un overlay dentro de la ventana principal (no una Window aparte).
// Copyright (c) 2026 Nicolás Groth / ISGroth. MIT License.
import { MissingFolderVm } from "types.slint";
import { Tr } from "i18n.slint";
import { Theme } from "theme.slint";

export component MissingFolder inherits Rectangle {
    in property <MissingFolderVm> vm;
    callback retry();
    callback go-ancestor();
    callback choose();
    callback close-pane();

    visible: root.vm.active;
    // Velo modal (sin cierre por clic afuera: hay que elegir una opción).
    background: #000000aa;
    TouchArea {}

    Rectangle {
        width: 460px;
        height: card-layout.preferred-height + 24px;
        background: Theme.panel-bg;
        border-radius: 8px;
        border-width: 1px;
        border-color: Theme.border;
        TouchArea {} // tragar clics dentro

        card-layout := VerticalLayout {
            padding: 16px;
            spacing: 12px;

            Text {
                text: Tr.missing-title;
                color: Theme.text;
                font-size: 16px;
                font-weight: 700;
            }
            Text {
                text: Tr.missing-body;
                color: Theme.text-dim;
                font-size: 12px;
                wrap: word-wrap;
            }
            // La ruta perdida.
            Rectangle {
                height: lostpath.preferred-height + 12px;
                background: Theme.row-bg;
                border-radius: 4px;
                border-width: 1px;
                border-color: Theme.border;
                lostpath := Text {
                    text: root.vm.lost-path;
                    color: Theme.highlight;
                    font-size: 12px;
                    x: 8px;
                    width: parent.width - 16px;
                    vertical-alignment: center;
                    wrap: word-wrap;
                }
            }
            // Opciones (una por fila, con descripción).
            for opt in [
                { label: Tr.missing-retry, kind: 0 },
                { label: Tr.missing-ancestor, kind: 1 },
                { label: Tr.missing-choose, kind: 2 },
                { label: Tr.missing-close, kind: 3 },
            ]: Rectangle {
                height: 34px;
                border-radius: 5px;
                border-width: 1px;
                border-color: opt-touch.has-hover ? Theme.accent : Theme.border;
                background: opt-touch.has-hover ? Theme.selection-bg : Theme.row-bg;
                Text {
                    text: opt.label;
                    color: Theme.text;
                    vertical-alignment: center;
                    x: 12px;
                }
                opt-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        if (opt.kind == 0) { root.retry(); }
                        if (opt.kind == 1) { root.go-ancestor(); }
                        if (opt.kind == 2) { root.choose(); }
                        if (opt.kind == 3) { root.close-pane(); }
                    }
                }
            }
        }
    }
}
