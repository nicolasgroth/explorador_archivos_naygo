//
// El contenido lo calcula un worker en Rust (con debounce 150 ms y cancelación); aquí
// solo se pinta según `mode`: 0=vacío 1=texto 2=imagen 3=mensaje.
import { ScrollView } from "std-widgets.slint";
import { PreviewVm } from "types.slint";

export component PreviewPanel inherits Rectangle {
    in property <bool> active;
    in property <PreviewVm> view;
    background: #0e1622;
    border-width: root.active ? 1.5px : 0px;
    border-color: #4f8ae0;

    VerticalLayout {
        padding: 6px;
        spacing: 4px;
        Text {
            text: "Vista previa";
            color: #9ab;
            font-weight: 700;
            height: 20px;
            vertical-alignment: center;
        }

        if root.view.mode == 0: Text {
            text: "Selecciona un archivo";
            color: #678;
            vertical-alignment: center;
        }

        if root.view.mode == 1: VerticalLayout {
            vertical-stretch: 1;
            spacing: 2px;
            ScrollView {
                vertical-stretch: 1;
                Text {
                    text: root.view.text;
                    color: #cdd;
                    font-family: "Consolas";
                    wrap: no-wrap;
                }
            }
            if root.view.truncated: Text {
                text: "… (recortado)";
                color: #889;
                font-size: 11px;
            }
        }

        if root.view.mode == 2: Image {
            vertical-stretch: 1;
            source: root.view.image;
            image-fit: contain;
        }

        if root.view.mode == 3: Text {
            text: root.view.message;
            color: #889;
            vertical-alignment: center;
            horizontal-alignment: center;
            vertical-stretch: 1;
        }
    }
}
