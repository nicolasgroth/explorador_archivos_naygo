// Naygo — panel Preview (Fase 2b): vista previa liviana de texto/imagen.
// Copyright (c) 2026 Nicolás Groth / ISGroth. MIT License.
//
// El contenido lo calcula un worker en Rust (con debounce 150 ms y cancelación); aquí
// solo se pinta según `mode`: 0=vacío 1=texto 2=imagen 3=mensaje. En modo texto, si la regla
// forzó un lenguaje, se pinta el código resaltado (un Text por segmento); si no, texto plano.
import { ScrollView, TextEdit } from "std-widgets.slint";
import { PreviewVm } from "types.slint";
import { Tr } from "i18n.slint";
import { Theme } from "theme.slint";

// Ícono "abrir con el programa del sistema": un rectángulo con una flecha saliente, dibujado con
// Path (no glifo de fuente, que bajo render por software puede no existir y salir invisible).
component OpenExternalIcon inherits Rectangle {
    in property <color> tint: Theme.text;
    in property <length> size: 13px;
    // Recuadro (la "ventana").
    Path {
        width: root.size;
        height: root.size;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        stroke: root.tint;
        stroke-width: 1.4px;
        viewbox-width: 12;
        viewbox-height: 12;
        // Caja abierta por la esquina superior derecha.
        MoveTo { x: 7; y: 1; }
        LineTo { x: 1; y: 1; }
        LineTo { x: 1; y: 11; }
        LineTo { x: 11; y: 11; }
        LineTo { x: 11; y: 5; }
    }
    // Flecha que sale hacia afuera.
    Path {
        width: root.size;
        height: root.size;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        stroke: root.tint;
        stroke-width: 1.4px;
        viewbox-width: 12;
        viewbox-height: 12;
        MoveTo { x: 5; y: 7; }
        LineTo { x: 11; y: 1; }
        MoveTo { x: 7.5; y: 1; }
        LineTo { x: 11; y: 1; }
        LineTo { x: 11; y: 4.5; }
    }
}

export component PreviewPanel inherits Rectangle {
    in property <bool> active;
    in property <PreviewVm> view;
    callback focus-pane();   // marcar este panel como activo al hacer clic en cualquier parte
    callback open-in-system();   // abrir el archivo previsualizado con el programa por defecto
    callback hover-tip(string, length);   // tooltip flotante (texto, x centrada) → AppWindow
    // Cuando hay código resaltado (no seleccionable por ser un Text por segmento), este toggle
    // alterna a una vista de texto plano dentro de un TextEdit read-only, que sí permite
    // seleccionar y copiar (Ctrl+C nativo). Solo aplica al modo texto con resaltado.
    property <bool> selectable: false;
    background: Theme.panel-bg;
    border-width: root.active ? 1.5px : 0px;
    border-color: Theme.accent;

    // TouchArea de fondo: un clic en el cuerpo (texto, imagen o zona vacía) marca el panel
    // como activo. Va PRIMERO (al fondo) para que el ScrollView del modo texto siga
    // recibiendo sus propios gestos por encima.
    bg-touch := TouchArea {
        clicked => { root.focus-pane(); }
    }

    VerticalLayout {
        padding: 6px;
        spacing: 4px;
        // Barra de título: rótulo + (si hay archivo) botón "abrir con el sistema".
        HorizontalLayout {
            height: 20px;
            spacing: 6px;
            Text {
                text: Tr.preview-title;
                color: Theme.text-dim;
                font-weight: 700;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
            // Botón "seleccionar/copiar texto": solo cuando hay código resaltado. Alterna entre la
            // vista coloreada (no seleccionable) y una vista de texto plano seleccionable.
            if root.view.highlighted: Rectangle {
                width: 26px;
                height: 20px;
                background: sel-touch.has-hover ? Theme.selection-bg : transparent;
                border-radius: 3px;
                Text {
                    text: "✎";
                    color: root.selectable ? Theme.accent : Theme.text-dim;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    width: 100%;
                    height: 100%;
                }
                sel-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.selectable = !root.selectable; }
                    changed has-hover => {
                        root.hover-tip(self.has-hover ? Tr.preview-select-tip : "",
                            self.absolute-position.x + self.width / 2);
                    }
                }
            }
            // Botón abrir con el programa del sistema (visible cuando hay algo en preview).
            if root.view.mode != 0: Rectangle {
                width: 26px;
                height: 20px;
                background: open-touch.has-hover ? Theme.selection-bg : transparent;
                border-radius: 3px;
                OpenExternalIcon {
                    width: 100%;
                    height: 100%;
                    tint: open-touch.has-hover ? Theme.text : Theme.text-dim;
                }
                open-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.open-in-system(); }
                    changed has-hover => {
                        root.hover-tip(self.has-hover ? Tr.preview-open-tip : "",
                            self.absolute-position.x + self.width / 2);
                    }
                }
            }
        }

        if root.view.mode == 0: Text {
            text: Tr.preview-select;
            color: Theme.text-dim;
            vertical-alignment: center;
        }

        if root.view.mode == 1: VerticalLayout {
            vertical-stretch: 1;
            spacing: 2px;
            ScrollView {
                vertical-stretch: 1;
                // Código resaltado: una fila por línea (un Text por segmento, sin ajuste), con
                // SCROLL HORIZONTAL como un editor — respeta la indentación y conserva el color.
                // El viewport toma el ancho natural del contenido; si supera el visible, el
                // ScrollView ofrece la barra horizontal. Las líneas ya vienen recortadas a
                // TEXT_MAX_LINE_CHARS, así que ningún glifo sale del rango i16 del render software.
                if root.view.highlighted && !root.selectable: hl-col := VerticalLayout {
                    alignment: start;
                    for line in root.view.hl-lines: HorizontalLayout {
                        alignment: start;
                        // Espaciador para que las líneas vacías ocupen alto.
                        Rectangle {
                            height: 16px;
                            width: 0px;
                        }
                        for seg in line.spans: Text {
                            text: seg.text;
                            color: seg.color;
                            font-family: "Consolas";
                            vertical-alignment: center;
                        }
                    }
                }
                // Vista seleccionable: texto plano dentro de un TextEdit read-only (una sola tinta,
                // con selección y Ctrl+C nativos). Se usa para el texto plano "puro" (sin resaltado)
                // y como vista alterna del código resaltado cuando el usuario activa el toggle.
                // El TextEdit de std-widgets hace word-wrap por defecto, así que las líneas larguísimas
                // no empujan glifos fuera del rango i16 del render por software (el core ya recorta).
                if !root.view.highlighted || root.selectable: TextEdit {
                    vertical-stretch: 1;
                    read-only: true;
                    text: root.view.text;
                    font-family: "Consolas";
                }
            }
            if root.view.truncated: Text {
                text: Tr.preview-truncated;
                color: Theme.text-dim;
                font-size: 11px;
            }
        }

        if root.view.mode == 2: Image {
            vertical-stretch: 1;
            source: root.view.image;
            image-fit: contain;
        }

        if root.view.mode == 3: Text {
            text: root.view.message;
            color: Theme.text-dim;
            vertical-alignment: center;
            horizontal-alignment: center;
            vertical-stretch: 1;
        }
    }
}
