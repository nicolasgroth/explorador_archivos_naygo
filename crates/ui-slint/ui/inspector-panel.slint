import { InspectorVm } from "types.slint";
import { Tr } from "i18n.slint";
import { Theme } from "theme.slint";

// Una fila etiqueta/valor del inspector.
component PropRow inherits HorizontalLayout {
    in property <string> label;
    in property <string> value;
    spacing: 8px;
    padding: 2px;
    Text {
        text: root.label;
        color: Theme.text-dim;
        font-weight: 700;
        width: 84px;
        horizontal-alignment: right;
        vertical-alignment: center;
    }
    Text {
        text: root.value;
        color: Theme.text;
        vertical-alignment: center;
        horizontal-stretch: 1;
        overflow: elide;
    }
}

export component InspectorPanel inherits Rectangle {
    in property <bool> active;
    in property <InspectorVm> info;
    callback focus-pane();   // marcar este panel como activo al hacer clic en cualquier parte
    background: Theme.panel-bg;
    border-width: root.active ? 1.5px : 0px;
    border-color: Theme.accent;

    // TouchArea de fondo: un clic en el cuerpo (texto o zona vacía) marca el panel como
    // activo. Va PRIMERO (al fondo) para no robar clics a controles que se monten encima.
    bg-touch := TouchArea {
        clicked => { root.focus-pane(); }
    }

    VerticalLayout {
        padding: 8px;
        spacing: 4px;
        Text {
            text: Tr.inspector-title;
            color: Theme.text-dim;
            font-weight: 700;
            height: 22px;
            vertical-alignment: center;
        }
        if !root.info.present: Text {
            text: Tr.inspector-no-selection;
            color: Theme.text-dim;
            vertical-alignment: center;
        }
        if root.info.present: VerticalLayout {
            spacing: 2px;
            PropRow { label: Tr.inspector-name; value: root.info.name; }
            PropRow { label: Tr.inspector-kind; value: root.info.kind; }
            PropRow { label: Tr.inspector-size; value: root.info.size; }
            PropRow { label: Tr.inspector-modified; value: root.info.modified; }
            PropRow { label: Tr.inspector-created; value: root.info.created; }
            PropRow { label: Tr.inspector-path; value: root.info.path; }
        }
        // Empuja el contenido hacia arriba.
        Rectangle { vertical-stretch: 1; }
    }
}
