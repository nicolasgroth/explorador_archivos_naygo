// Naygo — panel de archivos (Fase 2a): tabla virtualizada, encabezados, foco de teclado.
// Copyright (c) 2026 Nicolás Groth / ISGroth. MIT License.
//
// Columnas repartidas con `horizontal-stretch` (50/15/15/20) para evitar bucles de
// binding. Cada panel emite sus callbacks con su `pane-id` para que el controller sepa
// sobre cuál actuar; el panel activo lleva borde de acento.
import { ListView, LineEdit } from "std-widgets.slint";
import { RowData, PathSeg } from "types.slint";
import { Tr } from "i18n.slint";
import { Theme } from "theme.slint";

component HeaderCell inherits Rectangle {
    in property <string> text;
    callback clicked();
    background: hcell-touch.has-hover ? Theme.row-alt-bg : Theme.row-bg;
    Text {
        text: root.text;
        color: Theme.text-dim;
        font-weight: 700;
        vertical-alignment: center;
        x: 6px;
    }
    hcell-touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

export component FilePanel inherits FocusScope {
    in property <int> pane-id;
    in property <bool> active;
    in property <[RowData]> rows;
    in property <length> scroll-y;
    // --- Barra de ruta (breadcrumbs + edición + autocompletado) ---
    in property <[PathSeg]> segments;        // breadcrumbs de la carpeta actual
    in property <bool> editing;              // este panel está editando su ruta
    in property <string> edit-text;          // texto del editor (lo controla Rust)
    in property <[string]> suggestions;      // autocompletado del editor
    callback segment-clicked(int, string);   // (pane-id, ruta) clic en un breadcrumb → navegar
    callback path-edit-start(int);           // (pane-id) entrar a modo edición
    callback path-edit-changed(int, string); // (pane-id, texto) recalcular autocompletado
    callback path-edit-commit(int, string);  // (pane-id, texto) Enter → navegar
    callback path-edit-cancel(int);          // (pane-id) Esc → salir de edición
    callback suggestion-clicked(int, string);// (pane-id, nombre) elegir un candidato
    callback row-clicked(int, int);          // (pane-id, pos)
    callback row-double-clicked(int, int);
    callback row-drag-out(int);              // (pane-id) inicia el arrastre OLE de lo selecto
    callback row-context(int, int, length, length); // (pane-id, pos, x-ventana, y-ventana)
    callback sort-by(int, string);           // (pane-id, columna)
    callback activate(int);                  // (pane-id) al interactuar
    callback key(string, bool, bool, bool);

    key-pressed(event) => {
        root.activate(root.pane-id);
        root.key(event.text, event.modifiers.control, event.modifiers.shift, event.modifiers.alt);
        accept
    }

    // Cuando este panel pasa a ser el activo, tomar el foco de teclado para que las teclas
    // lleguen sin necesidad de un clic previo (p. ej. tras Tab o al arrancar).
    changed active => {
        if (root.active) {
            root.focus();
        }
    }

    // Borde de acento si es el panel activo.
    Rectangle {
        border-width: root.active ? 1.5px : 0px;
        border-color: Theme.accent;
        VerticalLayout {
            // --- Barra de ruta: breadcrumbs (modo normal) o editor con autocompletado. ---
            Rectangle {
                height: 26px;
                background: Theme.row-bg;
                border-radius: 4px;
                // Modo BREADCRUMB: segmentos clicables; clic en el hueco entra a edición.
                if !root.editing: HorizontalLayout {
                    padding-left: 4px;
                    spacing: 0px;
                    for seg[i] in root.segments: Rectangle {
                        width: seg-label.preferred-width + 10px;
                        background: seg-touch.has-hover ? Theme.selection-bg : transparent;
                        border-radius: 3px;
                        seg-label := Text {
                            text: (i == 0 ? "" : "› ") + seg.label;
                            color: Theme.text;
                            vertical-alignment: center;
                            x: 4px;
                        }
                        seg-touch := TouchArea {
                            pointer-event(ev) => {
                                if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left) {
                                    root.activate(root.pane-id);
                                    root.segment-clicked(root.pane-id, seg.path);
                                }
                            }
                        }
                    }
                    // Zona vacía a la derecha: clic = editar la ruta.
                    Rectangle {
                        horizontal-stretch: 1;
                        edit-touch := TouchArea {
                            pointer-event(ev) => {
                                if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left) {
                                    root.activate(root.pane-id);
                                    root.path-edit-start(root.pane-id);
                                }
                            }
                        }
                    }
                }
                // Modo EDICIÓN: LineEdit con la ruta; Enter navega, Esc cancela.
                if root.editing: path-edit := LineEdit {
                    text: root.edit-text;
                    placeholder-text: "C:\\…";
                    edited(t) => { root.path-edit-changed(root.pane-id, t); }
                    accepted(t) => { root.path-edit-commit(root.pane-id, t); }
                    key-pressed(ev) => {
                        if (ev.text == Key.Escape) {
                            root.path-edit-cancel(root.pane-id);
                            return accept;
                        }
                        return reject;
                    }
                }
            }
            // Autocompletado: lista flotante de candidatos bajo el editor (solo en edición).
            if root.editing && root.suggestions.length > 0: Rectangle {
                height: min(root.suggestions.length * 22px + 4px, 132px);
                background: Theme.row-bg;
                border-width: 1px;
                border-color: Theme.selection-bg;
                border-radius: 4px;
                ListView {
                    for s[i] in root.suggestions: Rectangle {
                        height: 22px;
                        background: sug-touch.has-hover ? Theme.selection-bg : transparent;
                        Text {
                            text: "📁 " + s;
                            color: Theme.text;
                            vertical-alignment: center;
                            x: 6px;
                        }
                        sug-touch := TouchArea {
                            pointer-event(ev) => {
                                if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left) {
                                    root.suggestion-clicked(root.pane-id, s);
                                }
                            }
                        }
                    }
                }
            }
            HorizontalLayout {
                height: 22px;
                HeaderCell {
                    text: Tr.col-name;
                    horizontal-stretch: 50;
                    clicked => {
                        root.sort-by(root.pane-id, "name");
                    }
                }
                HeaderCell {
                    text: Tr.col-ext;
                    horizontal-stretch: 15;
                    clicked => {
                        root.sort-by(root.pane-id, "ext");
                    }
                }
                HeaderCell {
                    text: Tr.col-size;
                    horizontal-stretch: 15;
                    clicked => {
                        root.sort-by(root.pane-id, "size");
                    }
                }
                HeaderCell {
                    text: Tr.col-modified;
                    horizontal-stretch: 20;
                    clicked => {
                        root.sort-by(root.pane-id, "modified");
                    }
                }
            }
            ListView {
                viewport-y: root.scroll-y;
                for row[i] in root.rows: Rectangle {
                    height: 22px;
                    // Fondo: selección > resaltado (recién aparecido, watcher) > hover > nada.
                    background: row.selected
                        ? Theme.selection-bg
                        : (row.highlight
                            ? Theme.highlight.with-alpha(0.22)
                            : (row-touch.has-hover ? Theme.row-alt-bg : transparent));
                    border-width: row.focused ? 1px : 0px;
                    border-color: Theme.accent;
                    HorizontalLayout {
                        padding-left: 6px;
                        // Atenuar las filas cortadas (Ctrl+X) hasta pegar.
                        opacity: row.cut ? 0.45 : 1.0;
                        // Nombre con su ícono de color a la izquierda (6A). El ícono ya viene
                        // decodificado y cacheado desde Rust (slint::Image): pintarlo cuesta lo
                        // mismo que un glifo, no se re-rasteriza por frame.
                        HorizontalLayout {
                            horizontal-stretch: 50;
                            spacing: 6px;
                            Image {
                                source: row.icon;
                                width: 16px;
                                height: 16px;
                                vertical-alignment: center;
                                image-rendering: smooth;
                            }
                            Text {
                                text: row.name;
                                color: row.is-dir ? Theme.highlight : Theme.text;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                                overflow: elide;
                            }
                        }
                        Text {
                            text: row.ext;
                            color: Theme.text-dim;
                            vertical-alignment: center;
                            horizontal-stretch: 15;
                            overflow: elide;
                        }
                        Text {
                            text: row.size;
                            color: Theme.text-dim;
                            vertical-alignment: center;
                            horizontal-stretch: 15;
                            horizontal-alignment: right;
                        }
                        Text {
                            text: row.modified;
                            color: Theme.text-dim;
                            vertical-alignment: center;
                            horizontal-stretch: 20;
                            overflow: elide;
                        }
                    }
                    row-touch := TouchArea {
                        // El `clicked` de un TouchArea DENTRO de un ListView no se dispara
                        // bajo el backend winit/software: el Flickable del ListView se traga
                        // el press/release para interpretar scroll. Los eventos pointer-event
                        // SÍ llegan (el hover funciona), así que detectamos el clic a mano:
                        // press y release sobre la misma fila = clic. El doble-clic lo detecta
                        // Rust por tiempo. (Si el puntero se va entre press y release, no es
                        // clic: se cancela.)
                        property <bool> pressed-here: false;
                        // Coords del press (para detectar el inicio de un arrastre por umbral).
                        property <length> press-x;
                        property <length> press-y;
                        // Se disparó ya el arrastre OLE de este gesto (no repetir).
                        property <bool> dragging: false;
                        pointer-event(ev) => {
                            if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left) {
                                self.pressed-here = true;
                                self.dragging = false;
                                self.press-x = self.mouse-x;
                                self.press-y = self.mouse-y;
                            }
                            // Inicio de ARRASTRE OLE: el botón sigue abajo y el puntero se movió
                            // más que el umbral sobre una fila SELECCIONADA → sacar los archivos.
                            // Solo si la fila ya estaba seleccionada (arrastrar lo elegido), para
                            // no pisar el clic-para-seleccionar ni el scroll del ListView.
                            if (ev.kind == PointerEventKind.move && self.pressed-here && !self.dragging && row.selected) {
                                if (abs(self.mouse-x - self.press-x) > 6px || abs(self.mouse-y - self.press-y) > 6px) {
                                    self.dragging = true;
                                    self.pressed-here = false;
                                    root.activate(root.pane-id);
                                    root.row-drag-out(root.pane-id);
                                }
                            }
                            if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left && self.pressed-here) {
                                self.pressed-here = false;
                                root.activate(root.pane-id);
                                root.row-clicked(root.pane-id, i);
                                // Tomar el foco de teclado: así los atajos (Supr, Ctrl+C…)
                                // llegan al panel tras hacer clic en una fila. (Se hace en el
                                // `up`, ya completado el gesto, para no robar el grab del clic.)
                                root.focus();
                            }
                            // Clic derecho: seleccionar la fila y abrir el menú contextual en
                            // coords de la ventana (absolute-position del TouchArea + puntero).
                            if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.right) {
                                root.activate(root.pane-id);
                                root.row-clicked(root.pane-id, i);
                                root.row-context(
                                    root.pane-id, i,
                                    row-touch.absolute-position.x + row-touch.mouse-x,
                                    row-touch.absolute-position.y + row-touch.mouse-y);
                            }
                            if (ev.kind == PointerEventKind.cancel) {
                                self.pressed-here = false;
                            }
                        }
                        // Doble clic NATIVO de Slint (cronometrado por el SO, robusto ante la
                        // latencia del hilo de UI bajo render por software). Es el camino
                        // primario para abrir; la detección por tiempo en Rust queda de
                        // respaldo. Rust evita la doble navegación (ver on_row_double_clicked).
                        double-clicked => {
                            root.row-double-clicked(root.pane-id, i);
                        }
                    }
                }
            }
        }
    }
}
