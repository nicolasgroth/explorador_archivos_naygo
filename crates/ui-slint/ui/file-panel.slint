// Naygo — panel de archivos (Fase 2a): tabla virtualizada, encabezados, foco de teclado.
// Copyright (c) 2026 Nicolás Groth <ngroth@gmail.com>. ISGroth.
// SPDX-License-Identifier: MIT
//
// Columnas repartidas con `horizontal-stretch` (50/15/15/20) para evitar bucles de
// binding. Cada panel emite sus callbacks con su `pane-id` para que el controller sepa
// sobre cuál actuar; el panel activo lleva borde de acento.
import { ListView, LineEdit, ScrollView } from "std-widgets.slint";
import { RowData, PathSeg, ColumnVm, ColumnToggleVm } from "types.slint";
import { Tr } from "i18n.slint";
import { Theme } from "theme.slint";

// Íconos dibujados con Path (no glifos de fuente): bajo render por software los emoji/★/✓
// salían invisibles. `fill`/`stroke` los pinta el llamador según estado.

// Estrella de 5 puntas. `filled` la rellena (favorito activo) o solo la contornea.
component StarIcon inherits Rectangle {
    in property <bool> filled: false;
    in property <color> tint: Theme.highlight;
    in property <length> size: 15px;
    Path {
        width: root.size;
        height: root.size;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        fill: root.filled ? root.tint : transparent;
        stroke: root.tint;
        stroke-width: 1.2px;
        viewbox-width: 20;
        viewbox-height: 20;
        MoveTo { x: 10; y: 1; }
        LineTo { x: 12.6; y: 7.1; }
        LineTo { x: 19; y: 7.6; }
        LineTo { x: 14.2; y: 11.8; }
        LineTo { x: 15.7; y: 18; }
        LineTo { x: 10; y: 14.7; }
        LineTo { x: 4.3; y: 18; }
        LineTo { x: 5.8; y: 11.8; }
        LineTo { x: 1; y: 7.6; }
        LineTo { x: 7.4; y: 7.1; }
        Close { }
    }
}

// Portapapeles (copiar): hoja con una pestañita arriba.
component ClipboardIcon inherits Rectangle {
    in property <color> tint: Theme.text;
    in property <length> size: 14px;
    Path {
        width: root.size;
        height: root.size;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        stroke: root.tint;
        stroke-width: 1.2px;
        fill: transparent;
        viewbox-width: 16;
        viewbox-height: 16;
        // Hoja.
        MoveTo { x: 3; y: 3; }
        LineTo { x: 13; y: 3; }
        LineTo { x: 13; y: 15; }
        LineTo { x: 3; y: 15; }
        Close { }
        // Pestaña superior.
        MoveTo { x: 6; y: 1.5; }
        LineTo { x: 10; y: 1.5; }
        LineTo { x: 10; y: 4; }
        LineTo { x: 6; y: 4; }
        Close { }
    }
}

// Tilde (✓) para el feedback "copiado".
component CheckIcon inherits Rectangle {
    in property <color> tint: Theme.highlight;
    in property <length> size: 14px;
    Path {
        width: root.size;
        height: root.size;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        stroke: root.tint;
        stroke-width: 1.8px;
        fill: transparent;
        viewbox-width: 16;
        viewbox-height: 16;
        MoveTo { x: 2.5; y: 8.5; }
        LineTo { x: 6.5; y: 12.5; }
        LineTo { x: 13.5; y: 3.5; }
    }
}

component HeaderCell inherits Rectangle {
    in property <string> text;
    in property <bool> align-right: false;
    in property <int> sort-dir: 0;      // 0=ninguno 1=asc 2=desc (F2)
    in property <bool> has-filter: false;// embudo si hay filtro activo (F2)
    callback clicked();
    // Clic derecho → abre el menú de columna (ordenar/filtrar/ocultar) (F2).
    callback context-menu(length, length);
    // Redimensionar: `delta` en px arrastrados sobre el asa del borde derecho (6C).
    callback resize(length);
    background: hcell-touch.has-hover ? Theme.row-alt-bg : Theme.row-bg;
    HorizontalLayout {
        x: 6px;
        width: parent.width - 12px;
        spacing: 3px;
        // Embudo a la izquierda cuando hay filtro activo en esta columna.
        if root.has-filter: Text {
            text: "⏷";
            color: Theme.accent;
            font-size: 11px;
            vertical-alignment: center;
        }
        Text {
            text: root.text;
            color: Theme.text-dim;
            font-weight: 700;
            vertical-alignment: center;
            horizontal-alignment: root.align-right ? right : left;
            horizontal-stretch: 1;
            overflow: elide;
        }
        // Indicador de orden ▲/▼ a la derecha de la etiqueta.
        if root.sort-dir != 0: Text {
            text: root.sort-dir == 1 ? "▲" : "▼";
            color: Theme.accent;
            font-size: 10px;
            vertical-alignment: center;
        }
    }
    hcell-touch := TouchArea {
        // El asa de resize ocupa los últimos 6px del borde derecho; el resto ordena al hacer clic.
        width: parent.width - 6px;
        pointer-event(ev) => {
            if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.right) {
                root.context-menu(
                    self.absolute-position.x + self.mouse-x,
                    self.absolute-position.y + self.mouse-y);
            }
        }
        clicked => {
            root.clicked();
        }
    }
    // Asa de redimensionado: barra de 6px en el borde derecho. Arrastrar cambia el ancho.
    resize-handle := TouchArea {
        x: parent.width - 6px;
        width: 6px;
        mouse-cursor: ew-resize;
        property <length> start-x;
        property <bool> resizing: false;
        pointer-event(ev) => {
            if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left) {
                self.resizing = true;
                self.start-x = self.mouse-x;
            }
            if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left && self.resizing) {
                self.resizing = false;
                root.resize(self.mouse-x - self.start-x);
            }
            if (ev.kind == PointerEventKind.cancel) {
                self.resizing = false;
            }
        }
    }
}

// Una opción del aviso "carpeta no encontrada" (reintentar / subir / elegir / cerrar).
// Encapsula el recuadro con hover + texto + TouchArea para no duplicar el markup entre el
// `for` de las opciones y el botón "subir" que va aparte (condicionado por missing-has-ancestor).
component MissingOpButton inherits Rectangle {
    in property <string> label;
    callback clicked();
    height: 32px;
    border-radius: 5px;
    border-width: 1px;
    border-color: opt-touch.has-hover ? Theme.accent : Theme.border;
    background: opt-touch.has-hover ? Theme.selection-bg : Theme.row-bg;
    Text {
        text: root.label;
        color: Theme.text;
        vertical-alignment: center;
        x: 12px;
    }
    opt-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

export component FilePanel inherits FocusScope {
    in property <int> pane-id;
    in property <bool> active;
    // Se está ARRASTRANDO un archivo sobre ESTE panel ahora mismo: borde marcado + path-bar
    // remarcada, para indicar dónde caerá el drop. Manda sobre `active` mientras dura el arrastre.
    in property <bool> drag-over: false;
    // Hay un MODAL de operación abierto (conflicto/eliminar/aviso, etc.). Mientras sea true se
    // DESMONTA el `body-touch` exterior (ver más abajo) para que NO robe hover/clic/arrastre al
    // velo del modal: sin esto el popup queda con el hover muerto hasta el primer clic, y arrastrar
    // resalta filas que no debería. Al cerrar el modal vuelve a false → el TouchArea se re-monta.
    in property <bool> modal-open: false;
    // Hay un arrastre OLE EN CURSO (DoDragDrop corriendo su bucle modal de Windows). Rust lo pone
    // en true al lanzar el arrastre y en false cuando termina (drop procesado o cancelado). Mientras
    // es true DESMONTAMOS el `body-touch` exterior — igual que con `modal-open` — por una razón de
    // SEGURIDAD DE DATOS: el bucle modal de DoDragDrop CAPTURA el mouse y NUNCA devuelve el
    // `pointer-up` al TouchArea del panel origen, que quedaría con `pressed-here`/grab de puntero sin
    // liberar. Tras el drag, el cursor sobre OTRO panel seguiría llegando al body-touch del ORIGEN,
    // resaltando/seleccionando la fila a su misma altura (captura fantasma). Al desmontar y re-montar
    // el TouchArea nace con el estado del gesto LIMPIO y sin grab huérfano. Es la misma técnica que
    // ya usa `modal-open`, reaprovechada.
    in property <bool> drag-in-progress: false;
    in property <[RowData]> rows;
    in property <[ColumnVm]> columns;        // columnas visibles (orden/ancho/alineación) (6C)
    in property <[ColumnToggleVm]> col-menu; // TODAS las columnas para el menú agregar/quitar (6C)
    in property <length> row-h: 22px;        // alto de fila (densidad configurable)
    in property <length> scroll-y;
    // Índice de VISTA de la fila enfocada (-1 = ninguna). Lo pasa Rust desde `f.focused`. Al
    // cambiar, el cuerpo ajusta `wheel-scroll` para REVELAR esa fila (ver `changed focused-row`):
    // así navegar con ↑↓/Re-Av Pág/Inicio-Fin/typeahead/paleta vuelve a arrastrar la vista tras
    // el cursor. La ListView dejó de ser interactiva y ya no auto-scrollea sola.
    in property <int> focused-row: -1;
    // Desplazamiento por rueda del cuerpo de la lista. El ListView va con `interactive: false`
    // (su Flickable se tragaba los `move` con botón apretado y cancelaba el TouchArea hijo, así
    // que ni el arrastre ni el rubber-band funcionaban). Ahora un único TouchArea exterior
    // captura todo y la rueda mueve `wheel-scroll`; `viewport-y` lo lee de una sola vía (sin
    // ciclo de binding). 0 = arriba; crece hacia abajo (viewport-y es su negativo). Es la ÚNICA
    // fuente de scroll del cuerpo: la rueda lo mueve por delta y el auto-scroll por teclado lo
    // clampa para revelar la fila enfocada (una sola verdad → rueda y teclado no se pelean).
    property <length> wheel-scroll: 0;
    // Fila bajo el cursor según el TouchArea exterior (-1 = ninguna/zona vacía). La pinta el
    // fondo de cada fila para el efecto hover (antes lo daba el `has-hover` del row-touch).
    property <int> hover-row: -1;
    // Al cambiar el contenido (navegar / refrescar), el scroll por rueda vuelve a arriba: si no,
    // una carpeta nueva quedaría desplazada con el offset de la anterior.
    changed rows => { root.wheel-scroll = 0; }
    // Auto-scroll por teclado (C1): cuando el foco se mueve, ajusta `wheel-scroll` lo mínimo para
    // que la fila enfocada quede completamente visible dentro del viewport del ListView.
    //   · ventana visible = [wheel-scroll, wheel-scroll + visible-height]
    //   · borde superior de la fila = focused-row * row-h ; inferior = (focused-row + 1) * row-h
    // Si la fila está por ENCIMA de la ventana → llevar el scroll a su borde superior; si está por
    // DEBAJO → llevar el fondo de la fila al borde inferior. Si ya se ve, no se toca. Todo se
    // recorta a [0, alto-total - alto-visible]. `visible-height` puede ser 0 antes del primer
    // layout: en ese caso no movemos nada (al asentarse, el siguiente movimiento de foco corrige).
    changed focused-row => {
        if (root.focused-row >= 0 && list.visible-height > 0px) {
            // Tope inferior posible del scroll (no pasar del final de la lista).
            root.wheel-scroll = clamp(
                // ¿La fila cae por debajo del borde inferior? Empujar para revelarla por abajo.
                ((root.focused-row + 1) * root.row-h > root.wheel-scroll + list.visible-height)
                    ? (root.focused-row + 1) * root.row-h - list.visible-height
                    // ¿Por encima del borde superior? Subir hasta su borde superior.
                    : (root.focused-row * root.row-h < root.wheel-scroll
                        ? root.focused-row * root.row-h
                        // Ya visible: dejar el scroll como está.
                        : root.wheel-scroll),
                0px,
                max(0px, root.rows.length * root.row-h - list.visible-height));
        }
    }
    // --- Barra de ruta (breadcrumbs + edición + autocompletado) ---
    in property <[PathSeg]> segments;        // breadcrumbs de la carpeta actual
    in property <bool> editing;              // este panel está editando su ruta
    in property <string> edit-text;          // texto del editor (lo controla Rust)
    in property <[string]> suggestions;      // autocompletado del editor
    in property <bool> is-favorite;          // la carpeta actual está en favoritos (★ llena)
    in property <bool> no-matches;           // filtro activo que vació la vista → aviso (F2)
    // Carpeta no encontrada / ilegible: muestra el aviso IN-PLACE con opciones.
    in property <bool> missing;
    in property <string> missing-path;       // la ruta perdida (para mostrarla)
    in property <bool> missing-has-ancestor;  // ¿hay un ancestro existente al que subir? (ver FIX 2)
    in property <bool> missing-ejected;      // ¿la pérdida fue por expulsión de disco? (cambia el texto)
    callback missing-retry(int);             // (pane-id) reintentar
    callback missing-ancestor(int);          // (pane-id) subir al ancestro existente
    callback missing-choose(int);            // (pane-id) elegir otra carpeta (selector nativo)
    callback missing-close(int);             // (pane-id) cerrar el panel
    callback fav-toggle(int);                // (pane-id) anclar/quitar la carpeta de favoritos
    callback copy-path(int);                 // (pane-id) copiar la ruta al portapapeles
    // Tooltip de los íconos de la path-bar: (texto-o-vacío, x-centro, y-borde-inferior) en coords
    // de ventana. La AppWindow lo pinta en su overlay JUSTO debajo del ícono. Vacío al salir el mouse.
    callback hover-tip(string, length, length);
    // --- Rename inline (6D): la fila `rename-pos` muestra un editor en la celda Name. ---
    in property <int> rename-pos: -1;        // posición de vista en edición (-1 = ninguna)
    in property <string> rename-text;        // nombre inicial del editor
    callback rename-commit(int, string);     // (pos, nombre) Enter → renombrar
    callback rename-chain(int, string, int); // (pos, nombre, dir) ↑/↓ → encadenar
    callback rename-cancel();                // Esc → cerrar
    callback segment-clicked(int, string);   // (pane-id, ruta) clic en un breadcrumb → navegar
    callback path-edit-start(int);           // (pane-id) entrar a modo edición
    callback path-edit-changed(int, string); // (pane-id, texto) recalcular autocompletado
    callback path-edit-commit(int, string);  // (pane-id, texto) Enter → navegar
    callback path-edit-cancel(int);          // (pane-id) Esc → salir de edición
    callback suggestion-clicked(int, string);// (pane-id, nombre) elegir un candidato
    callback row-clicked(int, int);          // (pane-id, pos)
    callback row-double-clicked(int, int);
    callback row-drag-out(int);              // (pane-id) inicia el arrastre OLE de lo selecto
    callback rubber-band(int, int, int);     // (pane-id, from-pos, to-pos) selección por rectángulo
    callback row-context(int, int, length, length); // (pane-id, pos, x-ventana, y-ventana)
    // Clic derecho en la ZONA VACÍA del panel: menú contextual de la CARPETA (Explorador,
    // terminal, nueva carpeta…), no de un archivo. (pane-id, x-ventana, y-ventana)
    callback empty-context(int, length, length);
    callback sort-by(int, string);           // (pane-id, columna) — legado (no usado por el header)
    callback sort-by-kind(int, int);         // (pane-id, kind) ordenar por columna dinámica
    callback column-toggle(int, int);        // (pane-id, kind) mostrar/ocultar columna
    callback column-move(int, int, int);     // (pane-id, from, to) reordenar columnas
    callback column-resize(int, int, length);// (pane-id, kind, ancho) redimensionar
    callback column-context(int, int, length, length); // (pane-id, kind, x, y) clic derecho en header (F2)
    // Menú de columnas abierto (clic en "Columnas…"): muestra los toggles.
    property <bool> col-menu-open: false;
    callback activate(int);                  // (pane-id) al interactuar
    callback key(string, bool, bool, bool);
    // Soltado de tecla: reporta el estado REAL de los modificadores tras el release, para que
    // Rust resetee `ctrl_down`/`shift_down`. Sin esto, un Ctrl pegado tras Ctrl+C hacía que el
    // siguiente doble-clic en carpeta abriera-en-otro-panel en vez de navegar.
    callback key-release(bool, bool, bool);  // (ctrl, shift, alt) — modificadores vigentes
    // Botones laterales del mouse (atrás/adelante) sobre este panel: navegan su historial.
    callback nav-back(int);                  // (pane-id)
    callback nav-forward(int);               // (pane-id)
    // Vista profunda (recursiva): toggle en la barra + estado on/off.
    in property <bool> deep-active: false;
    callback toggle-deep(int);               // (pane-id)
    // Barra inferior (footer): texto de selección/espacio de disco. Vacío = barra oculta.
    in property <string> footer-text;

    key-pressed(event) => {
        root.activate(root.pane-id);
        root.key(event.text, event.modifiers.control, event.modifiers.shift, event.modifiers.alt);
        accept
    }

    // Al soltar una tecla, reportamos el estado vigente de los modificadores. Cuando se suelta
    // Ctrl, `event.modifiers.control` ya viene en false, así que Rust limpia `ctrl_down` (idem
    // Shift). Es la fuente más fiable: rastrea el estado real, no adivina por el texto.
    key-released(event) => {
        root.key-release(event.modifiers.control, event.modifiers.shift, event.modifiers.alt);
        accept
    }

    // C2: al entrar a rename el `body-touch` se desmonta y `hover-row` se queda congelado en la
    // última fila bajo el cursor → quedaría una fila con el fondo de hover pegado. Lo limpiamos al
    // empezar a editar (y también al salir, por simetría: el puntero pudo moverse con el editor
    // tapando el cuerpo).
    changed rename-pos => { root.hover-row = -1; }

    // Mismo motivo que arriba para el arrastre OLE: mientras dura el drag el `body-touch` está
    // desmontado y `hover-row` se quedaría congelado en la fila que estaba bajo el cursor al empezar
    // → un resaltado fantasma pegado. Lo limpiamos al entrar Y al salir del arrastre (al salir, el
    // cursor pudo terminar sobre otro panel: este no debe mostrar hover hasta que el TouchArea
    // re-montado reciba un `moved` real).
    changed drag-in-progress => { root.hover-row = -1; }

    // Cuando este panel pasa a ser el activo, tomar el foco de teclado para que las teclas
    // lleguen sin necesidad de un clic previo (p. ej. tras Tab o al arrancar).
    changed active => {
        if (root.active) {
            root.focus();
        }
    }

    // Marca del panel activo: borde de acento MÁS marcado (2px) + una sutil bruma de acento de
    // fondo, para que se distinga claramente del panel inactivo de un vistazo.
    // DRAG-OVER (arrastrando un archivo sobre este panel): borde AÚN más grueso (3px) de acento a
    // plena intensidad + bruma más notoria, para gritar "aquí soltarás". Manda sobre `active`.
    Rectangle {
        border-width: root.drag-over ? 3px : (root.active ? 2px : 1px);
        border-color: (root.drag-over || root.active) ? Theme.accent : Theme.border;
        border-radius: 4px;
        background: root.drag-over
            ? Theme.accent.with-alpha(0.14)
            : (root.active ? Theme.accent.with-alpha(0.05) : transparent);
        VerticalLayout {
            // --- Barra de ruta: breadcrumbs (modo normal) o editor con autocompletado. ---
            Rectangle {
                height: 26px;
                // Cuando el panel está activo, la path-bar lleva un fondo de acento tenue para
                // resaltar dónde está el foco. Al arrastrar encima (drag-over) se remarca más fuerte
                // para reforzar que ese es el destino del drop.
                background: root.drag-over
                    ? Theme.accent.with-alpha(0.32)
                    : (root.active ? Theme.accent.with-alpha(0.18) : Theme.row-bg);
                border-radius: 4px;
                // Modo BREADCRUMB: segmentos clicables; clic en el hueco entra a edición.
                if !root.editing: HorizontalLayout {
                    padding-left: 4px;
                    spacing: 0px;
                    for seg[i] in root.segments: Rectangle {
                        width: seg-label.preferred-width + 10px;
                        background: seg-touch.has-hover ? Theme.selection-bg : transparent;
                        border-radius: 3px;
                        seg-label := Text {
                            text: (i == 0 ? "" : "› ") + seg.label;
                            color: Theme.text;
                            vertical-alignment: center;
                            x: 4px;
                        }
                        seg-touch := TouchArea {
                            pointer-event(ev) => {
                                if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left) {
                                    root.activate(root.pane-id);
                                    root.segment-clicked(root.pane-id, seg.path);
                                }
                            }
                        }
                    }
                    // Zona vacía a la derecha: clic = editar la ruta.
                    Rectangle {
                        horizontal-stretch: 1;
                        edit-touch := TouchArea {
                            pointer-event(ev) => {
                                if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left) {
                                    root.activate(root.pane-id);
                                    root.path-edit-start(root.pane-id);
                                }
                            }
                        }
                    }
                    // ★ favorito (toggle): lleno si la carpeta ya está anclada.
                    Rectangle {
                        width: 24px;
                        background: fav-touch.has-hover ? Theme.selection-bg : transparent;
                        border-radius: 3px;
                        StarIcon {
                            width: 100%;
                            height: 100%;
                            filled: root.is-favorite;
                            tint: root.is-favorite ? Theme.highlight : Theme.text-dim;
                        }
                        fav-touch := TouchArea {
                            pointer-event(ev) => {
                                if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left) {
                                    root.fav-toggle(root.pane-id);
                                }
                            }
                            changed has-hover => {
                                root.hover-tip(self.has-hover ? Tr.pathbar-fav-tip : "",
                                    self.absolute-position.x + self.width / 2,
                                    self.absolute-position.y + self.height);
                            }
                        }
                    }
                    // 📋 copiar la ruta de la carpeta al portapapeles. Al copiar, el ícono cambia
                    // a ✓ por ~1s (feedback inmediato en el lugar del clic).
                    copy-box := Rectangle {
                        width: 26px;
                        background: copy-touch.has-hover ? Theme.selection-bg : transparent;
                        border-radius: 3px;
                        property <bool> flashed: false;
                        // ✓ al copiar, si no el portapapeles. Ambos dibujados con Path.
                        if copy-box.flashed: CheckIcon { width: 100%; height: 100%; tint: Theme.highlight; }
                        if !copy-box.flashed: ClipboardIcon { width: 100%; height: 100%; tint: Theme.text; }
                        // Apaga el ✓ tras ~1s.
                        flash-timer := Timer {
                            interval: 1s;
                            running: copy-box.flashed;
                            triggered => { copy-box.flashed = false; self.running = false; }
                        }
                        copy-touch := TouchArea {
                            pointer-event(ev) => {
                                if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left) {
                                    root.copy-path(root.pane-id);
                                    copy-box.flashed = true;
                                }
                            }
                            changed has-hover => {
                                root.hover-tip(self.has-hover ? Tr.pathbar-copy-tip : "",
                                    self.absolute-position.x + self.width / 2,
                                    self.absolute-position.y + self.height);
                            }
                        }
                    }
                    // Botón toggle de vista profunda: tres líneas escalonadas. Se pinta con
                    // fondo de acento cuando está activo o al pasar el cursor.
                    Rectangle {
                        width: 26px;
                        height: 22px;
                        border-radius: 4px;
                        background: deep-touch.has-hover || root.deep-active ? Theme.accent : transparent;
                        Path {
                            width: 14px;
                            height: 14px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            stroke: (deep-touch.has-hover || root.deep-active) ? white : Theme.text-dim;
                            stroke-width: 1.3px;
                            fill: transparent;
                            viewbox-width: 14;
                            viewbox-height: 14;
                            MoveTo { x: 1; y: 3; }   LineTo { x: 9; y: 3; }
                            MoveTo { x: 4; y: 7; }   LineTo { x: 12; y: 7; }
                            MoveTo { x: 7; y: 11; }  LineTo { x: 13; y: 11; }
                        }
                        deep-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.toggle-deep(root.pane-id); }
                            changed has-hover => {
                                root.hover-tip(self.has-hover ? Tr.deep-view-tip : "",
                                    self.absolute-position.x + self.width / 2,
                                    self.absolute-position.y + self.height);
                            }
                        }
                    }
                }
                // Modo EDICIÓN: LineEdit con la ruta; Enter navega, Esc cancela, perder foco
                // (clic afuera) vuelve a los breadcrumbs.
                if root.editing: path-edit := LineEdit {
                    text: root.edit-text;
                    placeholder-text: "C:\\…";
                    // Tomar el foco al abrir el editor (si no, el clic que lo abrió no enfoca el
                    // LineEdit y el "perder foco" nunca tendría foco que perder).
                    init => { self.focus(); }
                    edited(t) => { root.path-edit-changed(root.pane-id, t); }
                    accepted(t) => { root.path-edit-commit(root.pane-id, t); }
                    // Al perder el foco (clic afuera) salir de edición → vuelve a breadcrumbs.
                    changed has-focus => {
                        if (!self.has-focus) {
                            root.path-edit-cancel(root.pane-id);
                        }
                    }
                    key-pressed(ev) => {
                        if (ev.text == Key.Escape) {
                            root.path-edit-cancel(root.pane-id);
                            return accept;
                        }
                        return reject;
                    }
                }
            }
            // Autocompletado: lista flotante de candidatos bajo el editor (solo en edición).
            if root.editing && root.suggestions.length > 0: Rectangle {
                height: min(root.suggestions.length * 22px + 4px, 132px);
                background: Theme.row-bg;
                border-width: 1px;
                border-color: Theme.selection-bg;
                border-radius: 4px;
                ListView {
                    for s[i] in root.suggestions: Rectangle {
                        height: 22px;
                        background: sug-touch.has-hover ? Theme.selection-bg : transparent;
                        Text {
                            text: "📁 " + s;
                            color: Theme.text;
                            vertical-alignment: center;
                            x: 6px;
                        }
                        sug-touch := TouchArea {
                            pointer-event(ev) => {
                                if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left) {
                                    root.suggestion-clicked(root.pane-id, s);
                                }
                            }
                        }
                    }
                }
            }
            // Encabezado dinámico: una HeaderCell por columna visible, con su ancho persistido.
            // Clic = ordenar por esa columna; arrastrar el borde derecho = redimensionar (6C).
            // El botón "≡" al final abre el menú de columnas (agregar/quitar).
            HorizontalLayout {
                height: 22px;
                for col[ci] in root.columns: HeaderCell {
                    width: col.width;
                    text: col.label;
                    align-right: col.align-right;
                    sort-dir: col.sort-dir;
                    has-filter: col.has-filter;
                    clicked => {
                        root.sort-by-kind(root.pane-id, col.kind);
                    }
                    context-menu(x, y) => {
                        root.column-context(root.pane-id, col.kind, x, y);
                    }
                    resize(delta) => {
                        root.column-resize(root.pane-id, col.kind, col.width + delta);
                    }
                }
                // Botón de menú de columnas (al final, ancho fijo).
                Rectangle {
                    width: 24px;
                    background: colbtn-touch.has-hover ? Theme.row-alt-bg : Theme.row-bg;
                    Text { text: "≡"; color: Theme.text-dim; horizontal-alignment: center; vertical-alignment: center; }
                    colbtn-touch := TouchArea {
                        clicked => { root.col-menu-open = !root.col-menu-open; }
                    }
                }
            }
            // Cuerpo de la lista. El ListView va con `interactive: false`: su Flickable arbitraba
            // los `move` con botón apretado para hacer scroll y CANCELABA el TouchArea de cada
            // fila, de modo que ni el arrastre OLE ni la selección por rectángulo recibían los
            // `move` (el clic sí, porque el Flickable reenvía press+release sin movimiento). Ahora
            // un único TouchArea exterior (`body-touch`, hermano POSTERIOR del ListView, por
            // ENCIMA en z-order) captura TODOS los eventos crudos y deduce la fila por la `y` + el
            // scroll. La rueda se re-implementa con `scroll-event` moviendo `wheel-scroll`.
            Rectangle {
                // I5: durante el rename, un TouchArea de fondo de BAJA prioridad (primer hijo → por
                // DEBAJO del ListView en z-order) que existe SOLO mientras se edita. La fila-editor
                // es un LineEdit real que queda POR ENCIMA, así que sigue recibiendo sus clics; pero
                // un clic en el resto del cuerpo (zona vacía / otra fila) cae a este TouchArea —el
                // Flickable del ListView no es interactivo y reenvía el clic— y le quita el foco al
                // editor (lo lleva al FocusScope raíz). Eso dispara el `changed has-focus` del
                // LineEdit, que CONFIRMA el rename. Así clic-fuera cierra el rename como espera el
                // usuario. (No usamos `body-touch` aquí porque va por ENCIMA y taparía el editor.)
                if root.rename-pos != -1: TouchArea {
                    pointer-event(ev) => {
                        if (ev.kind == PointerEventKind.down) {
                            root.activate(root.pane-id);
                            root.focus();
                        }
                    }
                }
                list := ListView {
                // El ListView (std-widgets) NO expone `interactive`; su Flickable interno ya viene
                // con `interactive: false` en el estilo fluent, pero igual interceptaba el `move`
                // del TouchArea hijo. La solución es el `body-touch` exterior (abajo): al estar por
                // ENCIMA en z-order, agarra el puntero antes que el Flickable y le quita los
                // eventos. El scroll lo maneja `body-touch` por la rueda; `viewport-y` lee
                // `wheel-scroll` de una sola vía (0 arriba, NEGATIVO al bajar) sin ciclo de binding.
                viewport-y: -(root.scroll-y + root.wheel-scroll);
                for row[i] in root.rows: Rectangle {
                    height: root.row-h;
                    // Fondo de la cebra para un panel NO activo. Tres casos:
                    //  - flat-inactive-panels ON  → TODAS las filas con row-inactive-bg (panel plano,
                    //    sin "líneas"), para que se distinga aún más del panel activo.
                    //  - flat OFF                 → cebra con row-inactive-bg de base + la franja sutil
                    //    en las impares (igual estructura que el panel activo, pero sobre el color de
                    //    inactivo). Con el default (row-inactive-bg = row-bg) no se nota el cambio.
                    property <brush> inactive-zebra: Theme.flat-inactive-panels
                        ? Theme.row-inactive-bg
                        : (mod(i, 2) == 1 ? Theme.row-alt-bg.with-alpha(0.35) : Theme.row-inactive-bg);
                    // Fondo: selección > resaltado (recién aparecido) > hover > cebra de base. La
                    // selección, el resaltado y el hover MANDAN por encima de activo/inactivo. La cebra
                    // de base depende de si el panel está activo: activo = cebra clásica (par transparente
                    // sobre el panel); inactivo = `inactive-zebra` (atenuable o plana).
                    background: row.selected
                        ? Theme.selection-bg
                        : (row.highlight
                            ? Theme.highlight.with-alpha(0.22)
                            : (i == root.hover-row
                                ? Theme.row-alt-bg
                                : (root.active
                                    ? (mod(i, 2) == 1 ? Theme.row-alt-bg.with-alpha(0.35) : transparent)
                                    : self.inactive-zebra)));
                    border-width: row.focused ? 1px : 0px;
                    border-color: Theme.accent;
                    border-radius: 3px;
                    HorizontalLayout {
                        padding-left: 6px;
                        // Atenuar las filas cortadas (Ctrl+X) hasta pegar.
                        opacity: row.cut ? 0.45 : 1.0;
                        // Celdas dinámicas: una por columna visible, con su ancho. La columna Name
                        // (kind 0) se pinta como ícono + nombre; las demás como texto de `cells[ci]`.
                        // El ícono cacheado (6A) cuesta como un glifo: no se re-rasteriza por frame.
                        for col[ci] in root.columns: HorizontalLayout {
                            width: col.width;
                            spacing: 6px;
                            // Sangría por profundidad (vista profunda). depth=0 => sin efecto.
                            if col.kind == 0 && row.depth > 0: Rectangle { width: row.depth * 14px; }
                            if col.kind == 0: Image {
                                source: row.icon;
                                width: 16px;
                                height: 16px;
                                vertical-alignment: center;
                                image-rendering: smooth;
                            }
                            // Editor inline de rename (6D): en la celda Name de la fila en edición.
                            // Enter confirma; ↑/↓ encadenan al anterior/siguiente; Esc cancela.
                            if col.kind == 0 && root.rename-pos == i: rename-edit := LineEdit {
                                text: root.rename-text;
                                horizontal-stretch: 1;
                                font-size: 13px;
                                init => { self.focus(); self.select-all(); }
                                accepted => { root.rename-commit(i, self.text); }
                                // I5: perder el foco (clic fuera del editor) CONFIRMA el rename con
                                // el texto actual, igual que el editor de la path-bar. `rename-commit`
                                // es idempotente (nombre igual/ inválido = no-op), así que esto es
                                // seguro incluso cuando el cierre lo provoca Esc (cancel) o ↑/↓
                                // (chain, que ya commiteó): no dispara renames duplicados ni ops vacías.
                                changed has-focus => {
                                    if (!self.has-focus) {
                                        root.rename-commit(i, self.text);
                                    }
                                }
                                key-pressed(ev) => {
                                    if (ev.text == Key.Escape) {
                                        root.rename-cancel();
                                        return accept;
                                    }
                                    if (ev.text == Key.UpArrow) {
                                        root.rename-chain(i, self.text, -1);
                                        return accept;
                                    }
                                    if (ev.text == Key.DownArrow) {
                                        root.rename-chain(i, self.text, 1);
                                        return accept;
                                    }
                                    reject
                                }
                            }
                            if !(col.kind == 0 && root.rename-pos == i): Text {
                                text: row.cells[ci];
                                color: col.kind == 0
                                    ? (row.is-dir ? Theme.highlight : Theme.text)
                                    : Theme.text-dim;
                                vertical-alignment: center;
                                horizontal-alignment: col.align-right ? right : left;
                                horizontal-stretch: 1;
                                overflow: elide;
                            }
                        }
                    }
                    // La fila es solo VISUAL: ya no lleva TouchArea propio. Todo el input lo captura
                    // `body-touch` (abajo), por encima del ListView.
                }
                }
                // TouchArea exterior: ÚLTIMO hijo del cuerpo (por ENCIMA del ListView en z-order),
                // captura TODOS los eventos crudos y deduce la fila por la `y` + el scroll. Se
                // oculta durante el rename inline para no tapar el editor de la celda Name (durante
                // el rename no se necesita clic-en-vacío). También se DESMONTA si hay un modal abierto
                // (`modal-open`): así no roba hover/clic al velo del modal; vuelve al cerrarse este.
                if root.rename-pos == -1 && !root.modal-open && !root.drag-in-progress: body-touch := TouchArea {
                    // Estado del gesto en curso. `pressed-here`: hay un press de botón izquierdo
                    // vivo. `dragging`: ya se disparó el arrastre OLE (no repetir). `press-x/y`:
                    // dónde empezó (umbral clic-vs-arrastre). `start-row`: fila bajo el press.
                    property <bool> pressed-here: false;
                    property <bool> dragging: false;
                    property <length> press-x;
                    property <length> press-y;
                    property <int> start-row: -1;
                    // Fila ABSOLUTA bajo el cursor. `viewport-y` es 0 arriba y NEGATIVO al bajar, así
                    // que `mouse-y - viewport-y` = posición absoluta en el contenido. Puede caer
                    // fuera de rango (zona vacía): el llamador valida contra `rows.length`.
                    property <int> cur-row: floor((self.mouse-y - list.viewport-y) / root.row-h);
                    // ¿`start-row` es una fila real Y estaba seleccionada? (decide OLE vs rubber-band)
                    property <bool> start-selected:
                        self.start-row >= 0 && self.start-row < root.rows.length
                            ? root.rows[self.start-row].selected
                            : false;
                    // Hover: expón la fila bajo el cursor para que el fondo de la fila la resalte.
                    // -1 cuando el puntero no está sobre el cuerpo o cae en zona vacía.
                    changed has-hover => {
                        root.hover-row = (self.has-hover && self.cur-row >= 0 && self.cur-row < root.rows.length)
                            ? self.cur-row : -1;
                    }
                    moved => {
                        root.hover-row = (self.has-hover && self.cur-row >= 0 && self.cur-row < root.rows.length)
                            ? self.cur-row : -1;
                        // Inicio de ARRASTRE OLE: botón abajo, movimiento > umbral, con el press sobre
                        // una FILA REAL (esté o no seleccionada) → sacar lo elegido. Así arrastrar un
                        // archivo de un tirón (clic + arrastre en un solo gesto) funciona, como en el
                        // Explorador de Windows. Si la fila NO estaba seleccionada, se selecciona ella
                        // sola primero (row-clicked sin modificadores) para arrastrar lo correcto.
                        // Umbral de 12px (antes 6px): subido a propósito para reducir arrastres OLE
                        // accidentales por micro-movimientos del mouse al hacer clic (decisión de
                        // Nicolás: "umbral mayor + confirmar al soltar"). El rubber-band de abajo usa
                        // el mismo umbral por consistencia.
                        if (self.pressed-here && !self.dragging
                            && self.start-row >= 0 && self.start-row < root.rows.length
                            && (abs(self.mouse-x - self.press-x) > 12px || abs(self.mouse-y - self.press-y) > 12px)) {
                            self.dragging = true;
                            self.pressed-here = false;
                            root.activate(root.pane-id);
                            if (!self.start-selected) {
                                root.row-clicked(root.pane-id, self.start-row);
                            }
                            root.row-drag-out(root.pane-id);
                        }
                        // RUBBER-BAND (6F): arrastrar desde ZONA VACÍA (el press NO cayó sobre ninguna
                        // fila) selecciona el rango [start-row, cur-row], ambos ABSOLUTOS. Rust
                        // (select_rect_range) ordena y recorta el rango; Ctrl = aditivo. El alto de
                        // fila usa `row-h` (no 22px hardcodeado como el rubber-band viejo). Arrastrar
                        // SOBRE una fila ya no hace rubber-band: hace arrastre OLE (arriba).
                        if (self.pressed-here && !self.dragging
                            && (self.start-row < 0 || self.start-row >= root.rows.length)
                            && abs(self.mouse-y - self.press-y) > 12px) {
                            root.activate(root.pane-id);
                            root.rubber-band(root.pane-id, self.start-row, self.cur-row);
                        }
                    }
                    pointer-event(ev) => {
                        if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left) {
                            self.pressed-here = true;
                            self.dragging = false;
                            self.press-x = self.mouse-x;
                            self.press-y = self.mouse-y;
                            self.start-row = self.cur-row;
                            root.activate(root.pane-id);
                            root.focus();
                        }
                        // Soltar el botón izquierdo SIN haber arrastrado = clic. Sobre fila válida →
                        // seleccionar (Rust aplica Ctrl/Shift) y tomar el foco para que Supr/Ctrl+C
                        // lleguen al panel. En zona vacía: solo activar (ya se hizo en el down).
                        if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left && self.pressed-here) {
                            self.pressed-here = false;
                            if (self.cur-row >= 0 && self.cur-row < root.rows.length) {
                                root.row-clicked(root.pane-id, self.cur-row);
                                root.focus();
                            }
                        }
                        // Botones laterales del mouse: atrás/adelante en el historial del panel.
                        if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.back) {
                            root.nav-back(root.pane-id);
                        }
                        if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.forward) {
                            root.nav-forward(root.pane-id);
                        }
                        // Clic derecho: sobre fila válida la selecciona y abre el menú del ARCHIVO;
                        // en zona vacía abre el menú de la CARPETA. Coords en la ventana
                        // (absolute-position + puntero).
                        if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.right) {
                            root.activate(root.pane-id);
                            if (self.cur-row >= 0 && self.cur-row < root.rows.length) {
                                root.row-clicked(root.pane-id, self.cur-row);
                                root.row-context(
                                    root.pane-id, self.cur-row,
                                    self.absolute-position.x + self.mouse-x,
                                    self.absolute-position.y + self.mouse-y);
                            } else {
                                root.empty-context(
                                    root.pane-id,
                                    self.absolute-position.x + self.mouse-x,
                                    self.absolute-position.y + self.mouse-y);
                            }
                        }
                        if (ev.kind == PointerEventKind.cancel) {
                            self.pressed-here = false;
                            self.dragging = false;
                        }
                    }
                    // Doble clic NATIVO de Slint (cronometrado por el SO, robusto bajo render por
                    // software). Camino primario para abrir; la detección por tiempo en Rust queda
                    // de respaldo (evita la doble navegación, ver on_row_double_clicked).
                    double-clicked => {
                        if (self.cur-row >= 0 && self.cur-row < root.rows.length) {
                            root.row-double-clicked(root.pane-id, self.cur-row);
                        }
                    }
                    // Scroll por rueda: el ListView ya no lo hace (interactive:false). Movemos
                    // `wheel-scroll` en [0, alto-total - alto-visible]. `delta-y` es negativo al
                    // rodar hacia abajo, así que restarlo BAJA (aumenta wheel-scroll). Si el
                    // contenido cabe entero, el clamp deja el valor en 0.
                    scroll-event(ev) => {
                        root.wheel-scroll = clamp(
                            root.wheel-scroll - ev.delta-y,
                            0px,
                            max(0px, root.rows.length * root.row-h - self.height));
                        return accept;
                    }
                }
            }
            // Barra inferior (footer): resumen de selección / espacio de disco. Va al FONDO del
            // panel como último hijo del VerticalLayout; alto fijo de 22px (la lista de arriba se
            // queda con el resto del alto). Solo se pinta si hay texto que mostrar.
            if root.footer-text != "": Rectangle {
                height: 22px;
                background: Theme.row-alt-bg;
                // Borde superior fino que separa el footer del contenido.
                Rectangle { y: 0; height: 1px; width: parent.width; background: Theme.border; }
                Text {
                    x: 8px;
                    width: parent.width - 16px;
                    height: parent.height;
                    vertical-alignment: center;
                    text: root.footer-text;
                    color: Theme.text-dim;
                    font-size: 12px;
                    overflow: elide;
                }
            }
        }
        // Menú "Columnas…" (6C): flota arriba-derecha al pulsar el botón ≡ del header. Cada
        // entrada togglea su columna; Name es fija (deshabilitada).
        if root.col-menu-open: Rectangle {
            x: parent.width - self.width - 8px;
            y: 50px;
            width: 180px;
            height: menu-col.preferred-height + 8px;
            background: Theme.panel-bg;
            border-color: Theme.selection-bg;
            border-width: 1px;
            border-radius: 4px;
            menu-col := VerticalLayout {
                padding: 4px;
                spacing: 2px;
                for item in root.col-menu: Rectangle {
                    height: 24px;
                    background: item-touch.has-hover && !item.fixed ? Theme.selection-bg : transparent;
                    border-radius: 3px;
                    HorizontalLayout {
                        padding-left: 6px;
                        spacing: 6px;
                        Text {
                            text: item.visible ? "✓" : "  ";
                            color: Theme.highlight;
                            width: 14px;
                            vertical-alignment: center;
                        }
                        Text {
                            text: item.label;
                            color: item.fixed ? Theme.text-dim : Theme.text;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                    }
                    item-touch := TouchArea {
                        enabled: !item.fixed;
                        clicked => { root.column-toggle(root.pane-id, item.kind); }
                    }
                }
            }
        }
        // Aviso "sin coincidencias" (F2): centrado sobre la lista cuando un filtro la vació.
        if root.no-matches: Rectangle {
            y: parent.height / 2;
            height: 1px;
            Text {
                text: Tr.no-matches;
                color: Theme.text-dim;
                font-size: 13px;
                horizontal-alignment: center;
            }
        }
        // Aviso "carpeta no encontrada" IN-PLACE: cubre el área del panel cuando su carpeta no
        // existe/ilegible (USB sacado, red caída, ruta muerta). Trae la ruta perdida + las 4
        // opciones (reintentar / subir / elegir otra / cerrar panel). Cada botón emite con el
        // pane-id para que el controlador actúe sobre ESTE panel.
        if root.missing: Rectangle {
            background: Theme.panel-bg;
            ScrollView {
            VerticalLayout {
                alignment: start;
                spacing: 10px;
                padding: 20px;
                Text {
                    text: root.missing-ejected ? Tr.missing-title-ejected : Tr.missing-title;
                    color: Theme.text;
                    font-size: 15px;
                    font-weight: 700;
                    horizontal-alignment: center;
                }
                Text {
                    text: root.missing-ejected ? Tr.missing-body-ejected : Tr.missing-body;
                    color: Theme.text-dim;
                    font-size: 12px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
                Rectangle {
                    height: lost-txt.preferred-height + 12px;
                    background: Theme.row-bg;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: Theme.border;
                    lost-txt := Text {
                        text: root.missing-path;
                        color: Theme.highlight;
                        font-size: 12px;
                        x: 8px;
                        width: max(0px, parent.width - 16px);
                        vertical-alignment: center;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                }
                // Opciones (una por fila): reintentar / subir / elegir / cerrar. "Subir un nivel"
                // solo aparece si hay un ancestro existente real (si la unidad entera se
                // desconectó no tiene sentido: caería al HOME). Todas dependen solo de root.missing.
                MissingOpButton {
                    label: Tr.missing-retry;
                    clicked => { root.missing-retry(root.pane-id); }
                }
                if root.missing-has-ancestor: MissingOpButton {
                    label: Tr.missing-ancestor;
                    clicked => { root.missing-ancestor(root.pane-id); }
                }
                MissingOpButton {
                    label: Tr.missing-choose;
                    clicked => { root.missing-choose(root.pane-id); }
                }
                MissingOpButton {
                    label: Tr.missing-close;
                    clicked => { root.missing-close(root.pane-id); }
                }
            }
            }
        }
    }
}
