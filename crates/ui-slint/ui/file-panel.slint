// Naygo — panel de archivos (Fase 1): tabla virtualizada, encabezados, foco de teclado.
// Copyright (c) 2026 Nicolás Groth / ISGroth. MIT License.
//
// Las columnas se reparten con `horizontal-stretch` (50/15/15/20) en el HorizontalLayout,
// evitando anchos explícitos que referencien el ancho del padre (eso crea un bucle de
// binding en Slint). Encabezados y celdas usan el mismo factor → quedan alineados.
import { ListView } from "std-widgets.slint";
import { RowData } from "types.slint";

// Celda de encabezado clicable (ordena por su columna).
component HeaderCell inherits Rectangle {
    in property <string> text;
    callback clicked();
    background: hcell-touch.has-hover ? #243650 : #1b2838;
    Text {
        text: root.text;
        color: #9ab;
        font-weight: 700;
        vertical-alignment: center;
        x: 6px;
    }
    hcell-touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

export component FilePanel inherits FocusScope {
    in property <[RowData]> rows;
    in property <length> scroll-y;            // el controller lo fija para seguir el foco
    callback row-clicked(int);                // (pos de vista); modificadores via teclado en Rust
    callback row-double-clicked(int);
    callback sort-by(string);                 // "name"|"ext"|"size"|"modified"
    callback key(string, bool, bool, bool);   // (texto, ctrl, shift, alt)

    key-pressed(event) => {
        root.key(event.text, event.modifiers.control, event.modifiers.shift, event.modifiers.alt);
        accept
    }

    VerticalLayout {
        // Encabezados de columna (clic ordena). Mismos stretch que las celdas.
        HorizontalLayout {
            height: 22px;
            HeaderCell {
                text: "Nombre";
                horizontal-stretch: 50;
                clicked => {
                    root.sort-by("name");
                }
            }
            HeaderCell {
                text: "Extensión";
                horizontal-stretch: 15;
                clicked => {
                    root.sort-by("ext");
                }
            }
            HeaderCell {
                text: "Tamaño";
                horizontal-stretch: 15;
                clicked => {
                    root.sort-by("size");
                }
            }
            HeaderCell {
                text: "Modificado";
                horizontal-stretch: 20;
                clicked => {
                    root.sort-by("modified");
                }
            }
        }
        // Lista VIRTUALIZADA (solo materializa filas visibles).
        list := ListView {
            viewport-y: root.scroll-y;
            for row[i] in root.rows: Rectangle {
                height: 22px;
                background: row.selected ? #2a4a7a : (row-touch.has-hover ? #1f3350 : transparent);
                border-width: row.focused ? 1px : 0px;
                border-color: #4f8ae0;
                HorizontalLayout {
                    padding-left: 6px;
                    Text {
                        text: (row.is-dir ? "📁 " : "") + row.name;
                        color: row.is-dir ? #ffd479 : #dde;
                        vertical-alignment: center;
                        horizontal-stretch: 50;
                        overflow: elide;
                    }
                    Text {
                        text: row.ext;
                        color: #9ab;
                        vertical-alignment: center;
                        horizontal-stretch: 15;
                        overflow: elide;
                    }
                    Text {
                        text: row.size;
                        color: #9ab;
                        vertical-alignment: center;
                        horizontal-stretch: 15;
                        horizontal-alignment: right;
                    }
                    Text {
                        text: row.modified;
                        color: #9ab;
                        vertical-alignment: center;
                        horizontal-stretch: 20;
                        overflow: elide;
                    }
                }
                row-touch := TouchArea {
                    clicked => {
                        root.focus();
                        root.row-clicked(i);
                    }
                    double-clicked => {
                        root.row-double-clicked(i);
                    }
                }
            }
        }
    }
}
