// Naygo — panel de archivos (Fase 2a): tabla virtualizada, encabezados, foco de teclado.
// Copyright (c) 2026 Nicolás Groth / ISGroth. MIT License.
//
// Columnas repartidas con `horizontal-stretch` (50/15/15/20) para evitar bucles de
// binding. Cada panel emite sus callbacks con su `pane-id` para que el controller sepa
// sobre cuál actuar; el panel activo lleva borde de acento.
import { ListView, LineEdit } from "std-widgets.slint";
import { RowData, PathSeg, ColumnVm, ColumnToggleVm } from "types.slint";
import { Tr } from "i18n.slint";
import { Theme } from "theme.slint";

component HeaderCell inherits Rectangle {
    in property <string> text;
    in property <bool> align-right: false;
    in property <int> sort-dir: 0;      // 0=ninguno 1=asc 2=desc (F2)
    in property <bool> has-filter: false;// embudo si hay filtro activo (F2)
    callback clicked();
    // Clic derecho → abre el menú de columna (ordenar/filtrar/ocultar) (F2).
    callback context-menu(length, length);
    // Redimensionar: `delta` en px arrastrados sobre el asa del borde derecho (6C).
    callback resize(length);
    background: hcell-touch.has-hover ? Theme.row-alt-bg : Theme.row-bg;
    HorizontalLayout {
        x: 6px;
        width: parent.width - 12px;
        spacing: 3px;
        // Embudo a la izquierda cuando hay filtro activo en esta columna.
        if root.has-filter: Text {
            text: "⏷";
            color: Theme.accent;
            font-size: 11px;
            vertical-alignment: center;
        }
        Text {
            text: root.text;
            color: Theme.text-dim;
            font-weight: 700;
            vertical-alignment: center;
            horizontal-alignment: root.align-right ? right : left;
            horizontal-stretch: 1;
            overflow: elide;
        }
        // Indicador de orden ▲/▼ a la derecha de la etiqueta.
        if root.sort-dir != 0: Text {
            text: root.sort-dir == 1 ? "▲" : "▼";
            color: Theme.accent;
            font-size: 10px;
            vertical-alignment: center;
        }
    }
    hcell-touch := TouchArea {
        // El asa de resize ocupa los últimos 6px del borde derecho; el resto ordena al hacer clic.
        width: parent.width - 6px;
        pointer-event(ev) => {
            if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.right) {
                root.context-menu(
                    self.absolute-position.x + self.mouse-x,
                    self.absolute-position.y + self.mouse-y);
            }
        }
        clicked => {
            root.clicked();
        }
    }
    // Asa de redimensionado: barra de 6px en el borde derecho. Arrastrar cambia el ancho.
    resize-handle := TouchArea {
        x: parent.width - 6px;
        width: 6px;
        mouse-cursor: ew-resize;
        property <length> start-x;
        property <bool> resizing: false;
        pointer-event(ev) => {
            if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left) {
                self.resizing = true;
                self.start-x = self.mouse-x;
            }
            if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left && self.resizing) {
                self.resizing = false;
                root.resize(self.mouse-x - self.start-x);
            }
            if (ev.kind == PointerEventKind.cancel) {
                self.resizing = false;
            }
        }
    }
}

export component FilePanel inherits FocusScope {
    in property <int> pane-id;
    in property <bool> active;
    in property <[RowData]> rows;
    in property <[ColumnVm]> columns;        // columnas visibles (orden/ancho/alineación) (6C)
    in property <[ColumnToggleVm]> col-menu; // TODAS las columnas para el menú agregar/quitar (6C)
    in property <length> row-h: 22px;        // alto de fila (densidad configurable)
    in property <length> scroll-y;
    // --- Barra de ruta (breadcrumbs + edición + autocompletado) ---
    in property <[PathSeg]> segments;        // breadcrumbs de la carpeta actual
    in property <bool> editing;              // este panel está editando su ruta
    in property <string> edit-text;          // texto del editor (lo controla Rust)
    in property <[string]> suggestions;      // autocompletado del editor
    in property <bool> is-favorite;          // la carpeta actual está en favoritos (★ llena)
    in property <bool> no-matches;           // filtro activo que vació la vista → aviso (F2)
    callback fav-toggle(int);                // (pane-id) anclar/quitar la carpeta de favoritos
    callback copy-path(int);                 // (pane-id) copiar la ruta al portapapeles
    // Tooltip de los íconos de la path-bar: (texto-o-vacío, x-centro en coords de ventana). La
    // AppWindow lo pinta en su overlay (igual que la toolbar). Vacío al salir el mouse.
    callback hover-tip(string, length);
    // --- Rename inline (6D): la fila `rename-pos` muestra un editor en la celda Name. ---
    in property <int> rename-pos: -1;        // posición de vista en edición (-1 = ninguna)
    in property <string> rename-text;        // nombre inicial del editor
    callback rename-commit(int, string);     // (pos, nombre) Enter → renombrar
    callback rename-chain(int, string, int); // (pos, nombre, dir) ↑/↓ → encadenar
    callback rename-cancel();                // Esc → cerrar
    callback segment-clicked(int, string);   // (pane-id, ruta) clic en un breadcrumb → navegar
    callback path-edit-start(int);           // (pane-id) entrar a modo edición
    callback path-edit-changed(int, string); // (pane-id, texto) recalcular autocompletado
    callback path-edit-commit(int, string);  // (pane-id, texto) Enter → navegar
    callback path-edit-cancel(int);          // (pane-id) Esc → salir de edición
    callback suggestion-clicked(int, string);// (pane-id, nombre) elegir un candidato
    callback row-clicked(int, int);          // (pane-id, pos)
    callback row-double-clicked(int, int);
    callback row-drag-out(int);              // (pane-id) inicia el arrastre OLE de lo selecto
    callback rubber-band(int, int, int);     // (pane-id, from-pos, to-pos) selección por rectángulo
    callback row-context(int, int, length, length); // (pane-id, pos, x-ventana, y-ventana)
    callback sort-by(int, string);           // (pane-id, columna) — legado (no usado por el header)
    callback sort-by-kind(int, int);         // (pane-id, kind) ordenar por columna dinámica
    callback column-toggle(int, int);        // (pane-id, kind) mostrar/ocultar columna
    callback column-move(int, int, int);     // (pane-id, from, to) reordenar columnas
    callback column-resize(int, int, length);// (pane-id, kind, ancho) redimensionar
    callback column-context(int, int, length, length); // (pane-id, kind, x, y) clic derecho en header (F2)
    // Menú de columnas abierto (clic en "Columnas…"): muestra los toggles.
    property <bool> col-menu-open: false;
    callback activate(int);                  // (pane-id) al interactuar
    callback key(string, bool, bool, bool);

    key-pressed(event) => {
        root.activate(root.pane-id);
        root.key(event.text, event.modifiers.control, event.modifiers.shift, event.modifiers.alt);
        accept
    }

    // Cuando este panel pasa a ser el activo, tomar el foco de teclado para que las teclas
    // lleguen sin necesidad de un clic previo (p. ej. tras Tab o al arrancar).
    changed active => {
        if (root.active) {
            root.focus();
        }
    }

    // Borde de acento si es el panel activo.
    Rectangle {
        border-width: root.active ? 1.5px : 0px;
        border-color: Theme.accent;
        VerticalLayout {
            // --- Barra de ruta: breadcrumbs (modo normal) o editor con autocompletado. ---
            Rectangle {
                height: 26px;
                background: Theme.row-bg;
                border-radius: 4px;
                // Modo BREADCRUMB: segmentos clicables; clic en el hueco entra a edición.
                if !root.editing: HorizontalLayout {
                    padding-left: 4px;
                    spacing: 0px;
                    for seg[i] in root.segments: Rectangle {
                        width: seg-label.preferred-width + 10px;
                        background: seg-touch.has-hover ? Theme.selection-bg : transparent;
                        border-radius: 3px;
                        seg-label := Text {
                            text: (i == 0 ? "" : "› ") + seg.label;
                            color: Theme.text;
                            vertical-alignment: center;
                            x: 4px;
                        }
                        seg-touch := TouchArea {
                            pointer-event(ev) => {
                                if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left) {
                                    root.activate(root.pane-id);
                                    root.segment-clicked(root.pane-id, seg.path);
                                }
                            }
                        }
                    }
                    // Zona vacía a la derecha: clic = editar la ruta.
                    Rectangle {
                        horizontal-stretch: 1;
                        edit-touch := TouchArea {
                            pointer-event(ev) => {
                                if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left) {
                                    root.activate(root.pane-id);
                                    root.path-edit-start(root.pane-id);
                                }
                            }
                        }
                    }
                    // ★ favorito (toggle): lleno si la carpeta ya está anclada.
                    Rectangle {
                        width: 24px;
                        background: fav-touch.has-hover ? Theme.selection-bg : transparent;
                        border-radius: 3px;
                        Text {
                            text: root.is-favorite ? "★" : "☆";
                            color: root.is-favorite ? Theme.highlight : Theme.text-dim;
                            font-size: 14px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        fav-touch := TouchArea {
                            pointer-event(ev) => {
                                if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left) {
                                    root.fav-toggle(root.pane-id);
                                }
                            }
                            changed has-hover => {
                                root.hover-tip(self.has-hover ? Tr.pathbar-fav-tip : "",
                                    self.absolute-position.x + self.width / 2);
                            }
                        }
                    }
                    // 📋 copiar la ruta de la carpeta al portapapeles. Al copiar, el ícono cambia
                    // a ✓ por ~1s (feedback inmediato en el lugar del clic).
                    Rectangle {
                        width: 26px;
                        background: copy-touch.has-hover ? Theme.selection-bg : transparent;
                        border-radius: 3px;
                        property <bool> flashed: false;
                        Text {
                            text: parent.flashed ? "✓" : "📋";
                            color: parent.flashed ? Theme.highlight : Theme.text;
                            font-size: 13px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        // Apaga el ✓ tras ~1s.
                        flash-timer := Timer {
                            interval: 1s;
                            running: parent.flashed;
                            triggered => { parent.flashed = false; self.running = false; }
                        }
                        copy-touch := TouchArea {
                            pointer-event(ev) => {
                                if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left) {
                                    root.copy-path(root.pane-id);
                                    parent.flashed = true;
                                }
                            }
                            changed has-hover => {
                                root.hover-tip(self.has-hover ? Tr.pathbar-copy-tip : "",
                                    self.absolute-position.x + self.width / 2);
                            }
                        }
                    }
                }
                // Modo EDICIÓN: LineEdit con la ruta; Enter navega, Esc cancela, perder foco
                // (clic afuera) vuelve a los breadcrumbs.
                if root.editing: path-edit := LineEdit {
                    text: root.edit-text;
                    placeholder-text: "C:\\…";
                    // Tomar el foco al abrir el editor (si no, el clic que lo abrió no enfoca el
                    // LineEdit y el "perder foco" nunca tendría foco que perder).
                    init => { self.focus(); }
                    edited(t) => { root.path-edit-changed(root.pane-id, t); }
                    accepted(t) => { root.path-edit-commit(root.pane-id, t); }
                    // Al perder el foco (clic afuera) salir de edición → vuelve a breadcrumbs.
                    changed has-focus => {
                        if (!self.has-focus) {
                            root.path-edit-cancel(root.pane-id);
                        }
                    }
                    key-pressed(ev) => {
                        if (ev.text == Key.Escape) {
                            root.path-edit-cancel(root.pane-id);
                            return accept;
                        }
                        return reject;
                    }
                }
            }
            // Autocompletado: lista flotante de candidatos bajo el editor (solo en edición).
            if root.editing && root.suggestions.length > 0: Rectangle {
                height: min(root.suggestions.length * 22px + 4px, 132px);
                background: Theme.row-bg;
                border-width: 1px;
                border-color: Theme.selection-bg;
                border-radius: 4px;
                ListView {
                    for s[i] in root.suggestions: Rectangle {
                        height: 22px;
                        background: sug-touch.has-hover ? Theme.selection-bg : transparent;
                        Text {
                            text: "📁 " + s;
                            color: Theme.text;
                            vertical-alignment: center;
                            x: 6px;
                        }
                        sug-touch := TouchArea {
                            pointer-event(ev) => {
                                if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left) {
                                    root.suggestion-clicked(root.pane-id, s);
                                }
                            }
                        }
                    }
                }
            }
            // Encabezado dinámico: una HeaderCell por columna visible, con su ancho persistido.
            // Clic = ordenar por esa columna; arrastrar el borde derecho = redimensionar (6C).
            // El botón "≡" al final abre el menú de columnas (agregar/quitar).
            HorizontalLayout {
                height: 22px;
                for col[ci] in root.columns: HeaderCell {
                    width: col.width;
                    text: col.label;
                    align-right: col.align-right;
                    sort-dir: col.sort-dir;
                    has-filter: col.has-filter;
                    clicked => {
                        root.sort-by-kind(root.pane-id, col.kind);
                    }
                    context-menu(x, y) => {
                        root.column-context(root.pane-id, col.kind, x, y);
                    }
                    resize(delta) => {
                        root.column-resize(root.pane-id, col.kind, col.width + delta);
                    }
                }
                // Botón de menú de columnas (al final, ancho fijo).
                Rectangle {
                    width: 24px;
                    background: colbtn-touch.has-hover ? Theme.row-alt-bg : Theme.row-bg;
                    Text { text: "≡"; color: Theme.text-dim; horizontal-alignment: center; vertical-alignment: center; }
                    colbtn-touch := TouchArea {
                        clicked => { root.col-menu-open = !root.col-menu-open; }
                    }
                }
            }
            ListView {
                viewport-y: root.scroll-y;
                for row[i] in root.rows: Rectangle {
                    height: root.row-h;
                    // Fondo: selección > resaltado (recién aparecido) > hover > fila par (cebra
                    // muy sutil) > nada. La cebra da estructura sin líneas duras (estilo egui).
                    background: row.selected
                        ? Theme.selection-bg
                        : (row.highlight
                            ? Theme.highlight.with-alpha(0.22)
                            : (row-touch.has-hover
                                ? Theme.row-alt-bg
                                : (mod(i, 2) == 1 ? Theme.row-alt-bg.with-alpha(0.35) : transparent)));
                    border-width: row.focused ? 1px : 0px;
                    border-color: Theme.accent;
                    border-radius: 3px;
                    HorizontalLayout {
                        padding-left: 6px;
                        // Atenuar las filas cortadas (Ctrl+X) hasta pegar.
                        opacity: row.cut ? 0.45 : 1.0;
                        // Celdas dinámicas: una por columna visible, con su ancho. La columna Name
                        // (kind 0) se pinta como ícono + nombre; las demás como texto de `cells[ci]`.
                        // El ícono cacheado (6A) cuesta como un glifo: no se re-rasteriza por frame.
                        for col[ci] in root.columns: HorizontalLayout {
                            width: col.width;
                            spacing: 6px;
                            if col.kind == 0: Image {
                                source: row.icon;
                                width: 16px;
                                height: 16px;
                                vertical-alignment: center;
                                image-rendering: smooth;
                            }
                            // Editor inline de rename (6D): en la celda Name de la fila en edición.
                            // Enter confirma; ↑/↓ encadenan al anterior/siguiente; Esc cancela.
                            if col.kind == 0 && root.rename-pos == i: rename-edit := LineEdit {
                                text: root.rename-text;
                                horizontal-stretch: 1;
                                font-size: 13px;
                                init => { self.focus(); self.select-all(); }
                                accepted => { root.rename-commit(i, self.text); }
                                key-pressed(ev) => {
                                    if (ev.text == Key.Escape) {
                                        root.rename-cancel();
                                        return accept;
                                    }
                                    if (ev.text == Key.UpArrow) {
                                        root.rename-chain(i, self.text, -1);
                                        return accept;
                                    }
                                    if (ev.text == Key.DownArrow) {
                                        root.rename-chain(i, self.text, 1);
                                        return accept;
                                    }
                                    reject
                                }
                            }
                            if !(col.kind == 0 && root.rename-pos == i): Text {
                                text: row.cells[ci];
                                color: col.kind == 0
                                    ? (row.is-dir ? Theme.highlight : Theme.text)
                                    : Theme.text-dim;
                                vertical-alignment: center;
                                horizontal-alignment: col.align-right ? right : left;
                                horizontal-stretch: 1;
                                overflow: elide;
                            }
                        }
                    }
                    row-touch := TouchArea {
                        // El `clicked` de un TouchArea DENTRO de un ListView no se dispara
                        // bajo el backend winit/software: el Flickable del ListView se traga
                        // el press/release para interpretar scroll. Los eventos pointer-event
                        // SÍ llegan (el hover funciona), así que detectamos el clic a mano:
                        // press y release sobre la misma fila = clic. El doble-clic lo detecta
                        // Rust por tiempo. (Si el puntero se va entre press y release, no es
                        // clic: se cancela.)
                        property <bool> pressed-here: false;
                        // Coords del press (para detectar el inicio de un arrastre por umbral).
                        property <length> press-x;
                        property <length> press-y;
                        // Se disparó ya el arrastre OLE de este gesto (no repetir).
                        property <bool> dragging: false;
                        pointer-event(ev) => {
                            if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left) {
                                self.pressed-here = true;
                                self.dragging = false;
                                self.press-x = self.mouse-x;
                                self.press-y = self.mouse-y;
                            }
                            // Inicio de ARRASTRE OLE: el botón sigue abajo y el puntero se movió
                            // más que el umbral sobre una fila SELECCIONADA → sacar los archivos.
                            // Solo si la fila ya estaba seleccionada (arrastrar lo elegido), para
                            // no pisar el clic-para-seleccionar ni el scroll del ListView.
                            if (ev.kind == PointerEventKind.move && self.pressed-here && !self.dragging && row.selected) {
                                if (abs(self.mouse-x - self.press-x) > 6px || abs(self.mouse-y - self.press-y) > 6px) {
                                    self.dragging = true;
                                    self.pressed-here = false;
                                    root.activate(root.pane-id);
                                    root.row-drag-out(root.pane-id);
                                }
                            }
                            // RUBBER-BAND (6F): arrastrar desde una fila NO seleccionada selecciona
                            // el rango entre la fila de inicio (i) y la de destino (i + Δfilas por
                            // la y arrastrada; filas de 22px). Ctrl = aditivo. No pisa el OLE
                            // (que sale de filas YA seleccionadas) ni el clic simple.
                            if (ev.kind == PointerEventKind.move && self.pressed-here && !row.selected) {
                                if (abs(self.mouse-y - self.press-y) > 6px) {
                                    root.activate(root.pane-id);
                                    root.rubber-band(
                                        root.pane-id, i,
                                        i + round((self.mouse-y - self.press-y) / 22px));
                                }
                            }
                            if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left && self.pressed-here) {
                                self.pressed-here = false;
                                root.activate(root.pane-id);
                                root.row-clicked(root.pane-id, i);
                                // Tomar el foco de teclado: así los atajos (Supr, Ctrl+C…)
                                // llegan al panel tras hacer clic en una fila. (Se hace en el
                                // `up`, ya completado el gesto, para no robar el grab del clic.)
                                root.focus();
                            }
                            // Clic derecho: seleccionar la fila y abrir el menú contextual en
                            // coords de la ventana (absolute-position del TouchArea + puntero).
                            if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.right) {
                                root.activate(root.pane-id);
                                root.row-clicked(root.pane-id, i);
                                root.row-context(
                                    root.pane-id, i,
                                    row-touch.absolute-position.x + row-touch.mouse-x,
                                    row-touch.absolute-position.y + row-touch.mouse-y);
                            }
                            if (ev.kind == PointerEventKind.cancel) {
                                self.pressed-here = false;
                            }
                        }
                        // Doble clic NATIVO de Slint (cronometrado por el SO, robusto ante la
                        // latencia del hilo de UI bajo render por software). Es el camino
                        // primario para abrir; la detección por tiempo en Rust queda de
                        // respaldo. Rust evita la doble navegación (ver on_row_double_clicked).
                        double-clicked => {
                            root.row-double-clicked(root.pane-id, i);
                        }
                    }
                }
            }
        }
        // Menú "Columnas…" (6C): flota arriba-derecha al pulsar el botón ≡ del header. Cada
        // entrada togglea su columna; Name es fija (deshabilitada).
        if root.col-menu-open: Rectangle {
            x: parent.width - self.width - 8px;
            y: 50px;
            width: 180px;
            height: menu-col.preferred-height + 8px;
            background: Theme.panel-bg;
            border-color: Theme.selection-bg;
            border-width: 1px;
            border-radius: 4px;
            menu-col := VerticalLayout {
                padding: 4px;
                spacing: 2px;
                for item in root.col-menu: Rectangle {
                    height: 24px;
                    background: item-touch.has-hover && !item.fixed ? Theme.selection-bg : transparent;
                    border-radius: 3px;
                    HorizontalLayout {
                        padding-left: 6px;
                        spacing: 6px;
                        Text {
                            text: item.visible ? "✓" : "  ";
                            color: Theme.highlight;
                            width: 14px;
                            vertical-alignment: center;
                        }
                        Text {
                            text: item.label;
                            color: item.fixed ? Theme.text-dim : Theme.text;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                    }
                    item-touch := TouchArea {
                        enabled: !item.fixed;
                        clicked => { root.column-toggle(root.pane-id, item.kind); }
                    }
                }
            }
        }
        // Aviso "sin coincidencias" (F2): centrado sobre la lista cuando un filtro la vació.
        if root.no-matches: Rectangle {
            y: parent.height / 2;
            height: 1px;
            Text {
                text: Tr.no-matches;
                color: Theme.text-dim;
                font-size: 13px;
                horizontal-alignment: center;
            }
        }
    }
}
