// Las structs se declaran ANTES de quien las usa (PaneVm las referencia todas).
export struct RowData {
    name: string,
    ext: string,
    size: string,
    modified: string,
    is-dir: bool,
    selected: bool,
    focused: bool,
    cut: bool,
    // Apareció recién (watcher): se pinta resaltado unos segundos. Fase 5A.
    highlight: bool,
    // Ícono de color por tipo, ya decodificado y cacheado en Rust (6A).
    icon: image,
}

// Fila de navegación (favorito o reciente): etiqueta visible + ruta completa.
export struct NavRow {
    label: string,
    path: string,
}

// Un segmento de la barra de ruta (breadcrumb): etiqueta visible + ruta acumulada a la que
// navegar si se clickea. Ej: ("Empresas", "D:\Empresas").
export struct PathSeg {
    label: string,
    path: string,
}

// --- Operaciones de archivo (Fase 3) ---

// Estado del modal de operaciones activo. `kind`: 0=ninguno 1=confirmar-borrado
// 2=conflicto 3=pedir-nombre 4=pegar-preview 5=retomar.
export struct OpDialogVm {
    kind: int,
    // Confirmar borrado:
    del-count: int,
    del-permanent: bool,
    // Conflicto (por-ítem):
    conflict-name: string,
    // Pedir nombre (nuevo/renombrar):
    name-title: string,
    name-value: string,
    name-valid: bool,
    // Pegar preview (texto/imagen):
    paste-name: string,
    paste-is-image: bool,
}

// Estado del menú contextual (clic derecho). Posición en coords de la ventana.
export struct ContextMenuVm {
    active: bool,
    x: length,
    y: length,
    has-native: bool,
}

// Fila del modal "retomar tras cierre inesperado": id del journal + etiqueta.
export struct ResumeRowVm {
    id: string,
    label: string,
}

// Fila del panel de progreso: una operación en curso/terminada.
export struct OpRowVm {
    index: int,
    label: string,
    percent: float,    // 0..100
    status: string,    // "en cola" / "copiando…" / "hecho: N" / "cancelada"
    running: bool,
}

// Fila del historial de deshacer.
export struct HistRow {
    id: int,
    label: string,
    when: string,
    count: int,
    undoable: bool,
    reason: string,
}

// Fila del árbol aplanado: sangría por `depth`, estado de carga/expansión, disco (-1 = n/a).
export struct TreeRow {
    depth: int,
    name: string,
    path: string,
    expanded: bool,
    has-children: bool,
    is-drive: bool,
    active: bool,
    loading: bool,
    error: bool,
    disk-percent: int,
}

// Datos del inspector (propiedades del ítem enfocado del panel activo).
export struct InspectorVm {
    present: bool,
    name: string,
    kind: string,
    path: string,
    size: string,
    modified: string,
    created: string,
}

// Vista de preview: modo 0=vacío 1=texto 2=imagen 3=mensaje.
export struct PreviewVm {
    mode: int,
    text: string,
    truncated: bool,
    image: image,
    message: string,
}

// Una pestaña dentro de la barra de un grupo: su PaneId, etiqueta y si es la activa.
export struct TabVm {
    id: int,
    label: string,
    active: bool,
}

// Un candidato del selector de panel destino (overlay 1..9): su rect + el número a pintar.
export struct PickVm {
    x: length,
    y: length,
    w: length,
    h: length,
    number: int,
}

// Ajustes editables en la ventana de configuración (espejo de los campos de core::Settings
// que tocamos en la UI Slint). Las listas son los idiomas/temas disponibles para los combos.
export struct SettingsVm {
    bar-position: int,        // 0=arriba 1=costado
    icon-only: bool,
    show-parent: bool,
    ops-mode: int,            // 0=cola 1=paralelo
    confirm-trash: bool,
    show-op-summary: bool,
    size-no-subdirs: bool,
    autostart: bool,
    paste-confirm: bool,
    paste-text-name: string,
    paste-text-ext: string,
    date-format: int,         // 0=ISO min, 1=ISO fecha, 2=DMY min, 3=DMY fecha
    language: string,         // código del idioma activo
    theme: string,            // id del tema activo
    languages: [string],      // códigos disponibles
    themes: [string],         // ids disponibles
}

// Una fila del editor de atajos: la clave estable de la acción, su nombre legible y el chord
// actual como texto. `conflict` se setea tras una reasignación que pisó otra acción.
export struct ShortcutRowVm {
    action-key: string,
    label: string,
    chord-text: string,
    conflict: string,         // vacío = sin conflicto; si no, mensaje a mostrar
}

// Una barra de splitter colocada: su rect (px) + si el corte es horizontal (arrastra en x).
export struct SplitVm {
    index: int,
    x: length,
    y: length,
    w: length,
    h: length,
    horizontal: bool,
}

// Un panel colocado. El tipo (espejo de PanePurpose de core) elige qué datos usar:
// 0=Files 1=Tree 2=Inspector 3=History 4=Favorites 5=Preview.
export struct PaneVm {
    id: int,
    x: length,
    y: length,
    w: length,
    h: length,
    path: string,
    active: bool,
    purpose: int,
    title: string,            // título visible en la barra del panel (nombre de carpeta/tipo)
    // Datos según el `purpose` (cada panel usa solo el suyo; los demás van vacíos):
    rows: [RowData],          // Files
    segments: [PathSeg],      // Files: breadcrumbs de la barra de ruta
    tree-rows: [TreeRow],     // Tree
    favs: [NavRow],           // Favorites (sección favoritos)
    recents: [NavRow],        // Favorites (sección recientes)
    hist-rows: [HistRow],     // History
    inspector: InspectorVm,   // Inspector
    preview: PreviewVm,       // Preview
    // Si este panel es la pestaña ACTIVA de un grupo, `tabs` lista las pestañas del grupo
    // (vacío si el panel no está agrupado). La UI pinta la barra arriba del contenido.
    tabs: [TabVm],
}
