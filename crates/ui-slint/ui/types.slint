// Las structs se declaran ANTES de quien las usa (PaneVm las referencia todas).
export struct RowData {
    name: string,
    // Celdas de las columnas visibles distintas de Name, en orden visual (6C).
    cells: [string],
    is-dir: bool,
    selected: bool,
    focused: bool,
    cut: bool,
    // Apareció recién (watcher): se pinta resaltado unos segundos. Fase 5A.
    highlight: bool,
    // Ícono de color por tipo, ya decodificado y cacheado en Rust (6A).
    icon: image,
    // Profundidad en la vista profunda (recursiva): 0 = nivel raíz, >0 sangra la fila.
    // En vista normal/búsqueda es 0 (sin efecto).
    depth: int,
}

// Una columna visible de la tabla (6C): qué es, su etiqueta, ancho y alineación.
export struct ColumnVm {
    kind: int,             // 0=Name 1=Extension 2=Size 3=Modified 4=Created
    label: string,
    width: length,
    align-right: bool,     // Size se alinea a la derecha
    sort-dir: int,         // orden en esta columna: 0=ninguno 1=asc (▲) 2=desc (▼) (F2)
    has-filter: bool,      // hay un filtro activo en esta columna → embudo (F2)
}

// Una entrada del menú "Columnas…" (6C): TODAS las columnas con su estado de visibilidad.
export struct ColumnToggleVm {
    kind: int,
    label: string,
    visible: bool,
    fixed: bool,           // Name no se puede ocultar (toggle deshabilitado)
}

// Una extensión marcable en el editor de filtro de tipos (F2): la extensión ("" = sin
// extensión, se muestra como "(sin extensión)"), su conteo en la carpeta, y si está marcada.
export struct ExtRowVm {
    ext: string,
    label: string,
    count: int,
    checked: bool,
}

// Estado del menú/editor de columna (clic derecho en el header, F2). `mode`: 0=menú de acciones,
// 1=editor de filtro. El `kind` elige qué editor de filtro mostrar. Los campos de borrador son
// el espejo de ColumnMenuState del controlador.
export struct ColumnMenuVm {
    active: bool,
    x: length,
    y: length,
    kind: int,             // 0=Name 1=Extension 2=Size 3=Modified 4=Created
    label: string,         // etiqueta de la columna (para el título del editor)
    mode: int,             // 0=menú 1=filtro
    has-filter: bool,      // la columna ya tiene un filtro (habilita "quitar filtro")
    can-hide: bool,        // Name no se puede ocultar
    // Borradores del editor de filtro:
    text-draft: string,    // filtro de texto (Name)
    text-case: bool,       // sensible a mayúsculas
    min-draft: string,     // extremo mínimo (Size/fecha)
    max-draft: string,     // extremo máximo (Size/fecha)
    exts: [ExtRowVm],      // extensiones marcables (Extension)
}

// Una plantilla de disposición en el menú de Layouts (F4): nombre + si es built-in (no borrable).
export struct LayoutRow {
    name: string,
    builtin: bool,
}

// Una fila del preview de batch-rename (F5): nombre antes→después + estado.
// status: 0=Ok 1=SinCambio 2=Inválido 3=Colisión.
export struct BatchRowVm {
    old-name: string,
    new-name: string,
    status: int,
}

// Estado de la ventana de batch-rename (F5). Los campos del spec son el espejo de BatchSpec;
// `rows` es el preview en vivo; `can-apply` habilita el botón Aplicar.
export struct BatchRenameVm {
    active: bool,
    template: string,
    find: string,
    replace: string,
    use-regex: bool,
    include-ext: bool,
    case: int,              // 0=ninguna 1=minúsculas 2=MAYÚSCULAS 3=Título
    counter-start: string,
    counter-step: string,
    rows: [BatchRowVm],
    count: int,             // nº de ítems del lote
    can-apply: bool,
}

// Una fila de la tabla de atajos en la ayuda (F1): acción legible + su combinación.
export struct HelpRowVm {
    label: string,
    chord: string,
}

// Fila de navegación (favorito, reciente o unidad de disco): etiqueta visible +
// ruta completa. `removable` solo es relevante para la tira de unidades: marca las
// unidades extraíbles (USB) para mostrar el botón/menú de expulsión segura.
export struct NavRow {
    label: string,
    path: string,
    icon: image,           // ícono de carpeta/disco cacheado (6B)
    removable: bool,       // true para unidades extraíbles (USB) en la tira de discos
}

// Fila del árbol de favoritos (panel editable + menú ▾ del toolbar). `is-group` distingue
// grupo de favorito; `depth` da la sangría; `group-id` es el GroupId serializado ("0/2") del
// grupo (vacío en favoritos); `name-path` la ruta de nombres (clave estable de expansión);
// `expanded`/`has-children` solo aplican a grupos (chevron ▸/▾). `path` es la ruta del favorito.
export struct FavTreeRow {
    depth: int,
    is-group: bool,
    name: string,
    path: string,
    group-id: string,
    name-path: string,
    expanded: bool,
    has-children: bool,
    icon: image,
}

// Un segmento de la barra de ruta (breadcrumb): etiqueta visible + ruta acumulada a la que
// navegar si se clickea. Ej: ("Empresas", "D:\Empresas").
export struct PathSeg {
    label: string,
    path: string,
}

// --- Operaciones de archivo (Fase 3) ---

// Estado del modal de operaciones activo. `kind`: 0=ninguno 1=confirmar-borrado
// 2=conflicto 3=pedir-nombre 4=pegar-preview 5=retomar.
export struct OpDialogVm {
    kind: int,
    // Confirmar borrado:
    del-count: int,
    del-permanent: bool,
    // Conflicto (por-ítem):
    conflict-name: string,
    // Pedir nombre (nuevo/renombrar):
    name-title: string,
    name-value: string,
    name-valid: bool,
    // Pegar preview (texto/imagen):
    paste-name: string,
    paste-is-image: bool,
    // Conflicto de carpeta (P3):
    folder-name: string,
    folder-more: bool,
}

// Estado del modal de mensajes simple (avisos/confirmaciones temáticos, reemplazo de
// los diálogos nativos rfd). `kind`: 0=oculto 1=confirmación(2 botones) 2=aviso(1 botón).
// `level`: 0=info 1=warning 2=error (tiñe la franja del título).
export struct MessageVm {
    kind: int,
    level: int,
    title: string,
    body: string,
    confirm-label: string,
    cancel-label: string,
    danger: bool,
}

// Estado del menú contextual (clic derecho). Posición en coords de la ventana.
export struct ContextMenuVm {
    active: bool,
    x: length,
    y: length,
    has-native: bool,
    has-wt: bool,       // Windows Terminal (wt.exe) disponible → ofrecer "Abrir Windows Terminal aquí"
    // Modo CARPETA: clic derecho en la zona vacía del panel. Oculta las acciones de archivo
    // (copiar/cortar/renombrar/eliminar/copiar-nombre/ruta) y muestra "Abrir en Explorador" +
    // "Nueva carpeta". Pegar y terminales siguen, que aplican a la carpeta.
    folder-mode: bool,
}

// Fila del modal "retomar tras cierre inesperado": id del journal + etiqueta.
export struct ResumeRowVm {
    id: string,
    label: string,
}

// Una tarjeta de tema en la galería de selección (config → Apariencia). Trae el id estable,
// el nombre legible, si es el activo, y cuatro muestras de color representativas.
export struct ThemeCardVm {
    id: string,
    name: string,
    active: bool,
    // ¿Es un tema de fábrica? Decide los botones de la tarjeta: builtin → "Personalizar" (duplica);
    // de usuario → "Editar" + "Eliminar".
    is-builtin: bool,
    sw-panel: color,
    sw-accent: color,
    sw-row: color,
    sw-text: color,
    sw-highlight: color,
}

// Estado del modal "carpeta no encontrada" (USB desconectado / red caída / carpeta borrada).
export struct MissingFolderVm {
    active: bool,
    lost-path: string,   // la ruta que dejó de existir
}

// Una coincidencia del panel de búsqueda recursiva: nombre del archivo/carpeta, su carpeta
// contenedora relativa a la raíz de búsqueda (dónde está), tamaño/fecha ya formateados, si es
// carpeta, y el ícono cacheado. La acción "abrir" se hace por índice, no por ruta.
export struct SearchHitVm {
    name: string,
    rel-dir: string,     // carpeta contenedora relativa a la raíz ("" = en la raíz)
    detail: string,      // tamaño + fecha ya formateados (columna secundaria)
    is-dir: bool,
    icon: image,
}

// Estado del panel de búsqueda recursiva (Ctrl+F / lupa). `active` lo muestra; `query` es el
// texto buscado; `root-label` la carpeta raíz (para el encabezado); `hits` las coincidencias en
// vivo; `status` el resumen ("Buscando…", "N resultados", "parcial", "tope alcanzado").
export struct SearchVm {
    active: bool,
    query: string,
    root-label: string,
    running: bool,       // worker aún en vuelo (muestra el spinner/Detener)
    hits: [SearchHitVm],
    status: string,
}

// Estado del modal "nueva(s) carpeta(s)".
export struct NewFolderVm {
    active: bool,
    dir: string,        // carpeta destino (encabezado)
    text: string,       // texto multilínea en edición (una carpeta por línea)
    status: string,     // resumen: cuántas se crearán / cuántas inválidas
    can-create: bool,   // hay al menos una línea válida
}

// Fila del panel de progreso: una operación en curso/en cola/terminada (historial).
export struct OpRowVm {
    index: int,
    label: string,
    percent: float,        // 0..100
    status: string,        // "en cola" / "en curso…" / "pausada" / "hecho: N…" / "cancelada"
    running: bool,
    paused: bool,          // la op está pausada (token.is-paused)
    bytes-done: string,    // ya formateado, p. ej. "12,4 GB"
    bytes-total: string,   // ya formateado, p. ej. "94,9 GB"
    files-done: int,
    files-total: int,
    current-file: string,  // nombre del archivo en curso
    speed: string,         // velocidad media, p. ej. "123 MB/s"
    speed-peak: string,    // velocidad pico, p. ej. "126 MB/s"
    eta: string,           // tiempo restante estimado, p. ej. "11:08" o ""
    elapsed: string,       // transcurrido, p. ej. "01:48"
    kind: int,             // 0=en curso 1=en cola 2=historial
}

// Fila del historial de deshacer.
export struct HistRow {
    id: int,
    label: string,
    when: string,
    count: int,
    undoable: bool,
    reason: string,
}

// Fila del árbol aplanado: sangría por `depth`, estado de carga/expansión, disco (-1 = n/a).
export struct TreeRow {
    depth: int,
    name: string,
    path: string,
    expanded: bool,
    has-children: bool,
    is-drive: bool,
    active: bool,
    loading: bool,
    error: bool,
    disk-percent: int,
    // Texto de espacio del disco ("120 GB libre / 500 GB · 76%"); vacío si no es disco / sin dato.
    disk-detail: string,
    // Ícono de color cacheado (carpeta o disco) (6A).
    icon: image,
}

// Datos del inspector (propiedades del ítem enfocado del panel activo).
export struct InspectorVm {
    present: bool,
    name: string,
    kind: string,
    path: string,
    size: string,
    modified: string,
    created: string,
}

// Un segmento coloreado de una línea de código resaltado (un Text por segmento en la UI).
export struct HlSpanVm {
    text: string,
    color: color,
}

// Una línea de código resaltado = sus segmentos en orden de izquierda a derecha.
export struct HlLineVm {
    spans: [HlSpanVm],
}

// Vista de preview: modo 0=vacío 1=texto 2=imagen 3=mensaje.
export struct PreviewVm {
    mode: int,
    text: string,
    truncated: bool,
    image: image,
    message: string,
    // Resaltado de código: si `highlighted`, se pintan `hl-lines` (un Text por segmento) en vez
    // del `text` plano. `path` es la ruta del archivo en preview ("" = ninguno) para "abrir con el
    // programa del sistema".
    highlighted: bool,
    hl-lines: [HlLineVm],
    path: string,
}

// Una pestaña dentro de la barra de un grupo: su PaneId, etiqueta y si es la activa.
export struct TabVm {
    id: int,
    label: string,
    active: bool,
}

// Un candidato del selector de panel destino (overlay 1..9): su rect + el número a pintar.
export struct PickVm {
    x: length,
    y: length,
    w: length,
    h: length,
    number: int,
}

// Ajustes editables en la ventana de configuración (espejo de los campos de core::Settings
// que tocamos en la UI Slint). Las listas son los idiomas/temas disponibles para los combos.
export struct SettingsVm {
    bar-position: int,        // 0=arriba 1=costado
    icon-only: bool,
    show-parent: bool,
    ops-mode: int,            // 0=cola 1=paralelo
    confirm-trash: bool,
    show-op-summary: bool,
    size-no-subdirs: bool,
    autostart: bool,
    paste-confirm: bool,
    paste-text-name: string,
    paste-text-ext: string,
    date-format: int,         // 0=ISO min, 1=ISO fecha, 2=DMY min, 3=DMY fecha
    size-format: int,         // 0=Auto, 1=Bytes, 2=KB, 3=MB
    row-density: int,         // 0=compacta, 1=cómoda
    // Avanzado (F3c):
    ops-display: int,         // 0=panel 1=modal 2=siempre visible
    paste-image-fmt: int,     // 0=PNG 1=JPG
    tray-enabled: bool,
    close-to-tray: bool,
    new-items-at-end: bool,
    low-power-mode: int,      // 0=auto 1=siempre 2=nunca
    default-table-on: bool,   // hay plantilla de tabla por defecto guardada (C4)
    row-h: length,            // alto de fila resuelto (22/26px) — lo usan tabla y árbol
    language: string,         // código del idioma activo
    theme: string,            // id del tema activo
    icon-set: string,         // id del set de íconos activo
    languages: [string],      // códigos disponibles
    themes: [string],         // ids disponibles
    icon-sets: [string],      // ids de sets de íconos disponibles (embebidos + packs)
}

// Una regla de previsualización editable (C3): extensión, si se previsualiza, y el modo de vista
// forzado. `view-index`: 0=Auto 1=Texto 2=Imagen 3=Código. `lang-index`: posición en CodeLang::all()
// (solo relevante cuando view-index==3).
export struct PreviewRuleVm {
    ext: string,
    enabled: bool,
    view-index: int,
    lang-index: int,
}

// Una fila del editor de atajos: la clave estable de la acción, su nombre legible y el chord
// actual como texto. `conflict` se setea tras una reasignación que pisó otra acción.
export struct ShortcutRowVm {
    action-key: string,
    label: string,
    chord-text: string,
    conflict: string,         // vacío = sin conflicto; si no, mensaje a mostrar
}

// Una barra de splitter colocada: su rect (px) + si el corte es horizontal (arrastra en x).
export struct SplitVm {
    index: int,
    x: length,
    y: length,
    w: length,
    h: length,
    horizontal: bool,
}

// Un panel colocado. El tipo (espejo de PanePurpose de core) elige qué datos usar:
// 0=Files 1=Tree 2=Inspector 3=History 4=Favorites 5=Preview.
export struct PaneVm {
    id: int,
    x: length,
    y: length,
    w: length,
    h: length,
    path: string,
    active: bool,
    purpose: int,
    title: string,            // título visible en la barra del panel (nombre de carpeta/tipo)
    // Datos según el `purpose` (cada panel usa solo el suyo; los demás van vacíos):
    rows: [RowData],          // Files
    // Índice de VISTA de la fila enfocada (-1 = ninguna). Lo pasa Rust desde `f.focused`; el
    // FilePanel observa su cambio (`changed focused-row`) para que el scroll siga al cursor al
    // navegar por teclado (la ListView ya no es interactiva, así que no auto-scrollea sola).
    focused-row: int,
    columns: [ColumnVm],      // Files: columnas visibles (orden/ancho/alineación)
    col-menu: [ColumnToggleVm],// Files: TODAS las columnas para el menú "Columnas…"
    is-favorite: bool,        // Files: la carpeta actual está en favoritos (★ de la path-bar)
    no-matches: bool,         // Files: hay filtro activo pero la vista quedó vacía (F2)
    // Files: la carpeta del panel NO existe / es ilegible (USB sacado, red caída, ruta muerta).
    // Muestra el aviso "carpeta no encontrada" IN-PLACE con sus opciones. `missing-path` es la
    // ruta perdida (para mostrarla).
    missing: bool,
    missing-path: string,
    // ¿Hay un ancestro existente real al que subir? Si la unidad entera se desconectó es false y
    // el aviso oculta el botón "subir un nivel" (no tendría sentido: caería al HOME).
    missing-has-ancestor: bool,
    deep-active: bool,        // Files: la vista profunda (recursiva) está activa en este panel
    footer-text: string,      // Files: texto de la barra inferior (selección/disco), vacío si está deshabilitado
    segments: [PathSeg],      // Files: breadcrumbs de la barra de ruta
    tree-rows: [TreeRow],     // Tree
    favs: [NavRow],           // Favorites (sección favoritos — sin usar; reemplazado por fav-tree)
    recents: [NavRow],        // Favorites (sección recientes)
    fav-tree: [FavTreeRow],   // Favorites (árbol editable de favoritos con grupos)
    hist-rows: [HistRow],     // History
    inspector: InspectorVm,   // Inspector
    preview: PreviewVm,       // Preview
    // Si este panel es la pestaña ACTIVA de un grupo, `tabs` lista las pestañas del grupo
    // (vacío si el panel no está agrupado). La UI pinta la barra arriba del contenido.
    tabs: [TabVm],
}

// Una subsección de "Novedades" del Acerca de: una categoría y sus viñetas.
export struct NewsSection {
    category: string,
    items: [string],
}

// Un segmento del label de un resultado de la paleta: texto + si está resaltado (match).
export struct PaletteSpanVm {
    text: string,
    hit: bool,
}

// Un resultado de la paleta de comandos (Ctrl+P).
export struct PaletteItemVm {
    spans: [PaletteSpanVm],   // el label partido en segmentos resaltados/normales
    category: int,            // 0=Acción 1=Archivo 2=Reciente 3=Favorito 4=Tema 5=Config
    shortcut: string,         // "Ctrl+C" o ""
}

// Una entrada del menú de historial (▾) de Atrás/Adelante.
export struct HistoryItemVm {
    name: string,             // nombre de la carpeta
    path: string,             // ruta completa (atenuada)
}
