// Las structs se declaran ANTES de quien las usa (PaneVm las referencia todas).
export struct RowData {
    name: string,
    // Celdas de las columnas visibles distintas de Name, en orden visual (6C).
    cells: [string],
    is-dir: bool,
    selected: bool,
    focused: bool,
    cut: bool,
    // Apareció recién (watcher): se pinta resaltado unos segundos. Fase 5A.
    highlight: bool,
    // Ícono de color por tipo, ya decodificado y cacheado en Rust (6A).
    icon: image,
}

// Una columna visible de la tabla (6C): qué es, su etiqueta, ancho y alineación.
export struct ColumnVm {
    kind: int,             // 0=Name 1=Extension 2=Size 3=Modified 4=Created
    label: string,
    width: length,
    align-right: bool,     // Size se alinea a la derecha
    sort-dir: int,         // orden en esta columna: 0=ninguno 1=asc (▲) 2=desc (▼) (F2)
    has-filter: bool,      // hay un filtro activo en esta columna → embudo (F2)
}

// Una entrada del menú "Columnas…" (6C): TODAS las columnas con su estado de visibilidad.
export struct ColumnToggleVm {
    kind: int,
    label: string,
    visible: bool,
    fixed: bool,           // Name no se puede ocultar (toggle deshabilitado)
}

// Una extensión marcable en el editor de filtro de tipos (F2): la extensión ("" = sin
// extensión, se muestra como "(sin extensión)"), su conteo en la carpeta, y si está marcada.
export struct ExtRowVm {
    ext: string,
    label: string,
    count: int,
    checked: bool,
}

// Estado del menú/editor de columna (clic derecho en el header, F2). `mode`: 0=menú de acciones,
// 1=editor de filtro. El `kind` elige qué editor de filtro mostrar. Los campos de borrador son
// el espejo de ColumnMenuState del controlador.
export struct ColumnMenuVm {
    active: bool,
    x: length,
    y: length,
    kind: int,             // 0=Name 1=Extension 2=Size 3=Modified 4=Created
    label: string,         // etiqueta de la columna (para el título del editor)
    mode: int,             // 0=menú 1=filtro
    has-filter: bool,      // la columna ya tiene un filtro (habilita "quitar filtro")
    can-hide: bool,        // Name no se puede ocultar
    // Borradores del editor de filtro:
    text-draft: string,    // filtro de texto (Name)
    text-case: bool,       // sensible a mayúsculas
    min-draft: string,     // extremo mínimo (Size/fecha)
    max-draft: string,     // extremo máximo (Size/fecha)
    exts: [ExtRowVm],      // extensiones marcables (Extension)
}

// Fila de navegación (favorito o reciente): etiqueta visible + ruta completa.
export struct NavRow {
    label: string,
    path: string,
    icon: image,           // ícono de carpeta cacheado (6B)
}

// Un segmento de la barra de ruta (breadcrumb): etiqueta visible + ruta acumulada a la que
// navegar si se clickea. Ej: ("Empresas", "D:\Empresas").
export struct PathSeg {
    label: string,
    path: string,
}

// --- Operaciones de archivo (Fase 3) ---

// Estado del modal de operaciones activo. `kind`: 0=ninguno 1=confirmar-borrado
// 2=conflicto 3=pedir-nombre 4=pegar-preview 5=retomar.
export struct OpDialogVm {
    kind: int,
    // Confirmar borrado:
    del-count: int,
    del-permanent: bool,
    // Conflicto (por-ítem):
    conflict-name: string,
    // Pedir nombre (nuevo/renombrar):
    name-title: string,
    name-value: string,
    name-valid: bool,
    // Pegar preview (texto/imagen):
    paste-name: string,
    paste-is-image: bool,
}

// Estado del menú contextual (clic derecho). Posición en coords de la ventana.
export struct ContextMenuVm {
    active: bool,
    x: length,
    y: length,
    has-native: bool,
    has-wt: bool,       // Windows Terminal (wt.exe) disponible → ofrecer "Abrir Windows Terminal aquí"
}

// Fila del modal "retomar tras cierre inesperado": id del journal + etiqueta.
export struct ResumeRowVm {
    id: string,
    label: string,
}

// Fila del panel de progreso: una operación en curso/terminada.
export struct OpRowVm {
    index: int,
    label: string,
    percent: float,    // 0..100
    status: string,    // "en cola" / "copiando…" / "hecho: N" / "cancelada"
    running: bool,
}

// Fila del historial de deshacer.
export struct HistRow {
    id: int,
    label: string,
    when: string,
    count: int,
    undoable: bool,
    reason: string,
}

// Fila del árbol aplanado: sangría por `depth`, estado de carga/expansión, disco (-1 = n/a).
export struct TreeRow {
    depth: int,
    name: string,
    path: string,
    expanded: bool,
    has-children: bool,
    is-drive: bool,
    active: bool,
    loading: bool,
    error: bool,
    disk-percent: int,
    // Ícono de color cacheado (carpeta o disco) (6A).
    icon: image,
}

// Datos del inspector (propiedades del ítem enfocado del panel activo).
export struct InspectorVm {
    present: bool,
    name: string,
    kind: string,
    path: string,
    size: string,
    modified: string,
    created: string,
}

// Vista de preview: modo 0=vacío 1=texto 2=imagen 3=mensaje.
export struct PreviewVm {
    mode: int,
    text: string,
    truncated: bool,
    image: image,
    message: string,
}

// Una pestaña dentro de la barra de un grupo: su PaneId, etiqueta y si es la activa.
export struct TabVm {
    id: int,
    label: string,
    active: bool,
}

// Un candidato del selector de panel destino (overlay 1..9): su rect + el número a pintar.
export struct PickVm {
    x: length,
    y: length,
    w: length,
    h: length,
    number: int,
}

// Ajustes editables en la ventana de configuración (espejo de los campos de core::Settings
// que tocamos en la UI Slint). Las listas son los idiomas/temas disponibles para los combos.
export struct SettingsVm {
    bar-position: int,        // 0=arriba 1=costado
    icon-only: bool,
    show-parent: bool,
    ops-mode: int,            // 0=cola 1=paralelo
    confirm-trash: bool,
    show-op-summary: bool,
    size-no-subdirs: bool,
    autostart: bool,
    paste-confirm: bool,
    paste-text-name: string,
    paste-text-ext: string,
    date-format: int,         // 0=ISO min, 1=ISO fecha, 2=DMY min, 3=DMY fecha
    size-format: int,         // 0=Auto, 1=Bytes, 2=KB, 3=MB
    row-density: int,         // 0=compacta, 1=cómoda
    // Avanzado (F3c):
    ops-display: int,         // 0=panel 1=modal 2=siempre visible
    paste-image-fmt: int,     // 0=PNG 1=JPG
    tray-enabled: bool,
    close-to-tray: bool,
    new-items-at-end: bool,
    low-power-mode: int,      // 0=auto 1=siempre 2=nunca
    row-h: length,            // alto de fila resuelto (22/26px) — lo usan tabla y árbol
    language: string,         // código del idioma activo
    theme: string,            // id del tema activo
    icon-set: string,         // id del set de íconos activo
    languages: [string],      // códigos disponibles
    themes: [string],         // ids disponibles
    icon-sets: [string],      // ids de sets de íconos disponibles (embebidos + packs)
}

// Una fila del editor de atajos: la clave estable de la acción, su nombre legible y el chord
// actual como texto. `conflict` se setea tras una reasignación que pisó otra acción.
export struct ShortcutRowVm {
    action-key: string,
    label: string,
    chord-text: string,
    conflict: string,         // vacío = sin conflicto; si no, mensaje a mostrar
}

// Una barra de splitter colocada: su rect (px) + si el corte es horizontal (arrastra en x).
export struct SplitVm {
    index: int,
    x: length,
    y: length,
    w: length,
    h: length,
    horizontal: bool,
}

// Un panel colocado. El tipo (espejo de PanePurpose de core) elige qué datos usar:
// 0=Files 1=Tree 2=Inspector 3=History 4=Favorites 5=Preview.
export struct PaneVm {
    id: int,
    x: length,
    y: length,
    w: length,
    h: length,
    path: string,
    active: bool,
    purpose: int,
    title: string,            // título visible en la barra del panel (nombre de carpeta/tipo)
    // Datos según el `purpose` (cada panel usa solo el suyo; los demás van vacíos):
    rows: [RowData],          // Files
    columns: [ColumnVm],      // Files: columnas visibles (orden/ancho/alineación)
    col-menu: [ColumnToggleVm],// Files: TODAS las columnas para el menú "Columnas…"
    is-favorite: bool,        // Files: la carpeta actual está en favoritos (★ de la path-bar)
    no-matches: bool,         // Files: hay filtro activo pero la vista quedó vacía (F2)
    segments: [PathSeg],      // Files: breadcrumbs de la barra de ruta
    tree-rows: [TreeRow],     // Tree
    favs: [NavRow],           // Favorites (sección favoritos)
    recents: [NavRow],        // Favorites (sección recientes)
    hist-rows: [HistRow],     // History
    inspector: InspectorVm,   // Inspector
    preview: PreviewVm,       // Preview
    // Si este panel es la pestaña ACTIVA de un grupo, `tabs` lista las pestañas del grupo
    // (vacío si el panel no está agrupado). La UI pinta la barra arriba del contenido.
    tabs: [TabVm],
}
