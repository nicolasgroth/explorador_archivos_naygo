//
// En 2b la lista llega vacía (aún no hay operaciones de archivo: son F3). La UI queda
// lista: cada entrada muestra su etiqueta y un botón "Deshacer" habilitado solo si la
// operación AÚN aplica (validado en Rust); si no, el motivo va de tooltip.
import { ListView } from "std-widgets.slint";
import { HistRow } from "types.slint";
import { Tr } from "i18n.slint";
import { Theme } from "theme.slint";

export component HistoryPanel inherits Rectangle {
    in property <bool> active;
    in property <[HistRow]> rows;
    callback undo(int);   // id de la entrada a deshacer
    callback focus-pane();

    background: Theme.panel-bg;
    border-width: root.active ? 1.5px : 0px;
    border-color: Theme.accent;

    VerticalLayout {
        padding: 6px;
        spacing: 4px;
        // (Sin título interno: la pestaña del panel ya rotula "Historial".)
        if root.rows.length == 0: Text {
            text: Tr.history-empty;
            color: Theme.text-dim;
            height: 18px;
        }
        ListView {
            vertical-stretch: 1;
            for e[i] in root.rows: Rectangle {
                height: 30px;
                background: row-touch.has-hover ? Theme.row-bg : transparent;
                border-radius: 3px;
                HorizontalLayout {
                    padding-left: 6px;
                    padding-right: 4px;
                    spacing: 6px;
                    VerticalLayout {
                        horizontal-stretch: 1;
                        Text {
                            text: e.label;
                            color: Theme.text;
                            overflow: elide;
                            vertical-alignment: center;
                        }
                    }
                    // Tres estados visibles en el mismo espacio:
                    //  - deshacible → botón activo "Deshacer" (acento al pasar el mouse).
                    //  - ya deshecho → etiqueta "Deshecho ✓" en color de acento (confirma que se
                    //    aplicó; NO es un botón). Distingue de "no deshacible".
                    //  - no deshacible (Delete, o el inverso ya no aplica) → botón inerte y atenuado
                    //    con el motivo de tooltip.
                    Rectangle {
                        width: 86px;
                        background: e.undone
                            ? transparent
                            : (e.undoable ? (undo-touch.has-hover ? Theme.selection-bg : Theme.row-bg) : Theme.panel-bg);
                        border-radius: 4px;
                        border-width: e.undone ? 1px : 0px;
                        border-color: Theme.accent;
                        Text {
                            text: e.undone ? Tr.history-undone : Tr.history-undo;
                            color: e.undone ? Theme.accent : (e.undoable ? white : Theme.text-dim);
                            font-weight: e.undone ? 700 : 400;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        undo-touch := TouchArea {
                            enabled: e.undoable;
                            clicked => { root.focus-pane(); root.undo(e.id); }
                        }
                    }
                }
                row-touch := TouchArea { }
            }
        }
    }
}
