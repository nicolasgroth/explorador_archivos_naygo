// Naygo — diálogos modales de operaciones de archivo (Fase 3).
// Copyright (c) 2026 Nicolás Groth / ISGroth. MIT License.
//
// Un único componente `OpDialogs` que pinta el modal ACTIVO según `vm.kind`
// (0=ninguno). Overlay con velo (clic fuera cancela). Las decisiones salen por callbacks
// al controlador. Sin glifos Unicode raros (el render por software no los dibuja): solo
// texto. Los modales: confirmar borrado, conflicto por-ítem, pedir nombre, pegar preview.
import { OpDialogVm, ResumeRowVm } from "types.slint";
import { Tr } from "i18n.slint";
import { Theme } from "theme.slint";

// Botón de diálogo reutilizable (texto legible + hover).
component DlgBtn inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    in property <bool> danger: false;
    in property <bool> enabled: true;
    callback clicked();
    width: txt.preferred-width + 24px;
    height: 28px;
    border-radius: 4px;
    background: !root.enabled
        ? Theme.panel-bg
        : (touch.has-hover
            ? (root.danger ? Theme.error : Theme.selection-bg)
            : (root.danger ? Theme.error : (root.primary ? Theme.selection-bg : Theme.row-bg)));
    txt := Text {
        text: root.label;
        color: root.enabled ? white : Theme.text-dim;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}

export component OpDialogs inherits Rectangle {
    in property <OpDialogVm> vm;
    in property <[ResumeRowVm]> resume-rows;
    // Confirmar borrado:
    callback delete-confirm();
    callback delete-cancel();
    // Conflicto: action 0=sobrescribir 1=saltar 2=renombrar; all=aplicar a todos.
    callback conflict-decide(int, bool);
    // Pedir nombre:
    callback name-changed(string);   // para revalidar mientras se escribe
    callback name-confirm();
    callback name-cancel();
    // Pegar preview:
    callback paste-confirm();
    callback paste-cancel();
    // Retomar: decide por id; action 0=retomar 1=descartar.
    callback resume-decide(string, int);

    // Solo visible si hay un modal activo.
    visible: root.vm.kind > 0;
    // Velo: cubre todo y captura clics fuera de la tarjeta (cancela según el tipo).
    background: #000000aa;
    veil := TouchArea {
        clicked => {
            if (root.vm.kind == 1) { root.delete-cancel(); }
            if (root.vm.kind == 2) { root.conflict-decide(1, false); } // fuera = saltar
            if (root.vm.kind == 3) { root.name-cancel(); }
            if (root.vm.kind == 4) { root.paste-cancel(); }
        }
    }

    // Tarjeta centrada.
    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 380px;
        height: card.preferred-height + 32px;
        background: Theme.row-bg;
        border-color: Theme.selection-bg;
        border-width: 1px;
        border-radius: 8px;
        // Captura los clics dentro de la tarjeta (no propaga al velo).
        TouchArea {}
        card := VerticalLayout {
            padding: 16px;
            spacing: 14px;

            // --- 1: Confirmar borrado ---
            if root.vm.kind == 1: VerticalLayout {
                spacing: 12px;
                Text {
                    text: root.vm.del-permanent
                        ? "¿Eliminar permanentemente " + root.vm.del-count + " elemento(s)?"
                        : "¿Enviar " + root.vm.del-count + " elemento(s) a la papelera?";
                    color: white;
                    wrap: word-wrap;
                }
                if root.vm.del-permanent: Text {
                    text: Tr.dlg-no-undo;
                    color: Theme.error;
                    font-size: 12px;
                }
                HorizontalLayout {
                    alignment: end;
                    spacing: 8px;
                    DlgBtn { label: Tr.dlg-cancel; clicked => { root.delete-cancel(); } }
                    DlgBtn { label: Tr.dlg-delete; danger: true; clicked => { root.delete-confirm(); } }
                }
            }

            // --- 2: Conflicto por-ítem ---
            if root.vm.kind == 2: VerticalLayout {
                spacing: 12px;
                Text {
                    text: "Ya existe «" + root.vm.conflict-name + "». ¿Qué hacer?";
                    color: white;
                    wrap: word-wrap;
                }
                apply-all-row := HorizontalLayout {
                    spacing: 6px;
                    Rectangle {
                        width: 16px; height: 16px;
                        border-radius: 3px;
                        border-width: 1px;
                        border-color: Theme.accent;
                        background: all-touch.has-hover ? Theme.selection-bg : (apply-all-row.checked ? Theme.accent : transparent);
                        Text { text: apply-all-row.checked ? "x" : ""; color: white; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                        all-touch := TouchArea { clicked => { apply-all-row.checked = !apply-all-row.checked; } }
                    }
                    Text { text: Tr.dlg-apply-all; color: Theme.text; vertical-alignment: center; }
                    property <bool> checked: false;
                }
                HorizontalLayout {
                    alignment: end;
                    spacing: 8px;
                    DlgBtn { label: Tr.dlg-skip; clicked => { root.conflict-decide(1, apply-all-row.checked); } }
                    DlgBtn { label: Tr.dlg-rename; clicked => { root.conflict-decide(2, apply-all-row.checked); } }
                    DlgBtn { label: Tr.dlg-overwrite; danger: true; clicked => { root.conflict-decide(0, apply-all-row.checked); } }
                }
            }

            // --- 3: Pedir nombre ---
            if root.vm.kind == 3: VerticalLayout {
                spacing: 12px;
                Text { text: root.vm.name-title; color: white; }
                Rectangle {
                    height: 30px;
                    background: Theme.panel-bg;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: name-input.has-focus ? Theme.accent : Theme.border;
                    name-input := TextInput {
                        x: 8px;
                        width: parent.width - 16px;
                        color: white;
                        vertical-alignment: center;
                        text: root.vm.name-value;
                        edited => { root.name-changed(self.text); }
                        accepted => { if (root.vm.name-valid) { root.name-confirm(); } }
                    }
                }
                if !root.vm.name-valid: Text {
                    text: Tr.dlg-invalid-name;
                    color: Theme.error;
                    font-size: 12px;
                }
                HorizontalLayout {
                    alignment: end;
                    spacing: 8px;
                    DlgBtn { label: Tr.dlg-cancel; clicked => { root.name-cancel(); } }
                    DlgBtn { label: Tr.dlg-accept; primary: true; enabled: root.vm.name-valid; clicked => { root.name-confirm(); } }
                }
            }

            // --- 4: Pegar preview (texto/imagen) ---
            if root.vm.kind == 4: VerticalLayout {
                spacing: 12px;
                Text {
                    text: root.vm.paste-is-image ? "Pegar imagen como:" : "Pegar texto como:";
                    color: white;
                }
                Text { text: root.vm.paste-name; color: Theme.text; }
                HorizontalLayout {
                    alignment: end;
                    spacing: 8px;
                    DlgBtn { label: Tr.dlg-cancel; clicked => { root.paste-cancel(); } }
                    DlgBtn { label: Tr.dlg-create; primary: true; clicked => { root.paste-confirm(); } }
                }
            }

            // --- 5: Retomar operaciones interrumpidas ---
            if root.vm.kind == 5: VerticalLayout {
                spacing: 10px;
                Text {
                    text: Tr.dlg-resume-q;
                    color: white;
                    wrap: word-wrap;
                }
                for r in root.resume-rows: HorizontalLayout {
                    spacing: 6px;
                    Text {
                        text: r.label;
                        color: Theme.text;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }
                    DlgBtn { label: Tr.dlg-resume; primary: true; clicked => { root.resume-decide(r.id, 0); } }
                    DlgBtn { label: Tr.dlg-discard; clicked => { root.resume-decide(r.id, 1); } }
                }
            }
        }
    }

    // Enfocar el TextInput al abrir el modal de nombre (para escribir directo).
    forward-focus: name-focus-scope;
    name-focus-scope := FocusScope {
        // Vacío: solo para que Enter/Esc lleguen; el TextInput maneja su propio foco.
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                if (root.vm.kind == 1) { root.delete-cancel(); }
                if (root.vm.kind == 3) { root.name-cancel(); }
                if (root.vm.kind == 4) { root.paste-cancel(); }
            }
            accept
        }
    }
}
