// Naygo — diálogos modales de operaciones de archivo (Fase 3).
// Copyright (c) 2026 Nicolás Groth <ngroth@gmail.com>. ISGroth.
// SPDX-License-Identifier: MIT
//
// Un único componente `OpDialogs` que pinta el modal ACTIVO según `vm.kind`
// (0=ninguno). Overlay con velo (clic fuera cancela). Las decisiones salen por callbacks
// al controlador. Sin glifos Unicode raros (el render por software no los dibuja): solo
// texto. Los modales: confirmar borrado, conflicto por-ítem, pedir nombre, pegar preview.
import { OpDialogVm, ResumeRowVm } from "types.slint";
import { Tr } from "i18n.slint";
import { Theme } from "theme.slint";

// Botón de diálogo reutilizable.
//
// Estados (mejora visual de los modales de operación):
//   - is-default: es el botón con el FOCO (lo que activa ENTER y al que apunta TAB).
//     Se marca con un ANILLO/BORDE DE ACENTO del tema (2px Theme.accent) + fondo
//     levemente más claro (Theme.selection-bg). Reemplaza al antiguo rojo del foco.
//   - is-danger: acción destructiva (Sobrescribir, Eliminar, Reemplazar). Lleva un
//     TINTE ROJO TENUE (no el rojo saturado de antes): fondo Theme.error.with-alpha,
//     borde Theme.error.with-alpha, para advertir sin gritar.
//   - is-danger + is-default: manda el anillo de acento (tiene el foco) pero conserva
//     algo del tinte rojo de fondo para recordar que es destructivo.
//   - normal: borde fino Theme.border + fondo Theme.row-bg.
// El `shortcut` (p. ej. "Enter · S", "R", "O", "Esc") se pinta debajo del label,
// pequeño y atenuado, entre paréntesis. La tecla además funciona como atajo real
// (la maneja el FocusScope del modal).
component DlgBtn inherits Rectangle {
    in property <string> label;
    in property <string> shortcut;        // texto del atajo, p.ej. "Enter · S"
    in property <bool> is-default: false; // tiene el foco; ENTER lo activa; anillo de acento
    in property <bool> is-danger: false;  // destructivo; tinte rojo tenue
    in property <bool> enabled: true;
    callback clicked();
    // Los botones se ESTIRAN para repartir el ancho de la fila por igual (todos del mismo
    // tamaño, ocupando todo el ancho del modal). El `min-width` evita que el texto se recorte
    // si el modal fuera muy angosto.
    horizontal-stretch: 1;
    min-width: content.preferred-width + 16px;
    height: 34px;
    border-radius: 4px;
    // Fondo según estado. El tinte rojo del destructivo es tenue (.with-alpha);
    // el del foco aclara con la selección del tema; el hover sube un poco el contraste.
    background: !root.enabled
        ? Theme.panel-bg
        : (root.is-default
            ? (root.is-danger
                ? (touch.has-hover ? Theme.error.with-alpha(0.32) : Theme.error.with-alpha(0.22))
                : Theme.selection-bg)
            : (root.is-danger
                ? (touch.has-hover ? Theme.error.with-alpha(0.28) : Theme.error.with-alpha(0.18))
                : (touch.has-hover ? Theme.selection-bg : Theme.row-bg)));
    // Borde: anillo de acento grueso si tiene el foco; rojo tenue si es destructivo;
    // fino y neutro si es normal.
    border-width: root.is-default ? 2px : 1px;
    border-color: !root.enabled
        ? Theme.border
        : (root.is-default
            ? Theme.accent
            : (root.is-danger ? Theme.error.with-alpha(0.5) : Theme.border));
    content := VerticalLayout {
        alignment: center;
        spacing: 1px;
        Text {
            text: root.label;
            color: root.enabled
                ? (root.is-danger && !root.is-default ? Theme.error : white)
                : Theme.text-dim;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        // Atajo: solo si se definió. Pequeño, atenuado, entre paréntesis.
        if root.shortcut != "": Text {
            text: "(" + root.shortcut + ")";
            color: Theme.text-dim;
            font-size: 10px;
            horizontal-alignment: center;
        }
    }
    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}

// Una columna comparativa del conflicto de archivo ("Existente" o "Nuevo"). Muestra el
// encabezado, el nombre del archivo (destacado, elidido si es largo), una línea con tipo·tamaño y
// la fecha de modificación. `highlight` pinta un borde de acento tenue (se usa en la columna del
// archivo NUEVO para distinguir de un vistazo cuál es cuál).
component ConflictCol inherits Rectangle {
    in property <string> title;
    in property <string> name;
    in property <string> size;       // ya formateado ("1,2 MB" / "—")
    in property <string> date;       // ya formateada / "—"
    in property <string> kind-label; // "Carpeta" / "TXT" / "Archivo"
    in property <bool> highlight: false;
    horizontal-stretch: 1;
    border-radius: 6px;
    border-width: 1px;
    border-color: root.highlight ? Theme.accent.with-alpha(0.55) : Theme.border;
    background: Theme.row-bg;
    VerticalLayout {
        padding: 10px;
        spacing: 4px;
        // Encabezado de la columna (Existente / Nuevo).
        Text {
            text: root.title;
            color: root.highlight ? Theme.accent : Theme.text-dim;
            font-size: 11px;
        }
        // Nombre del archivo: lo más visible. Usa Theme.text (no `white` literal) para que sea
        // legible también en temas claros.
        Text {
            text: root.name;
            color: Theme.text;
            overflow: elide;
            wrap: no-wrap;
        }
        // Tipo · tamaño en una línea atenuada.
        Text {
            text: root.kind-label + " · " + root.size;
            color: Theme.text-dim;
            font-size: 12px;
            overflow: elide;
        }
        // Fecha de modificación.
        Text {
            text: root.date;
            color: Theme.text-dim;
            font-size: 12px;
            overflow: elide;
        }
    }
}

export component OpDialogs inherits Rectangle {
    in property <OpDialogVm> vm;
    in property <[ResumeRowVm]> resume-rows;
    // Confirmar borrado:
    callback delete-confirm();
    callback delete-cancel();
    // Conflicto: action 0=sobrescribir 1=saltar 2=renombrar; all=aplicar a todos.
    callback conflict-decide(int, bool);
    // Conflicto: cancelar TODA la operación sin decidir el choque (cierra el modal y aborta).
    callback conflict-cancel();
    // Conflicto: "Renombrar" pidiendo el NOMBRE nuevo (BUG 1). NO decide el choque: abre el modal
    // de nombre (kind==3) precargado con una sugerencia; al confirmar ahí se resuelve con el nombre.
    callback conflict-rename();
    // Conflicto de CARPETA (P3): decision 0=fusionar 1=reemplazar 2=saltar; all=aplicar a todas.
    callback folder-conflict-decide(int, bool);
    // Conflicto de carpeta: cancelar TODA la operación (cierra el modal y aborta).
    callback folder-conflict-cancel();
    // Pedir nombre:
    callback name-changed(string);   // para revalidar mientras se escribe
    callback name-confirm();
    callback name-cancel();
    // Pegar preview:
    callback paste-confirm();
    callback paste-cancel();
    // Retomar: decide por id; action 0=retomar 1=descartar.
    callback resume-decide(string, int);

    // Índice del botón con el FOCO dentro del modal activo. TAB lo avanza, Shift+TAB
    // lo retrocede (módulo el número de botones del kind). El botón cuyo índice coincide
    // pinta el anillo de acento (is-default) y es el que ENTER activa.
    property <int> focus-idx: 0;
    // Estado "aplicar a todos/todas" hoisteado a la tarjeta para que TANTO los botones
    // COMO el FocusScope (atajos/Enter) lean el mismo valor aunque la casilla sea
    // condicional. Uno para el conflicto de archivo (kind 2) y otro para el de carpeta (6).
    property <bool> conflict-apply-all: false;
    property <bool> folder-apply-all: false;
    // ¿Está expandido el bloque "Más opciones" del conflicto de archivo (kind==2)? Hoisteado a
    // root (como apply-all) para que persista mientras el modal vive y se resetee al reabrirlo.
    property <bool> conflict-more: false;
    // Cantidad de botones por kind (para el wrap del TAB). kind 1/4 = 2 botones,
    // kind 2/6 = 4 botones. El resto no usa TAB (3 lo maneja el TextInput; 5 tiene
    // botones por fila).
    function btn-count() -> int {
        if (root.vm.kind == 1) { return 2; }   // [Cancelar, Eliminar]
        if (root.vm.kind == 2) { return 4; }   // [Cancelar todo, Saltar, Renombrar, Sobrescribir]
        if (root.vm.kind == 4) { return 2; }   // [Cancelar, Crear]
        if (root.vm.kind == 6) { return 4; }   // [Cancelar todo, Saltar, Fusionar, Reemplazar]
        return 0;
    }
    // Dispara la acción del botón en `focus-idx` para el kind activo (lo usa ENTER).
    function activate-focused() {
        if (root.vm.kind == 1) {
            if (root.focus-idx == 0) { root.delete-cancel(); }
            if (root.focus-idx == 1) { root.delete-confirm(); }
        }
        if (root.vm.kind == 2) {
            if (root.focus-idx == 0) { root.conflict-cancel(); }
            if (root.focus-idx == 1) { root.conflict-decide(1, root.conflict-apply-all); }
            // idx 2 = "Mantener ambos" (Rename con sufijo, action int 2).
            if (root.focus-idx == 2) { root.conflict-decide(2, root.conflict-apply-all); }
            if (root.focus-idx == 3) { root.conflict-decide(0, root.conflict-apply-all); }
        }
        if (root.vm.kind == 4) {
            if (root.focus-idx == 0) { root.paste-cancel(); }
            if (root.focus-idx == 1) { root.paste-confirm(); }
        }
        if (root.vm.kind == 6) {
            if (root.focus-idx == 0) { root.folder-conflict-cancel(); }
            if (root.focus-idx == 1) { root.folder-conflict-decide(2, root.folder-apply-all); }
            if (root.focus-idx == 2) { root.folder-conflict-decide(0, root.folder-apply-all); }
            if (root.focus-idx == 3) { root.folder-conflict-decide(1, root.folder-apply-all); }
        }
    }

    // Solo visible si hay un modal activo.
    visible: root.vm.kind > 0;
    // Velo: cubre todo y captura clics fuera de la tarjeta (cancela según el tipo).
    // Un poco más oscuro que antes para que la tarjeta resalte más contra el fondo.
    background: #000000c0;
    veil := TouchArea {
        clicked => {
            if (root.vm.kind == 1) { root.delete-cancel(); }
            if (root.vm.kind == 2) { root.conflict-decide(1, false); } // fuera = saltar este archivo
            if (root.vm.kind == 3) { root.name-cancel(); }
            if (root.vm.kind == 4) { root.paste-cancel(); }
            if (root.vm.kind == 6) { root.folder-conflict-cancel(); } // fuera = cancelar la operación
        }
    }

    // Tarjeta centrada. Fondo Theme.panel-bg (más oscuro que las filas, contrasta con
    // el anillo de acento de los botones) y un BORDE SUTIL de acento tenue para que la
    // tarjeta se separe limpiamente del velo sin gritar.
    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        // El conflicto de archivo (kind==2) usa una tarjeta MÁS ANCHA para las dos columnas
        // comparativas lado a lado ("Existente" | "Nuevo"); el resto mantiene 380px.
        width: root.vm.kind == 2 ? 560px : 380px;
        height: card.preferred-height + 32px;
        background: Theme.panel-bg;
        border-color: Theme.accent.with-alpha(0.4);
        border-width: 1px;
        border-radius: 8px;
        // Captura los clics dentro de la tarjeta (no propaga al velo).
        TouchArea {}
        card := VerticalLayout {
            padding: 16px;
            spacing: 14px;

            // --- 1: Confirmar borrado ---
            if root.vm.kind == 1: VerticalLayout {
                spacing: 12px;
                Text {
                    text: root.vm.del-permanent
                        ? "¿Eliminar permanentemente " + root.vm.del-count + " elemento(s)?"
                        : "¿Enviar " + root.vm.del-count + " elemento(s) a la papelera?";
                    color: white;
                    wrap: word-wrap;
                }
                if root.vm.del-permanent: Text {
                    text: Tr.dlg-no-undo;
                    color: Theme.error;
                    font-size: 12px;
                }
                HorizontalLayout {
                    alignment: stretch;
                    spacing: 8px;
                    // Orden de TAB: [0]=Cancelar, [1]=Eliminar (default/Enter).
                    DlgBtn {
                        label: Tr.dlg-cancel; shortcut: "Esc";
                        is-default: root.focus-idx == 0;
                        clicked => { root.delete-cancel(); }
                    }
                    DlgBtn {
                        label: Tr.dlg-delete; shortcut: "Enter · D"; is-danger: true;
                        is-default: root.focus-idx == 1;
                        clicked => { root.delete-confirm(); }
                    }
                }
            }

            // --- 2: Conflicto por-ítem (rediseño estilo Directory Opus: comparación LADO A LADO) ---
            if root.vm.kind == 2: VerticalLayout {
                spacing: 12px;
                Text {
                    // "Ya existe «X». ¿Qué quieres hacer?" (el nombre va inline; la pregunta es i18n).
                    text: "«" + root.vm.conflict-name + "» — " + Tr.dlg-conflict-question;
                    color: white;
                    wrap: word-wrap;
                }
                // Dos columnas comparables: "Existente" (lo que ya está en el destino) | "Nuevo"
                // (lo que llega). Cada una muestra nombre + tipo·tamaño + fecha. La de "Nuevo" lleva
                // un borde de acento tenue para distinguir de un vistazo cuál es cuál.
                HorizontalLayout {
                    spacing: 10px;
                    ConflictCol {
                        title: Tr.dlg-conflict-existing;
                        name: root.vm.existing-name;
                        size: root.vm.existing-size;
                        date: root.vm.existing-date;
                        kind-label: root.vm.existing-is-dir
                            ? Tr.dlg-kind-folder
                            : (root.vm.existing-ext != "" ? root.vm.existing-ext : Tr.dlg-kind-file);
                        highlight: false;
                    }
                    ConflictCol {
                        title: Tr.dlg-conflict-incoming;
                        name: root.vm.incoming-name;
                        size: root.vm.incoming-size;
                        date: root.vm.incoming-date;
                        kind-label: root.vm.incoming-is-dir
                            ? Tr.dlg-kind-folder
                            : (root.vm.incoming-ext != "" ? root.vm.incoming-ext : Tr.dlg-kind-file);
                        highlight: true;
                    }
                }
                // "De dónde a dónde": carpeta de origen y de destino (rutas atenuadas, elididas si
                // son largas para no romper el ancho del modal). Solo si se conocen.
                if root.vm.conflict-from != "" || root.vm.conflict-to != "": VerticalLayout {
                    spacing: 2px;
                    if root.vm.conflict-from != "": HorizontalLayout {
                        spacing: 6px;
                        Text { text: Tr.dlg-conflict-from; color: Theme.text-dim; font-size: 12px; }
                        Text {
                            text: root.vm.conflict-from;
                            color: Theme.text-dim;
                            font-size: 12px;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }
                    }
                    if root.vm.conflict-to != "": HorizontalLayout {
                        spacing: 6px;
                        Text { text: Tr.dlg-conflict-to; color: Theme.text-dim; font-size: 12px; }
                        Text {
                            text: root.vm.conflict-to;
                            color: Theme.text-dim;
                            font-size: 12px;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }
                    }
                }
                apply-all-row := HorizontalLayout {
                    spacing: 6px;
                    Rectangle {
                        width: 16px; height: 16px;
                        border-radius: 3px;
                        border-width: 1px;
                        border-color: Theme.accent;
                        background: all-touch.has-hover ? Theme.selection-bg : (root.conflict-apply-all ? Theme.accent : transparent);
                        Text { text: root.conflict-apply-all ? "x" : ""; color: white; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                        all-touch := TouchArea { clicked => { root.conflict-apply-all = !root.conflict-apply-all; } }
                    }
                    Text { text: Tr.dlg-apply-all; color: Theme.text; vertical-alignment: center; }
                }
                // Acciones PRINCIPALES (las que navega TAB; btn-count()==4):
                //   [0]=Cancelar todo, [1]=Saltar (default/Enter, segura), [2]=Mantener ambos
                //   (Rename sufijo), [3]=Sobrescribir (destructivo).
                HorizontalLayout {
                    alignment: stretch;
                    spacing: 8px;
                    DlgBtn {
                        label: Tr.dlg-conflict-cancel-all; shortcut: "Esc";
                        is-default: root.focus-idx == 0;
                        clicked => { root.conflict-cancel(); }
                    }
                    DlgBtn {
                        label: Tr.dlg-skip; shortcut: "Enter · S";
                        is-default: root.focus-idx == 1;
                        clicked => { root.conflict-decide(1, root.conflict-apply-all); }
                    }
                    // "Mantener ambos" = renombrar el NUEVO con sufijo automático (ConflictAction
                    // Rename, action int 2). Conserva el existente y deja entrar el nuevo con "(N)".
                    DlgBtn {
                        label: Tr.dlg-keep-both; shortcut: "M";
                        is-default: root.focus-idx == 2;
                        clicked => { root.conflict-decide(2, root.conflict-apply-all); }
                    }
                    DlgBtn {
                        label: Tr.dlg-overwrite; shortcut: "O"; is-danger: true;
                        is-default: root.focus-idx == 3;
                        clicked => { root.conflict-decide(0, root.conflict-apply-all); }
                    }
                }
                // Desplegable "Más opciones": agrupa las acciones avanzadas (estilo submenú de Opus)
                // para NO saturar. El usuario lo expande con un clic. La fila extra NO entra en el
                // TAB de los 4 botones principales (se opera con clic / atajos propios).
                HorizontalLayout {
                    alignment: start;
                    spacing: 6px;
                    Text {
                        text: (root.conflict-more ? "▾ " : "▸ ")
                            + (root.conflict-more ? Tr.dlg-fewer-options : Tr.dlg-more-options);
                        color: Theme.accent;
                        font-size: 12px;
                        vertical-alignment: center;
                        more-touch := TouchArea {
                            clicked => { root.conflict-more = !root.conflict-more; }
                        }
                    }
                }
                if root.conflict-more: VerticalLayout {
                    spacing: 8px;
                    HorizontalLayout {
                        alignment: stretch;
                        spacing: 8px;
                        // "Renombrar…" pide un NOMBRE nuevo para el entrante (abre el modal de
                        // nombre; no aplica a todos: cada archivo necesita su propio nombre).
                        DlgBtn {
                            label: Tr.dlg-rename;
                            clicked => { root.conflict-rename(); }
                        }
                        // "Renombrar el existente": aparta el viejo con sufijo y deja entrar el nuevo
                        // con su nombre original (action int 3 = RenameExisting).
                        DlgBtn {
                            label: Tr.dlg-rename-existing;
                            clicked => { root.conflict-decide(3, root.conflict-apply-all); }
                        }
                        // "Saltar idénticos": política (action int 4 = SkipIdentical). Lo natural es
                        // con "aplicar a todos"; respeta la casilla.
                        DlgBtn {
                            label: Tr.dlg-skip-identical;
                            clicked => { root.conflict-decide(4, root.conflict-apply-all); }
                        }
                    }
                    HorizontalLayout {
                        alignment: stretch;
                        spacing: 8px;
                        // Atajos directos para "aplicar la misma decisión a TODOS los conflictos":
                        // Sobrescribir todos / Saltar todos (= la acción + apply_all forzado a true).
                        DlgBtn {
                            label: Tr.dlg-overwrite-all; is-danger: true;
                            clicked => { root.conflict-decide(0, true); }
                        }
                        DlgBtn {
                            label: Tr.dlg-skip-all;
                            clicked => { root.conflict-decide(1, true); }
                        }
                    }
                }
            }

            // --- 6: Conflicto de CARPETA (P3) ---
            if root.vm.kind == 6: folder-card := VerticalLayout {
                spacing: 12px;
                // El estado "aplicar a todas" vive en root.folder-apply-all (hoisteado) para que
                // los botones Y el FocusScope (atajos/Enter) lean el mismo valor aunque la casilla
                // (condicional) no se muestre.
                Text {
                    // "La carpeta «X» ya existe. ¿Qué hacer?" — el nombre va entre pre y suf
                    // (Slint no tiene replace; el patrón i18n parte el texto alrededor del nombre).
                    text: Tr.dlg-folder-exists-pre + root.vm.folder-name + Tr.dlg-folder-exists-suf;
                    color: white;
                    wrap: word-wrap;
                }
                // "De dónde a dónde": carpeta de origen y de destino (rutas atenuadas, elididas si
                // son largas). Solo si se conocen.
                if root.vm.conflict-from != "" || root.vm.conflict-to != "": VerticalLayout {
                    spacing: 2px;
                    if root.vm.conflict-from != "": HorizontalLayout {
                        spacing: 6px;
                        Text { text: Tr.dlg-conflict-from; color: Theme.text-dim; font-size: 12px; }
                        Text {
                            text: root.vm.conflict-from;
                            color: Theme.text-dim;
                            font-size: 12px;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }
                    }
                    if root.vm.conflict-to != "": HorizontalLayout {
                        spacing: 6px;
                        Text { text: Tr.dlg-conflict-to; color: Theme.text-dim; font-size: 12px; }
                        Text {
                            text: root.vm.conflict-to;
                            color: Theme.text-dim;
                            font-size: 12px;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }
                    }
                }
                // Casilla "aplicar a todas las carpetas": solo si hay más de una en conflicto.
                if root.vm.folder-more: HorizontalLayout {
                    spacing: 6px;
                    Rectangle {
                        width: 16px; height: 16px;
                        border-radius: 3px;
                        border-width: 1px;
                        border-color: Theme.accent;
                        background: fall-touch.has-hover ? Theme.selection-bg : (root.folder-apply-all ? Theme.accent : transparent);
                        Text { text: root.folder-apply-all ? "x" : ""; color: white; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                        fall-touch := TouchArea { clicked => { root.folder-apply-all = !root.folder-apply-all; } }
                    }
                    Text { text: Tr.dlg-folder-apply-all; color: Theme.text; vertical-alignment: center; }
                }
                HorizontalLayout {
                    alignment: stretch;
                    spacing: 8px;
                    // Orden de TAB: [0]=Cancelar todo, [1]=Saltar (default/Enter, opción segura),
                    // [2]=Fusionar, [3]=Reemplazar (destructivo).
                    DlgBtn {
                        label: Tr.dlg-conflict-cancel-all; shortcut: "Esc";
                        is-default: root.focus-idx == 0;
                        clicked => { root.folder-conflict-cancel(); }
                    }
                    DlgBtn {
                        label: Tr.dlg-folder-skip; shortcut: "Enter · S";
                        is-default: root.focus-idx == 1;
                        clicked => { root.folder-conflict-decide(2, root.folder-apply-all); }
                    }
                    DlgBtn {
                        label: Tr.dlg-folder-merge; shortcut: "F";
                        is-default: root.focus-idx == 2;
                        clicked => { root.folder-conflict-decide(0, root.folder-apply-all); }
                    }
                    DlgBtn {
                        label: Tr.dlg-folder-replace; shortcut: "R"; is-danger: true;
                        is-default: root.focus-idx == 3;
                        clicked => { root.folder-conflict-decide(1, root.folder-apply-all); }
                    }
                }
            }

            // --- 3: Pedir nombre ---
            if root.vm.kind == 3: VerticalLayout {
                spacing: 12px;
                // Si el modal es para "Renombrar" un conflicto (BUG 1), el título es i18n
                // ("Nuevo nombre para «X»", con X = name-conflict-for); si no, usa name-title
                // (nuevo archivo/carpeta/pegar), que ya viene formado desde el controlador.
                Text {
                    text: root.vm.name-conflict-for != ""
                        ? Tr.dlg-rename-to-pre + root.vm.name-conflict-for + Tr.dlg-rename-to-suf
                        : root.vm.name-title;
                    color: white;
                    wrap: word-wrap;
                }
                Rectangle {
                    height: 30px;
                    background: Theme.panel-bg;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: name-input.has-focus ? Theme.accent : Theme.border;
                    name-input := TextInput {
                        x: 8px;
                        width: parent.width - 16px;
                        color: white;
                        vertical-alignment: center;
                        text: root.vm.name-value;
                        edited => { root.name-changed(self.text); }
                        accepted => { if (root.vm.name-valid) { root.name-confirm(); } }
                    }
                }
                if !root.vm.name-valid: Text {
                    text: Tr.dlg-invalid-name;
                    color: Theme.error;
                    font-size: 12px;
                }
                HorizontalLayout {
                    alignment: stretch;
                    spacing: 8px;
                    // El foco vive en el TextInput (escribir directo), que maneja su propio Enter.
                    // Aceptar lleva el anillo de acento como botón por defecto visual.
                    DlgBtn { label: Tr.dlg-cancel; shortcut: "Esc"; clicked => { root.name-cancel(); } }
                    DlgBtn {
                        label: Tr.dlg-accept; shortcut: "Enter"; is-default: root.vm.name-valid;
                        enabled: root.vm.name-valid; clicked => { root.name-confirm(); }
                    }
                }
            }

            // --- 4: Pegar preview (texto/imagen) ---
            if root.vm.kind == 4: VerticalLayout {
                spacing: 12px;
                Text {
                    text: root.vm.paste-is-image ? Tr.dlg-paste-img : Tr.dlg-paste-txt;
                    color: white;
                }
                Text { text: root.vm.paste-name; color: Theme.text; }
                HorizontalLayout {
                    alignment: stretch;
                    spacing: 8px;
                    // Orden de TAB: [0]=Cancelar, [1]=Crear (default/Enter).
                    DlgBtn {
                        label: Tr.dlg-cancel; shortcut: "Esc";
                        is-default: root.focus-idx == 0;
                        clicked => { root.paste-cancel(); }
                    }
                    DlgBtn {
                        label: Tr.dlg-create; shortcut: "Enter · C";
                        is-default: root.focus-idx == 1;
                        clicked => { root.paste-confirm(); }
                    }
                }
            }

            // --- 5: Retomar operaciones interrumpidas ---
            if root.vm.kind == 5: VerticalLayout {
                spacing: 10px;
                Text {
                    text: Tr.dlg-resume-q;
                    color: white;
                    wrap: word-wrap;
                }
                for r in root.resume-rows: HorizontalLayout {
                    spacing: 6px;
                    Text {
                        text: r.label;
                        color: Theme.text;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }
                    // Retomar (acción recomendada por fila) lleva el anillo de acento; el modal de
                    // retomar tiene varias filas, así que no usa el índice de foco global.
                    DlgBtn { label: Tr.dlg-resume; is-default: true; clicked => { root.resume-decide(r.id, 0); } }
                    DlgBtn { label: Tr.dlg-discard; clicked => { root.resume-decide(r.id, 1); } }
                }
            }
        }
    }

    // Enfocar el FocusScope cada vez que aparece un modal (no solo en `init`, que corre una
    // sola vez: OpDialogs siempre está montado y solo cambia `vm.kind`). Sin esto el
    // FocusScope nunca recibe el foco y ni Enter ni Escape llegan de forma fiable.
    // Se observa `kind` a través de una property intermedia porque `changed` sobre un campo
    // de un struct (root.vm.kind) no dispara; espejar el valor en `k` sí dispara `changed k`.
    property <int> k: root.vm.kind;
    changed k => {
        if (root.k > 0) {
            // Resetear "aplicar a todos/todas" al abrir cada modal: estos flags están hoisteados a
            // root (para que el FocusScope/atajos los lean), así que ya NO se re-crean en false al
            // desmontarse el modal. Sin este reset, la casilla arrastraría el valor de una operación
            // anterior (un default destructivo silencioso en la siguiente copia con conflicto).
            root.conflict-apply-all = false;
            root.folder-apply-all = false;
            root.conflict-more = false;
            // El modal de nombre (3) enfoca su propio TextInput vía forward-focus; los demás
            // (borrado/conflictos/pegar) necesitan que el FocusScope tome el foco para Enter/Esc.
            name-focus-scope.focus();
            // Inicializa el índice de foco apuntando al botón SEGURO/recomendado por kind:
            //   1 (eliminar) → Eliminar (idx 1, confirmación; lo que ya hacía Enter)
            //   2 (conflicto archivo) → Saltar (idx 1, opción segura, decisión previa)
            //   4 (pegar) → Crear (idx 1)
            //   6 (conflicto carpeta) → Saltar (idx 1, opción segura)
            // Todos comparten idx 1, pero se deja explícito por si cambian los órdenes.
            if (root.vm.kind == 1) { root.focus-idx = 1; }
            if (root.vm.kind == 2) { root.focus-idx = 1; }
            if (root.vm.kind == 4) { root.focus-idx = 1; }
            if (root.vm.kind == 6) { root.focus-idx = 1; }
        }
    }

    // Enfocar el TextInput al abrir el modal de nombre (para escribir directo).
    forward-focus: name-focus-scope;
    name-focus-scope := FocusScope {
        // El FocusScope recibe el foco al abrir el modal (changed k → focus()). Aquí se manejan:
        //   - Escape: cancela según el kind.
        //   - Enter: activa el botón en focus-idx (el del anillo de acento). Para "pedir
        //     nombre" (3) el TextInput maneja su propio `accepted`, así que aquí no se toca.
        //   - Tab / Shift+Tab: mueve focus-idx entre los botones del modal (con wrap), de modo
        //     que el anillo de acento se mueve con él. Se ignora en kinds sin botones navegables.
        //   - Letras de atajo (fijas, comparadas en minúscula sin importar idioma): disparan el
        //     MISMO callback que el botón correspondiente. kind 2: s/r/o; kind 6: f/r/s;
        //     kind 1: d=eliminar; kind 4: c=crear. Son las letras que cada botón muestra.
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                if (root.vm.kind == 1) { root.delete-cancel(); }
                if (root.vm.kind == 2) { root.conflict-decide(1, false); } // Esc = saltar este archivo
                if (root.vm.kind == 3) { root.name-cancel(); }
                if (root.vm.kind == 4) { root.paste-cancel(); }
                if (root.vm.kind == 6) { root.folder-conflict-cancel(); }
                return accept;
            }
            // Tab / Shift+Tab: navegar el foco entre botones (módulo la cantidad del kind).
            if (event.text == Key.Tab) {
                if (root.btn-count() > 0) {
                    if (event.modifiers.shift) {
                        root.focus-idx = Math.mod(root.focus-idx + root.btn-count() - 1, root.btn-count());
                    } else {
                        root.focus-idx = Math.mod(root.focus-idx + 1, root.btn-count());
                    }
                }
                return accept;
            }
            // Enter activa el botón enfocado. En "pedir nombre" (3) el TextInput maneja Enter.
            if (event.text == Key.Return) {
                if (root.vm.kind != 3) { root.activate-focused(); }
                return accept;
            }
            // Letras de atajo (comparación en minúscula, fija, independiente del idioma).
            if (root.vm.kind == 1) {
                if (event.text == "d" || event.text == "D") { root.delete-confirm(); return accept; }
            }
            if (root.vm.kind == 2) {
                // Atajos del conflicto de archivo: s=Saltar, m=Mantener ambos, o=Sobrescribir
                // (los 3 principales); r=Renombrar… (abre el modal de nombre, también disponible
                // en "Más opciones").
                if (event.text == "s" || event.text == "S") { root.conflict-decide(1, root.conflict-apply-all); return accept; }
                if (event.text == "m" || event.text == "M") { root.conflict-decide(2, root.conflict-apply-all); return accept; }
                if (event.text == "o" || event.text == "O") { root.conflict-decide(0, root.conflict-apply-all); return accept; }
                if (event.text == "r" || event.text == "R") { root.conflict-rename(); return accept; }
            }
            if (root.vm.kind == 4) {
                if (event.text == "c" || event.text == "C") { root.paste-confirm(); return accept; }
            }
            if (root.vm.kind == 6) {
                if (event.text == "f" || event.text == "F") { root.folder-conflict-decide(0, root.folder-apply-all); return accept; }
                if (event.text == "r" || event.text == "R") { root.folder-conflict-decide(1, root.folder-apply-all); return accept; }
                if (event.text == "s" || event.text == "S") { root.folder-conflict-decide(2, root.folder-apply-all); return accept; }
            }
            accept
        }
    }
}
