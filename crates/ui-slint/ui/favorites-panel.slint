//
// Clic en una fila navega el panel Files activo; el botón × quita un favorito.
import { ListView } from "std-widgets.slint";
import { NavRow } from "types.slint";
import { Tr } from "i18n.slint";
import { Theme } from "theme.slint";

export component FavoritesPanel inherits Rectangle {
    in property <bool> active;
    in property <[NavRow]> favs;
    in property <[NavRow]> recents;
    callback navigate(string);   // ruta a la que ir
    callback remove(string);     // quitar favorito por ruta
    callback pin-current();      // anclar la carpeta del panel activo como favorita
    callback focus-pane();       // marcar este panel como activo al interactuar

    background: Theme.panel-bg;
    border-width: root.active ? 1.5px : 0px;
    border-color: Theme.accent;

    VerticalLayout {
        padding: 6px;
        spacing: 4px;
        HorizontalLayout {
            height: 20px;
            Text {
                text: Tr.fav-title;
                color: Theme.text-dim;
                font-weight: 700;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
            Rectangle {
                width: 52px;
                background: pin-touch.has-hover ? Theme.selection-bg : Theme.row-bg;
                border-radius: 3px;
                Text { text: Tr.fav-pin; color: Theme.highlight; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                pin-touch := TouchArea { clicked => { root.pin-current(); } }
            }
        }
        if root.favs.length == 0: Text {
            text: Tr.fav-empty;
            color: Theme.text-dim;
            height: 18px;
        }
        for f[i] in root.favs: Rectangle {
            height: 22px;
            background: fav-touch.has-hover ? Theme.row-alt-bg : transparent;
            border-radius: 3px;
            HorizontalLayout {
                padding-left: 6px;
                spacing: 4px;
                Image {
                    source: f.icon;
                    width: 16px;
                    height: 16px;
                    vertical-alignment: center;
                    image-rendering: smooth;
                }
                Text {
                    text: f.label;
                    color: Theme.highlight;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    overflow: elide;
                }
                Rectangle {
                    width: 18px;
                    background: rm-touch.has-hover ? Theme.error : transparent;
                    border-radius: 3px;
                    Text { text: "x"; color: Theme.error; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                    rm-touch := TouchArea {
                        clicked => { root.remove(f.path); }
                    }
                }
            }
            fav-touch := TouchArea {
                clicked => { root.focus-pane(); root.navigate(f.path); }
            }
        }

        Text {
            text: Tr.fav-recents;
            color: Theme.text-dim;
            font-weight: 700;
            height: 20px;
            vertical-alignment: center;
        }
        ListView {
            vertical-stretch: 1;
            for r[i] in root.recents: Rectangle {
                height: 22px;
                background: rec-touch.has-hover ? Theme.row-alt-bg : transparent;
                border-radius: 3px;
                HorizontalLayout {
                    padding-left: 6px;
                    spacing: 4px;
                    Image {
                        source: r.icon;
                        width: 16px;
                        height: 16px;
                        vertical-alignment: center;
                        image-rendering: smooth;
                    }
                    Text {
                        text: r.label;
                        color: Theme.text;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }
                }
                rec-touch := TouchArea {
                    clicked => { root.focus-pane(); root.navigate(r.path); }
                }
            }
        }
    }
}
