export component PathBar inherits Rectangle {
    in property <string> path;
    callback go-up();
    height: 30px;
    background: #1b2838;
    border-radius: 4px;
    HorizontalLayout {
        padding: 4px;
        spacing: 6px;
        Rectangle {
            width: 30px;
            background: up-touch.has-hover ? #2a4a7a : transparent;
            border-radius: 4px;
            Text {
                text: "↑";
                color: white;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            up-touch := TouchArea {
                clicked => {
                    root.go-up();
                }
            }
        }
        Text {
            text: root.path;
            color: #cdd;
            vertical-alignment: center;
        }
    }
}
