import { LineEdit } from "std-widgets.slint";
import { RowData, PaneVm, SplitVm, PickVm, TabVm, OpDialogVm, OpRowVm, ResumeRowVm, ContextMenuVm, ColumnMenuVm, NavRow, LayoutRow } from "types.slint";
import { PathBar } from "path-bar.slint";
import { FilePanel } from "file-panel.slint";
import { ColumnMenu } from "column-menu.slint";
import { TreePanel } from "tree-panel.slint";
import { InspectorPanel } from "inspector-panel.slint";
import { HistoryPanel } from "history-panel.slint";
import { FavoritesPanel } from "favorites-panel.slint";
import { PreviewPanel } from "preview-panel.slint";
import { OpDialogs } from "op-dialogs.slint";
import { OpsPanel } from "ops-panel.slint";
import { ContextMenu } from "context-menu.slint";
import { ConfigWindow } from "config-window.slint";
import { BatchRename } from "batch-rename.slint";
import { Help } from "help.slint";
import { BatchRenameVm, HelpRowVm } from "types.slint";
import { SettingsVm, ShortcutRowVm, PreviewRuleVm } from "types.slint";
import { Tr } from "i18n.slint";
import { Theme } from "theme.slint";
import { Splash } from "splash.slint";
// Reexportar los globals para que Slint genere su binding accesible desde Rust
// (i18n_keys / theme_apply). Splash se reexporta para tener su componente en Rust.
export { Tr }
export { Theme }
export { Splash }

// Barra de pestañas de un grupo: una pestaña por miembro; la activa resaltada; cada una
// con su × para cerrarla. Clic en una pestaña la activa.
component TabBar inherits Rectangle {
    in property <[TabVm]> tabs;
    callback select(int);
    callback close(int);
    height: 24px;
    background: Theme.panel-bg;
    HorizontalLayout {
        padding: 2px;
        spacing: 2px;
        for t in root.tabs: Rectangle {
            background: t.active ? Theme.selection-bg : (tab-touch.has-hover ? Theme.row-alt-bg : Theme.row-bg);
            border-radius: 4px;
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 4px;
                spacing: 4px;
                Text {
                    text: t.label;
                    color: t.active ? white : Theme.text-dim;
                    vertical-alignment: center;
                    overflow: elide;
                }
                Rectangle {
                    width: 16px;
                    background: x-touch.has-hover ? Theme.error : transparent;
                    border-radius: 3px;
                    Text { text: "x"; color: Theme.error; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                    x-touch := TouchArea { clicked => { root.close(t.id); } }
                }
            }
            tab-touch := TouchArea { clicked => { root.select(t.id); } }
        }
    }
}

// Botón de la barra de herramientas: etiqueta de texto (el renderizador por software no
// dibuja glifos Unicode raros, así que usamos texto legible) + tooltip al pasar el mouse.
component ToolBtn inherits Rectangle {
    in property <string> label;
    in property <string> tip;
    in property <length> btn-width: 34px;
    in property <bool> highlight: false;
    // Ícono de acción cacheado (6B). Vacío = botón solo-texto (p. ej. el "+").
    in property <image> icon;
    // Si true, se oculta el texto y queda solo el ícono (Settings.icon_only).
    in property <bool> icon-only: false;
    callback clicked();
    width: root.btn-width;
    background: (touch.has-hover || root.highlight) ? Theme.selection-bg : Theme.row-bg;
    border-radius: 7px;
    // Contenido centrado por geometría (no por layout, que dejaba el ícono descentrado):
    // ícono + texto juntos, centrados en el botón. En icon-only solo va el ícono.
    content-row := HorizontalLayout {
        spacing: 5px;
        x: (parent.width - self.preferred-width) / 2;
        y: (parent.height - self.preferred-height) / 2;
        width: self.preferred-width;
        height: self.preferred-height;
        if root.icon.width > 0: Image {
            source: root.icon;
            width: 16px;
            height: 16px;
            image-rendering: smooth;
        }
        if !root.icon-only || root.icon.width == 0: Text {
            text: root.label;
            color: white;
            font-size: 12px;
            vertical-alignment: center;
        }
    }
    // Publica el tooltip y su posición X (centro del botón) al pasar el mouse, para que la
    // AppWindow lo pinte ENCIMA del contenido (un tooltip anidado en la toolbar queda tapado
    // por los paneles, que se pintan después en el VerticalLayout).
    callback hover-tip(string, length);
    touch := TouchArea {
        clicked => { root.clicked(); }
        changed has-hover => {
            root.hover-tip(self.has-hover ? root.tip : "", root.absolute-position.x + root.width / 2);
        }
    }
}

// Botón compacto de unidad de disco para la tira de la toolbar: ícono + letra (p. ej. "C:").
// Clic navega el panel activo a la raíz. Tooltip con la ruta.
component DriveBtn inherits Rectangle {
    in property <string> label;
    in property <string> tip;
    in property <image> icon;
    callback clicked();
    width: drive-row.preferred-width + 10px;
    background: dtouch.has-hover ? Theme.selection-bg : Theme.row-bg;
    border-radius: 4px;
    drive-row := HorizontalLayout {
        alignment: center;
        spacing: 3px;
        padding-left: 5px;
        padding-right: 5px;
        Image {
            source: root.icon;
            width: 15px;
            height: 15px;
            vertical-alignment: center;
            image-rendering: smooth;
        }
        Text {
            text: root.label;
            color: white;
            font-size: 12px;
            vertical-alignment: center;
        }
    }
    callback hover-tip(string, length);
    dtouch := TouchArea {
        clicked => { root.clicked(); }
        changed has-hover => {
            root.hover-tip(self.has-hover ? root.tip : "", root.absolute-position.x + root.width / 2);
        }
    }
}

// Un ítem del menú desplegable ▾.
component MenuItem inherits Rectangle {
    in property <string> label;
    callback clicked();
    height: 26px;
    background: mi-touch.has-hover ? Theme.selection-bg : transparent;
    border-radius: 4px;
    Text {
        text: root.label;
        color: Theme.text;
        vertical-alignment: center;
        x: 8px;
    }
    mi-touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component AppWindow inherits Window {
    title: "Naygo";
    preferred-width: 1000px;
    preferred-height: 640px;
    // Tope de tamaño explícito y amplio: sin esto, el max-width que Slint computa del árbol de
    // layout (toolbar + paneles) terminaba acotando el ancho de la ventana y Windows no dejaba
    // ensancharla más allá de ~600px. Forzar un max grande deja crecer libremente.
    max-width: 6000px;
    max-height: 4000px;

    in property <string> active-path;
    in property <[PaneVm]> panes;
    in property <[SplitVm]> splits;
    callback go-up();
    callback add-pane();
    callback add-pane-dir(int);       // divide el panel activo en una dirección: 0=derecha
                                      // 1=abajo 2=izquierda 3=arriba (menú del botón "+")
    callback add-pane-of(int);        // agrega un panel del purpose dado (menú ▾)
    callback row-clicked(int, int);
    callback row-double-clicked(int, int);
    callback row-drag-out(int);           // inicia el arrastre OLE de los archivos seleccionados
    callback rubber-band(int, int, int);  // (pane, from, to) selección por rectángulo (6F)
    // --- Barra de ruta (breadcrumbs + edición + autocompletado) ---
    // El panel que está editando su ruta (-1 = ninguno), su texto y sus candidatos. Rust los
    // controla; el FilePanel correspondiente muestra el editor.
    in-out property <int> edit-pane: -1;
    in property <string> edit-text;
    in property <[string]> edit-suggestions;
    // --- Rename inline (6D): la fila `rename-pos` del panel `rename-pane` muestra un editor. ---
    in-out property <int> rename-pane: -1;
    in-out property <int> rename-pos: -1;
    in property <string> rename-text;          // texto inicial del editor (lo fija Rust)
    callback rename-commit(int, int, string);  // (pane, pos, nombre) Enter → renombrar y cerrar
    callback rename-chain(int, int, string, int); // (pane, pos, nombre, dir) ↑/↓ → encadenar
    callback rename-cancel();                   // Esc → cerrar sin renombrar
    callback path-segment-clicked(int, string);
    callback path-edit-start(int);
    callback path-edit-changed(int, string);
    callback path-edit-commit(int, string);
    callback path-edit-cancel(int);
    callback path-suggestion-clicked(int, string);
    callback fav-toggle(int);             // (pane-id) ★ anclar/quitar favorito de la carpeta
    callback copy-path(int);              // (pane-id) 📋 copiar la ruta al portapapeles
    callback sort-by(int, string);
    callback sort-by-kind(int, int);      // (pane-id, kind) ordenar por columna dinámica
    callback column-toggle(int, int);     // (pane-id, kind) mostrar/ocultar columna
    callback column-move(int, int, int);  // (pane-id, from, to) reordenar columnas
    callback column-resize(int, int, length); // (pane-id, kind, ancho) redimensionar
    // Menú/editor de columna (clic derecho en el header, F2).
    callback column-context(int, int, length, length); // (pane-id, kind, x, y) abrir menú
    in property <ColumnMenuVm> column-menu;
    callback colmenu-sort-asc();
    callback colmenu-sort-desc();
    callback colmenu-open-filter();
    callback colmenu-clear-filter();
    callback colmenu-hide();
    callback colmenu-move-left();
    callback colmenu-move-right();
    callback colfilter-set-text(string);
    callback colfilter-toggle-case();
    callback colfilter-set-min(string);
    callback colfilter-set-max(string);
    callback colfilter-toggle-ext(string);
    callback colfilter-apply();
    callback colmenu-dismiss();
    callback activate(int);
    callback key(string, bool, bool, bool);
    // Arrastre de splitter (resize de paneles). `split-drag` pide a Rust la posición ACOTADA
    // del borde para pintar la barra-fantasma EN VIVO (Rust setea splitpreview-*); `split-commit`
    // (al soltar) aplica la fraction de verdad. Se separa porque reflowar todo el layout en cada
    // `moved` no repinta bajo el render por software (solo tras un input) y se ve distorsionado;
    // la barra-fantasma (un único Rectangle por escalares) sí repinta al instante.
    callback split-drag(int, length, length);
    callback split-commit(int, length, length);
    // Barra-fantasma del splitter en curso (rect en coords de contenido; w/h 0 = oculta).
    in property <length> splitpreview-x;
    in property <length> splitpreview-y;
    in property <length> splitpreview-w;
    in property <length> splitpreview-h;
    // Paneles especiales:
    callback tree-toggle(int, string);   // (pane-id, ruta) expandir/colapsar rama
    callback tree-navigate(string);      // navegar el Files activo a esa carpeta
    callback tree-key(int, string);      // (pane-id, dir) navegación por teclado del árbol
    callback nav-navigate(string);       // favorito/reciente → navegar Files activo
    callback fav-remove(string);         // quitar favorito por ruta
    callback fav-pin-current();          // anclar la carpeta del Files activo
    callback undo-entry(int);            // deshacer la entrada del historial
    // Acciones multi-panel (toolbar):
    callback swap-panes();               // intercambiar el activo con el otro panel
    callback clone-pane();               // clonar la carpeta del activo en otro panel
    callback stack-pane();               // apilar el activo como pestaña sobre otro panel
    // Pestañas (grupos):
    callback tab-select(int);            // activar la pestaña (PaneId)
    callback tab-close(int);             // cerrar la pestaña (PaneId)
    // Reacomodo por arrastre (drag-to-rearrange):
    callback pane-drag-move(int, length, length); // (PaneId, x, y) en coords de contenido
    callback pane-drag-drop(int, length, length); // soltar: recompone el layout
    // Vista previa de la zona de drop activa (rect en coords de contenido; w/h 0 = oculta).
    in property <length> drop-x;
    in property <length> drop-y;
    in property <length> drop-w;
    in property <length> drop-h;
    // La zona es el CENTRO (apilar como pestaña): la UI lo pinta como una pestaña, no como
    // un relleno de borde, para que se entienda que va a agrupar en tabs.
    in property <bool> drop-is-tab;
    // Selector numérico de panel destino (overlay 1..9):
    in property <[PickVm]> picks;        // candidatos con su rect + número (vacío = sin selector)
    callback pick-resolve(int);          // elegí el panel número N (clic)
    callback pick-cancel();              // cancelar (clic fuera)
    // Texto de la barra de estado (carpeta activa + recuento de ítems/selección).
    in property <string> status;
    // Operaciones de archivo (Fase 3): modal activo + filas de progreso.
    in property <OpDialogVm> op-dialog;
    in property <[OpRowVm]> op-rows;
    in property <[ResumeRowVm]> resume-rows;
    callback resume-decide(string, int);
    callback delete-confirm();
    callback delete-cancel();
    callback conflict-decide(int, bool);   // (action, apply-all)
    callback name-changed(string);
    callback name-confirm();
    callback name-cancel();
    callback paste-confirm();
    callback paste-cancel();
    callback op-cancel(int);
    // Menú contextual (clic derecho).
    callback row-context(int, int, length, length);  // (pane-id, pos, x, y)
    in property <ContextMenuVm> ctx-menu;
    callback ctx-open();
    callback ctx-open-with();
    callback ctx-copy();
    callback ctx-cut();
    callback ctx-paste();
    callback ctx-rename();
    callback ctx-delete();
    callback ctx-copy-names();
    callback ctx-copy-path();
    callback ctx-terminal-ps();
    callback ctx-terminal-cmd();
    callback ctx-terminal-wt();
    callback ctx-native();
    callback ctx-dismiss();
    // Estado del menú ▾ (desplegable de "agregar panel").
    property <bool> add-menu-open: false;
    // Estado del menú del botón "+" (elegir dirección de la división).
    property <bool> dir-menu-open: false;
    // Menú de Layouts (F4): plantillas de disposición. `layout-rows` lo llena Rust.
    property <bool> layout-menu-open: false;
    in property <[LayoutRow]> layout-rows;
    callback apply-layout(string);      // aplicar la plantilla `name`
    callback delete-layout(string);     // borrar una plantilla de usuario `name`
    callback save-layout(string);       // guardar la disposición actual como plantilla `name`
    // Renombrado por lotes (F5):
    in property <BatchRenameVm> batch;
    callback batch-set-template(string);
    callback batch-set-find(string);
    callback batch-set-replace(string);
    callback batch-set-regex(bool);
    callback batch-set-include-ext(bool);
    callback batch-set-case(int);
    callback batch-set-counter-start(string);
    callback batch-set-counter-step(string);
    callback batch-apply();
    callback batch-close();
    // Ayuda (F1):
    in property <bool> help-open;
    in property <[HelpRowVm]> help-shortcuts;
    callback help-close();
    // Modal para nombrar la plantilla al guardar la disposición actual.
    property <bool> layout-save-open: false;
    property <string> layout-save-name: "";

    // --- Íconos de acción de la toolbar (6B) ---
    // Los setea Rust desde el IconCache al arrancar y al cambiar de set de íconos.
    in property <image> ic-up;
    in property <image> ic-panel;
    in property <image> ic-swap;
    in property <image> ic-clone;
    in property <image> ic-tabs;
    in property <image> ic-settings;
    // Tira de unidades de disco de la toolbar (6-fix): label = letra, icon = ícono de disco,
    // path = raíz. Clic navega el panel activo. Rust la rellena al arrancar y al cambiar de USB.
    in property <[NavRow]> drives;
    callback nav-drive(string);

    // --- Ventana de configuración (Fase 4) ---
    in-out property <bool> config-open: false;
    in property <SettingsVm> settings-vm;
    in property <[ShortcutRowVm]> shortcut-rows;
    in property <string> config-dir;
    in property <string> app-version;
    callback cfg-set-ops-mode(int);
    callback cfg-set-confirm-trash(bool);
    callback cfg-set-show-op-summary(bool);
    callback cfg-set-show-parent(bool);
    callback cfg-set-icon-only(bool);
    callback cfg-set-bar-position(int);
    callback cfg-set-size-no-subdirs(bool);
    callback cfg-set-autostart(bool);
    callback cfg-set-paste-confirm(bool);
    callback cfg-set-paste-text-name(string);
    callback cfg-set-paste-text-ext(string);
    callback cfg-set-language(string);
    callback cfg-set-theme(string);
    callback cfg-set-icon-set(string);
    callback cfg-set-date-format(int);
    callback cfg-set-size-format(int);
    callback cfg-set-row-density(int);
    callback cfg-shortcut-capture(string);
    callback cfg-capture-key(string, bool, bool, bool);
    callback cfg-shortcut-reset(string);
    callback cfg-shortcuts-reset-all();
    callback cfg-export-language();
    callback cfg-export-theme();
    callback cfg-export-config();
    callback cfg-import-pack();
    callback cfg-set-ops-display(int);
    callback cfg-set-paste-image-fmt(int);
    callback cfg-set-low-power-mode(int);
    callback cfg-set-new-items-at-end(bool);
    callback cfg-set-tray-enabled(bool);
    callback cfg-set-close-to-tray(bool);
    callback cfg-factory-reset();
    callback cfg-save-default-table();
    callback cfg-clear-default-table();
    in property <[PreviewRuleVm]> cfg-preview-rules;
    callback cfg-preview-toggle(string);
    callback cfg-preview-set-as(string, string);
    callback cfg-preview-remove(string);
    callback cfg-preview-add(string);
    callback cfg-open-repo();
    pure callback cfg-egg-prefix(int) -> string;
    // Emitido cuando cambia el tamaño del área de contenido (resize de ventana) para que
    // Rust reparta los paneles aun en reposo (con el timer apagado).
    callback content-resized();
    // Despertar el bucle de la UI desde un hilo worker (watcher de carpeta/dispositivos): el
    // waker lo invoca vía invoke_from_event_loop para re-arrancar el timer si estaba dormido.
    callback wake();

    // Alto de la barra superior (path-bar + botones). El área de contenido es el resto.
    property <length> top-bar-h: 34px;
    // Tooltip de la toolbar (texto + X del centro del botón). Lo publican los ToolBtn/DriveBtn
    // al pasar el mouse; se pinta como overlay al FINAL de la AppWindow (encima del contenido).
    property <string> hovered-tip: "";
    property <length> hovered-tip-x: 0;
    // Toast transitorio (aviso breve, p. ej. "Ruta copiada"). `show-toast(texto)` lo muestra y un
    // Timer lo apaga a los ~1.5s. Reusable para otras confirmaciones.
    property <string> toast-text: "";
    public function show-toast(msg: string) {
        root.toast-text = msg;
        toast-timer.running = false;
        toast-timer.running = true;
    }
    toast-timer := Timer {
        interval: 1500ms;
        running: false;
        triggered => { root.toast-text = ""; self.running = false; }
    }
    // Área de contenido que Rust usa para repartir los paneles (sin padding global aquí:
    // el contenido empieza en 0,0 dentro de `content`).
    out property <length> content-w: content.width;
    out property <length> content-h: content.height;
    // Avisa a Rust cuando cambia el tamaño del área de contenido (resize de ventana).
    changed content-w => { root.content-resized(); }
    changed content-h => { root.content-resized(); }

    VerticalLayout {
        padding: 0px;
        // Barra superior: path del panel activo + subir + agregar panel.
        Rectangle {
            height: root.top-bar-h;
            background: Theme.panel-bg;
            HorizontalLayout {
                padding: 4px;
                spacing: 6px;
                ToolBtn {
                    label: Tr.toolbar-up;
                    tip: Tr.toolbar-up-tip;
                    icon: root.ic-up;
                    icon-only: root.settings-vm.icon-only;
                    btn-width: root.settings-vm.icon-only ? 34px : 64px;
                    clicked => { root.go-up(); }
                    hover-tip(t, x) => { root.hovered-tip = t; root.hovered-tip-x = x; }
                }
                ToolBtn {
                    // El "+" se queda solo-texto: es un glifo, no una acción con ícono propio.
                    label: "+";
                    tip: Tr.toolbar-add-tip;
                    highlight: root.dir-menu-open;
                    clicked => { root.dir-menu-open = !root.dir-menu-open; }
                    hover-tip(t, x) => { root.hovered-tip = t; root.hovered-tip-x = x; }
                }
                ToolBtn {
                    label: Tr.toolbar-panel;
                    tip: Tr.toolbar-panel-tip;
                    icon: root.ic-panel;
                    icon-only: root.settings-vm.icon-only;
                    btn-width: root.settings-vm.icon-only ? 34px : 68px;
                    highlight: root.add-menu-open;
                    clicked => { root.add-menu-open = !root.add-menu-open; }
                    hover-tip(t, x) => { root.hovered-tip = t; root.hovered-tip-x = x; }
                }
                ToolBtn {
                    label: Tr.toolbar-swap;
                    tip: Tr.toolbar-swap-tip;
                    icon: root.ic-swap;
                    icon-only: root.settings-vm.icon-only;
                    btn-width: root.settings-vm.icon-only ? 34px : 68px;
                    clicked => { root.swap-panes(); }
                    hover-tip(t, x) => { root.hovered-tip = t; root.hovered-tip-x = x; }
                }
                ToolBtn {
                    label: Tr.toolbar-clone;
                    tip: Tr.toolbar-clone-tip;
                    icon: root.ic-clone;
                    icon-only: root.settings-vm.icon-only;
                    btn-width: root.settings-vm.icon-only ? 34px : 72px;
                    clicked => { root.clone-pane(); }
                    hover-tip(t, x) => { root.hovered-tip = t; root.hovered-tip-x = x; }
                }
                ToolBtn {
                    label: Tr.toolbar-tabs;
                    tip: Tr.toolbar-tabs-tip;
                    icon: root.ic-tabs;
                    icon-only: root.settings-vm.icon-only;
                    btn-width: root.settings-vm.icon-only ? 34px : 68px;
                    clicked => { root.stack-pane(); }
                    hover-tip(t, x) => { root.hovered-tip = t; root.hovered-tip-x = x; }
                }
                ToolBtn {
                    label: Tr.cfg-title;
                    tip: Tr.cfg-title;
                    icon: root.ic-settings;
                    icon-only: root.settings-vm.icon-only;
                    btn-width: root.settings-vm.icon-only ? 34px : 94px;
                    clicked => { root.config-open = true; }
                    hover-tip(t, x) => { root.hovered-tip = t; root.hovered-tip-x = x; }
                }
                // Menú de plantillas de disposición (F4).
                ToolBtn {
                    label: Tr.toolbar-layouts;
                    tip: Tr.toolbar-layouts-tip;
                    icon: root.ic-tabs;
                    icon-only: root.settings-vm.icon-only;
                    btn-width: root.settings-vm.icon-only ? 34px : 84px;
                    highlight: root.layout-menu-open;
                    clicked => { root.layout-menu-open = !root.layout-menu-open; }
                    hover-tip(t, x) => { root.hovered-tip = t; root.hovered-tip-x = x; }
                }
                // Separador antes de la tira de unidades.
                Rectangle { width: 1px; background: Theme.selection-bg; }
                // Tira de unidades de disco (paridad con egui): clic navega el panel activo.
                for d in root.drives: DriveBtn {
                    label: d.label;
                    tip: d.path;
                    icon: d.icon;
                    clicked => { root.nav-drive(d.path); }
                    hover-tip(t, x) => { root.hovered-tip = t; root.hovered-tip-x = x; }
                }
                Rectangle {
                    // Stretchy: ocupa el espacio sobrante de la toolbar. Sin esto, TODOS los
                    // hijos del HorizontalLayout tenían ancho finito, así que la fila (y por ende
                    // la ventana) heredaba un max-width finito y no se podía ensanchar la ventana.
                    horizontal-stretch: 1;
                    background: Theme.row-bg;
                    border-radius: 4px;
                    Text { text: root.active-path; color: Theme.text; vertical-alignment: center; x: 8px; }
                }
            }
        }
        // Zona de contenido: paneles posicionados absolutamente + barras de splitter.
        content := Rectangle {
            background: Theme.panel-bg;
            // Paneles (posición/tamaño calculados en Rust). El componente concreto se
            // elige por `p.purpose`: 0=Files 1=Tree 2=Inspector 3=History 4=Favorites
            // 5=Preview. Cada `if` instancia su componente en el mismo rect del panel.
            for p in root.panes: Rectangle {
                x: p.x;
                y: p.y;
                width: p.w;
                height: p.h;
                // Recortar el contenido al rect del panel: si no, en un panel chico el header
                // de columnas o la path-bar se desbordan y se mezclan con el panel vecino.
                clip: true;
                // Todo panel lleva una barra de título de 24px arriba: muestra su nombre y
                // sirve de ASA para arrastrarlo y reacomodar el layout. Si el panel es la
                // pestaña activa de un grupo, en su lugar va la barra de pestañas.
                property <length> bar-h: 24px;
                if p.tabs.length > 0: TabBar {
                    x: 0;
                    y: 0;
                    width: 100%;
                    height: parent.bar-h;
                    tabs: p.tabs;
                    select(id) => { root.tab-select(id); }
                    close(id) => { root.tab-close(id); }
                }
                if p.tabs.length == 0: title-bar := Rectangle {
                    x: 0;
                    y: 0;
                    width: 100%;
                    height: parent.bar-h;
                    background: p.active ? Theme.row-bg : Theme.row-bg;
                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 6px;
                        spacing: 6px;
                        Text {
                            text: p.title;
                            color: p.active ? white : Theme.text-dim;
                            font-weight: 600;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }
                        Text {
                            text: Tr.drag-move;
                            color: title-touch.pressed ? Theme.accent : Theme.text-dim;
                            font-size: 10px;
                            vertical-alignment: center;
                        }
                    }
                    title-touch := TouchArea {
                        mouse-cursor: move;
                        moved => {
                            root.pane-drag-move(p.id, p.x + self.mouse-x, p.y + self.mouse-y);
                        }
                        pointer-event(ev) => {
                            if (ev.kind == PointerEventKind.down) { root.activate(p.id); }
                            if (ev.button == PointerEventButton.left && ev.kind == PointerEventKind.up) {
                                root.pane-drag-drop(p.id, p.x + self.mouse-x, p.y + self.mouse-y);
                            }
                        }
                    }
                }
                // Contenido del panel, debajo de la barra (título o pestañas).
                pane-content := Rectangle {
                    x: 0;
                    y: parent.bar-h;
                    width: 100%;
                    height: parent.height - parent.bar-h;
                    if p.purpose == 0: FilePanel {
                        width: 100%;
                        height: 100%;
                        pane-id: p.id;
                        active: p.active;
                        rows: p.rows;
                        columns: p.columns;
                        col-menu: p.col-menu;
                        row-h: root.settings-vm.row-h;
                        segments: p.segments;
                        editing: root.edit-pane == p.id;
                        edit-text: root.edit-pane == p.id ? root.edit-text : "";
                        suggestions: root.edit-pane == p.id ? root.edit-suggestions : [];
                        is-favorite: p.is-favorite;
                        no-matches: p.no-matches;
                        fav-toggle(id) => { root.fav-toggle(id); }
                        copy-path(id) => { root.copy-path(id); root.show-toast(Tr.pathbar-copied); }
                        hover-tip(t, x) => { root.hovered-tip = t; root.hovered-tip-x = x; }
                        rename-pos: root.rename-pane == p.id ? root.rename-pos : -1;
                        rename-text: root.rename-pane == p.id ? root.rename-text : "";
                        rename-commit(pos, name) => { root.rename-commit(p.id, pos, name); }
                        rename-chain(pos, name, dir) => { root.rename-chain(p.id, pos, name, dir); }
                        rename-cancel() => { root.rename-cancel(); }
                        segment-clicked(id, path) => { root.path-segment-clicked(id, path); }
                        path-edit-start(id) => { root.path-edit-start(id); }
                        path-edit-changed(id, t) => { root.path-edit-changed(id, t); }
                        path-edit-commit(id, t) => { root.path-edit-commit(id, t); }
                        path-edit-cancel(id) => { root.path-edit-cancel(id); }
                        suggestion-clicked(id, name) => { root.path-suggestion-clicked(id, name); }
                        row-clicked(id, pos) => { root.row-clicked(id, pos); }
                        row-double-clicked(id, pos) => { root.row-double-clicked(id, pos); }
                        row-drag-out(id) => { root.row-drag-out(id); }
                        rubber-band(id, from, to) => { root.rubber-band(id, from, to); }
                        row-context(id, pos, cx, cy) => { root.row-context(id, pos, cx, cy); }
                        sort-by(id, col) => { root.sort-by(id, col); }
                        sort-by-kind(id, kind) => { root.sort-by-kind(id, kind); }
                        column-toggle(id, kind) => { root.column-toggle(id, kind); }
                        column-move(id, from, to) => { root.column-move(id, from, to); }
                        column-resize(id, kind, w) => { root.column-resize(id, kind, w); }
                        column-context(id, kind, cx, cy) => { root.column-context(id, kind, cx, cy); }
                        activate(id) => { root.activate(id); }
                        key(t, c, s, a) => { root.key(t, c, s, a); }
                    }
                    if p.purpose == 1: TreePanel {
                        width: 100%;
                        height: 100%;
                        active: p.active;
                        rows: p.tree-rows;
                        row-h: root.settings-vm.row-h;
                        toggle(path) => { root.tree-toggle(p.id, path); }
                        navigate(path) => { root.tree-navigate(path); }
                        tree-key(k) => { root.tree-key(p.id, k); }
                        focus-pane() => { root.activate(p.id); }
                    }
                    if p.purpose == 2: InspectorPanel {
                        width: 100%;
                        height: 100%;
                        active: p.active;
                        info: p.inspector;
                    }
                    if p.purpose == 3: HistoryPanel {
                        width: 100%;
                        height: 100%;
                        active: p.active;
                        rows: p.hist-rows;
                        undo(id) => { root.undo-entry(id); }
                        focus-pane() => { root.activate(p.id); }
                    }
                    if p.purpose == 4: FavoritesPanel {
                        width: 100%;
                        height: 100%;
                        active: p.active;
                        favs: p.favs;
                        recents: p.recents;
                        navigate(path) => { root.nav-navigate(path); }
                        remove(path) => { root.fav-remove(path); }
                        pin-current() => { root.fav-pin-current(); }
                        focus-pane() => { root.activate(p.id); }
                    }
                    if p.purpose == 5: PreviewPanel {
                        width: 100%;
                        height: 100%;
                        active: p.active;
                        view: p.preview;
                    }
                }
            }
            // Barras de splitter arrastrables. La barra VISIBLE es fina (4px), pero la zona de
            // agarre (TouchArea) se ENSANCHA ~5px a cada lado para que sea fácil de tomar con el
            // mouse (4px era casi imposible de pinchar). La barra visible va centrada en la zona.
            for s in root.splits: Rectangle {
                // Zona de agarre: el rect del handle expandido en el eje transversal.
                x: s.horizontal ? s.x - 5px : s.x;
                y: s.horizontal ? s.y : s.y - 5px;
                width: s.horizontal ? s.w + 10px : s.w;
                height: s.horizontal ? s.h : s.h + 10px;
                // Barra visible (fina), centrada en la zona de agarre.
                Rectangle {
                    x: s.horizontal ? (parent.width - s.w) / 2 : 0;
                    y: s.horizontal ? 0 : (parent.height - s.h) / 2;
                    width: s.w;
                    height: s.h;
                    background: sp-touch.has-hover || sp-touch.pressed ? Theme.accent : Theme.border;
                }
                sp-touch := TouchArea {
                    mouse-cursor: s.horizontal ? ew-resize : ns-resize;
                    // Posición ABSOLUTA del puntero en coords de contenido. `self.mouse-x` es
                    // relativo a la zona de agarre, cuyo origen es `s.x - 5px` (ver arriba).
                    // Mientras se arrastra: pedir la barra-fantasma (no reflowar). Al soltar:
                    // aplicar la fraction y limpiar la fantasma.
                    moved => {
                        root.split-drag(s.index, parent.x + self.mouse-x, parent.y + self.mouse-y);
                    }
                    pointer-event(ev) => {
                        if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left) {
                            root.split-commit(s.index, parent.x + self.mouse-x, parent.y + self.mouse-y);
                        }
                        if (ev.kind == PointerEventKind.cancel) {
                            root.split-commit(s.index, parent.x + self.mouse-x, parent.y + self.mouse-y);
                        }
                    }
                }
            }
            // Barra-fantasma del splitter en curso: un único Rectangle posicionado por escalares,
            // que repinta al instante (a diferencia del reflow completo del layout). Muestra
            // dónde quedará el borde al soltar. Visible solo durante el arrastre (w/h > 0).
            if root.splitpreview-w > 0 && root.splitpreview-h > 0: Rectangle {
                x: root.splitpreview-x;
                y: root.splitpreview-y;
                width: root.splitpreview-w;
                height: root.splitpreview-h;
                background: Theme.accent;
                border-radius: 2px;
                opacity: 0.7;
            }
            // Vista previa de la zona de drop durante un arrastre (resaltado translúcido).
            if root.drop-w > 0 && root.drop-h > 0: Rectangle {
                x: root.drop-x;
                y: root.drop-y;
                width: root.drop-w;
                height: root.drop-h;
                background: #4f8ae055;
                border-width: 2px;
                border-color: Theme.accent;
                border-radius: 4px;
                // Si la zona es el centro (apilar como pestaña), dibujar una "pestaña" arriba a
                // la izquierda con su etiqueta, para que se entienda que va a AGRUPAR en tabs
                // (no dividir). El borde discontinuo del relleno lo distingue de un split.
                if root.drop-is-tab: Rectangle {
                    x: 8px;
                    y: 6px;
                    width: tab-label.preferred-width + 18px;
                    height: 22px;
                    background: Theme.selection-bg;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: Theme.accent;
                    tab-label := Text {
                        text: "+ " + Tr.drop-as-tab;
                        color: white;
                        font-size: 12px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
        // Panel de progreso de operaciones (sobre la barra de estado; oculto si no hay ops).
        OpsPanel {
            rows: root.op-rows;
            cancel(idx) => { root.op-cancel(idx); }
        }
        // Barra de estado: carpeta activa + recuento de ítems y selección.
        Rectangle {
            height: 22px;
            background: Theme.panel-bg;
            Text {
                text: root.status;
                color: Theme.text-dim;
                font-size: 11px;
                vertical-alignment: center;
                x: 8px;
            }
        }
    }

    // Modales de operaciones (overlay sobre toda la ventana; visible solo si hay uno).
    OpDialogs {
        width: 100%;
        height: 100%;
        vm: root.op-dialog;
        resume-rows: root.resume-rows;
        resume-decide(id, a) => { root.resume-decide(id, a); }
        delete-confirm() => { root.delete-confirm(); }
        delete-cancel() => { root.delete-cancel(); }
        conflict-decide(a, all) => { root.conflict-decide(a, all); }
        name-changed(v) => { root.name-changed(v); }
        name-confirm() => { root.name-confirm(); }
        name-cancel() => { root.name-cancel(); }
        paste-confirm() => { root.paste-confirm(); }
        paste-cancel() => { root.paste-cancel(); }
    }

    // Tooltip de la toolbar: overlay al nivel de la AppWindow (se pinta DESPUÉS del contenido,
    // así no queda tapado por los paneles). Aparece justo bajo la barra, centrado en el botón.
    if root.hovered-tip != "": Rectangle {
        x: min(max(root.hovered-tip-x - self.width / 2, 4px), root.width - self.width - 4px);
        y: root.top-bar-h + 2px;
        width: htip.preferred-width + 14px;
        height: 22px;
        background: Theme.panel-bg;
        border-color: Theme.selection-bg;
        border-width: 1px;
        border-radius: 4px;
        htip := Text {
            text: root.hovered-tip;
            color: Theme.text;
            font-size: 11px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // Toast transitorio (aviso breve, p. ej. "Ruta copiada"): centrado abajo, sobre la barra de
    // estado. Aparece al copiar y se apaga solo (toast-timer).
    if root.toast-text != "": Rectangle {
        x: (root.width - self.width) / 2;
        y: root.height - 56px;
        width: toast-label.preferred-width + 24px;
        height: 28px;
        background: Theme.accent;
        border-radius: 6px;
        opacity: 0.95;
        toast-label := Text {
            text: root.toast-text;
            color: white;
            font-size: 12px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // Menú contextual (clic derecho): acciones propias + nativo de Windows.
    ContextMenu {
        width: 100%;
        height: 100%;
        vm: root.ctx-menu;
        open() => { root.ctx-open(); }
        open-with() => { root.ctx-open-with(); }
        copy() => { root.ctx-copy(); }
        cut() => { root.ctx-cut(); }
        paste() => { root.ctx-paste(); }
        rename() => { root.ctx-rename(); }
        delete() => { root.ctx-delete(); }
        copy-names() => { root.ctx-copy-names(); }
        copy-path() => { root.ctx-copy-path(); }
        terminal-ps() => { root.ctx-terminal-ps(); }
        terminal-cmd() => { root.ctx-terminal-cmd(); }
        terminal-wt() => { root.ctx-terminal-wt(); }
        native() => { root.ctx-native(); }
        dismiss() => { root.ctx-dismiss(); }
    }

    // Menú/editor de columna (clic derecho en el encabezado, F2).
    ColumnMenu {
        width: 100%;
        height: 100%;
        vm: root.column-menu;
        sort-asc() => { root.colmenu-sort-asc(); }
        sort-desc() => { root.colmenu-sort-desc(); }
        open-filter() => { root.colmenu-open-filter(); }
        clear-filter() => { root.colmenu-clear-filter(); }
        hide-column() => { root.colmenu-hide(); }
        move-left() => { root.colmenu-move-left(); }
        move-right() => { root.colmenu-move-right(); }
        set-text(t) => { root.colfilter-set-text(t); }
        toggle-case() => { root.colfilter-toggle-case(); }
        set-min(t) => { root.colfilter-set-min(t); }
        set-max(t) => { root.colfilter-set-max(t); }
        toggle-ext(e) => { root.colfilter-toggle-ext(e); }
        apply() => { root.colfilter-apply(); }
        dismiss() => { root.colmenu-dismiss(); }
    }

    // Ventana de configuración (overlay modal). Visible solo si config-open.
    if root.config-open: ConfigWindow {
        width: 100%;
        height: 100%;
        vm: root.settings-vm;
        shortcuts: root.shortcut-rows;
        config-dir: root.config-dir;
        app-version: root.app-version;
        set-ops-mode(m) => { root.cfg-set-ops-mode(m); }
        set-confirm-trash(v) => { root.cfg-set-confirm-trash(v); }
        set-show-op-summary(v) => { root.cfg-set-show-op-summary(v); }
        set-show-parent(v) => { root.cfg-set-show-parent(v); }
        set-icon-only(v) => { root.cfg-set-icon-only(v); }
        set-bar-position(p) => { root.cfg-set-bar-position(p); }
        set-size-no-subdirs(v) => { root.cfg-set-size-no-subdirs(v); }
        set-autostart(v) => { root.cfg-set-autostart(v); }
        set-paste-confirm(v) => { root.cfg-set-paste-confirm(v); }
        set-paste-text-name(n) => { root.cfg-set-paste-text-name(n); }
        set-paste-text-ext(e) => { root.cfg-set-paste-text-ext(e); }
        set-language(l) => { root.cfg-set-language(l); }
        set-theme(t) => { root.cfg-set-theme(t); }
        set-icon-set(s) => { root.cfg-set-icon-set(s); }
        set-date-format(i) => { root.cfg-set-date-format(i); }
        set-size-format(i) => { root.cfg-set-size-format(i); }
        set-row-density(i) => { root.cfg-set-row-density(i); }
        shortcut-capture(k) => { root.cfg-shortcut-capture(k); }
        capture-key(txt, c, s, a) => { root.cfg-capture-key(txt, c, s, a); }
        shortcut-reset(k) => { root.cfg-shortcut-reset(k); }
        shortcuts-reset-all() => { root.cfg-shortcuts-reset-all(); }
        export-language() => { root.cfg-export-language(); }
        export-theme() => { root.cfg-export-theme(); }
        export-config() => { root.cfg-export-config(); }
        import-pack() => { root.cfg-import-pack(); }
        set-ops-display(i) => { root.cfg-set-ops-display(i); }
        set-paste-image-fmt(i) => { root.cfg-set-paste-image-fmt(i); }
        set-low-power-mode(i) => { root.cfg-set-low-power-mode(i); }
        set-new-items-at-end(v) => { root.cfg-set-new-items-at-end(v); }
        set-tray-enabled(v) => { root.cfg-set-tray-enabled(v); }
        set-close-to-tray(v) => { root.cfg-set-close-to-tray(v); }
        factory-reset() => { root.cfg-factory-reset(); }
        save-default-table() => { root.cfg-save-default-table(); }
        clear-default-table() => { root.cfg-clear-default-table(); }
        preview-rules: root.cfg-preview-rules;
        preview-toggle(e) => { root.cfg-preview-toggle(e); }
        preview-set-as(e, a) => { root.cfg-preview-set-as(e, a); }
        preview-remove(e) => { root.cfg-preview-remove(e); }
        preview-add(e) => { root.cfg-preview-add(e); }
        open-repo() => { root.cfg-open-repo(); }
        egg-prefix(n) => { root.cfg-egg-prefix(n) }
        close() => { root.config-open = false; }
    }

    // Ventana de renombrado por lotes (F5). Visible solo si batch.active.
    BatchRename {
        width: 100%;
        height: 100%;
        vm: root.batch;
        set-template(t) => { root.batch-set-template(t); }
        set-find(t) => { root.batch-set-find(t); }
        set-replace(t) => { root.batch-set-replace(t); }
        set-regex(v) => { root.batch-set-regex(v); }
        set-include-ext(v) => { root.batch-set-include-ext(v); }
        set-case(i) => { root.batch-set-case(i); }
        set-counter-start(t) => { root.batch-set-counter-start(t); }
        set-counter-step(t) => { root.batch-set-counter-step(t); }
        apply() => { root.batch-apply(); }
        close() => { root.batch-close(); }
    }

    // Ayuda en pantalla (F1).
    Help {
        width: 100%;
        height: 100%;
        active: root.help-open;
        shortcuts: root.help-shortcuts;
        close() => { root.help-close(); }
    }

    // Desplegable ▾: agregar un panel del tipo elegido (divide el leaf activo). Flota
    // sobre todo. Un velo invisible cierra el menú al hacer clic fuera.
    if root.add-menu-open: TouchArea {
        clicked => { root.add-menu-open = false; }
    }
    if root.add-menu-open: Rectangle {
        x: 70px;
        y: root.top-bar-h + 2px;
        width: 160px;
        height: menu-items.preferred-height + 8px;
        background: Theme.row-bg;
        border-color: Theme.selection-bg;
        border-width: 1px;
        border-radius: 6px;
        menu-items := VerticalLayout {
            padding: 4px;
            spacing: 1px;
            MenuItem { label: Tr.add-files; clicked => { root.add-pane-of(0); root.add-menu-open = false; } }
            MenuItem { label: Tr.add-tree; clicked => { root.add-pane-of(1); root.add-menu-open = false; } }
            MenuItem { label: Tr.add-inspector; clicked => { root.add-pane-of(2); root.add-menu-open = false; } }
            MenuItem { label: Tr.add-history; clicked => { root.add-pane-of(3); root.add-menu-open = false; } }
            MenuItem { label: Tr.add-favorites; clicked => { root.add-pane-of(4); root.add-menu-open = false; } }
            MenuItem { label: Tr.add-preview; clicked => { root.add-pane-of(5); root.add-menu-open = false; } }
        }
    }

    // Menú de Layouts (F4): plantillas built-in + del usuario. Clic aplica; ✕ borra las de
    // usuario; al final, "Guardar disposición actual…" abre el modal de nombre.
    if root.layout-menu-open: TouchArea {
        clicked => { root.layout-menu-open = false; }
    }
    if root.layout-menu-open: Rectangle {
        x: root.width - self.width - 90px;
        y: root.top-bar-h + 2px;
        width: 230px;
        height: layout-items.preferred-height + 8px;
        background: Theme.row-bg;
        border-color: Theme.selection-bg;
        border-width: 1px;
        border-radius: 6px;
        layout-items := VerticalLayout {
            padding: 4px;
            spacing: 1px;
            for row in root.layout-rows: Rectangle {
                height: 28px;
                background: lay-touch.has-hover ? Theme.selection-bg : transparent;
                border-radius: 3px;
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 4px;
                    spacing: 4px;
                    Text {
                        text: (row.builtin ? "▦ " : "★ ") + row.name;
                        color: Theme.text;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }
                    // ✕ para borrar plantillas de usuario (no las built-in).
                    if !row.builtin: Rectangle {
                        width: 22px;
                        background: del-touch.has-hover ? Theme.error : transparent;
                        border-radius: 3px;
                        Text { text: "✕"; color: Theme.text-dim; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                        del-touch := TouchArea {
                            clicked => { root.delete-layout(row.name); }
                        }
                    }
                }
                lay-touch := TouchArea {
                    clicked => { root.apply-layout(row.name); root.layout-menu-open = false; }
                }
            }
            Rectangle { height: 1px; background: Theme.border; }
            MenuItem {
                label: Tr.layout-save-current;
                clicked => {
                    root.layout-menu-open = false;
                    root.layout-save-name = "";
                    root.layout-save-open = true;
                }
            }
        }
    }

    // Modal para nombrar la plantilla al guardar la disposición actual.
    if root.layout-save-open: Rectangle {
        background: #000000aa;
        TouchArea { clicked => { root.layout-save-open = false; } }
        Rectangle {
            width: 360px;
            height: 130px;
            background: Theme.panel-bg;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.border;
            TouchArea {}
            VerticalLayout {
                padding: 16px;
                spacing: 10px;
                Text { text: Tr.layout-save-title; color: Theme.text; font-weight: 700; }
                name-edit := LineEdit {
                    placeholder-text: Tr.layout-save-placeholder;
                    text: root.layout-save-name;
                    init => { self.focus(); }
                    edited(t) => { root.layout-save-name = t; }
                    accepted(t) => {
                        root.save-layout(t);
                        root.layout-save-open = false;
                    }
                }
                HorizontalLayout {
                    alignment: end;
                    spacing: 8px;
                    Rectangle {
                        width: 90px; height: 28px;
                        background: cancel-t.has-hover ? Theme.row-alt-bg : Theme.row-bg;
                        border-radius: 4px;
                        Text { text: Tr.dlg-cancel; color: Theme.text; horizontal-alignment: center; vertical-alignment: center; }
                        cancel-t := TouchArea { clicked => { root.layout-save-open = false; } }
                    }
                    Rectangle {
                        width: 90px; height: 28px;
                        background: save-t.has-hover ? Theme.accent.darker(10%) : Theme.accent;
                        border-radius: 4px;
                        Text { text: Tr.dlg-accept; color: white; horizontal-alignment: center; vertical-alignment: center; }
                        save-t := TouchArea {
                            clicked => {
                                root.save-layout(name-edit.text);
                                root.layout-save-open = false;
                            }
                        }
                    }
                }
            }
        }
    }

    // Menú del botón "+": elegir la dirección de la división (derecha/abajo/izquierda/arriba).
    // Velo invisible cierra al hacer clic fuera.
    if root.dir-menu-open: TouchArea {
        clicked => { root.dir-menu-open = false; }
    }
    if root.dir-menu-open: Rectangle {
        x: 54px;
        y: root.top-bar-h + 2px;
        width: 170px;
        height: dir-items.preferred-height + 8px;
        background: Theme.row-bg;
        border-color: Theme.selection-bg;
        border-width: 1px;
        border-radius: 6px;
        dir-items := VerticalLayout {
            padding: 4px;
            spacing: 1px;
            MenuItem { label: Tr.split-right; clicked => { root.add-pane-dir(0); root.dir-menu-open = false; } }
            MenuItem { label: Tr.split-down; clicked => { root.add-pane-dir(1); root.dir-menu-open = false; } }
            MenuItem { label: Tr.split-left; clicked => { root.add-pane-dir(2); root.dir-menu-open = false; } }
            MenuItem { label: Tr.split-up; clicked => { root.add-pane-dir(3); root.dir-menu-open = false; } }
        }
    }

    // Selector de panel destino (overlay 1..9): oscurece cada candidato y pinta su número.
    // Clic sobre un candidato lo elige; clic fuera (velo) cancela. Los rects llegan en
    // coordenadas del área de contenido → se desplazan por la altura de la barra superior.
    if root.picks.length > 0: TouchArea {
        clicked => { root.pick-cancel(); }
    }
    for p in root.picks: Rectangle {
        x: p.x;
        y: root.top-bar-h + p.y;
        width: p.w;
        height: p.h;
        background: #000000cc;
        border-width: 2px;
        border-color: Theme.accent;
        border-radius: 4px;
        Text {
            text: p.number;
            color: white;
            font-size: 48px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        pick-touch := TouchArea {
            clicked => { root.pick-resolve(p.number); }
        }
    }
}
