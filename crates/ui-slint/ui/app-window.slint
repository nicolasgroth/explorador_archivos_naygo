import { Splash } from "splash.slint";
// Reexportar los globals para que Slint genere su binding accesible desde Rust
// (i18n_keys / theme_apply). Splash se reexporta para tener su componente en Rust.
export { Tr }
export { Theme }
export { Splash }
// La ventana de config es ahora una ventana nativa propia; se reexporta para que `include_modules!`
// genere su tipo en Rust (su wiring vive en main.rs contra esa instancia).
export { ConfigWindow }

// Barra de pestañas de un grupo: una pestaña por miembro; la activa resaltada; cada una
// con su × para cerrarla. Clic en una pestaña la activa.
component TabBar inherits Rectangle {
    in property <[TabVm]> tabs;
    callback select(int);
    callback close(int);
    height: 24px;
    background: Theme.panel-bg;
    HorizontalLayout {
        padding: 2px;
        spacing: 2px;
        for t in root.tabs: Rectangle {
            background: t.active ? Theme.selection-bg : (tab-touch.has-hover ? Theme.row-alt-bg : Theme.row-bg);
            border-radius: 4px;
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 4px;
                spacing: 4px;
                Text {
                    text: t.label;
                    color: t.active ? white : Theme.text-dim;
                    vertical-alignment: center;
                    overflow: elide;
                }
                Rectangle {
                    width: 16px;
                    background: x-touch.has-hover ? Theme.error : transparent;
                    border-radius: 3px;
                    Text { text: "x"; color: Theme.error; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                    x-touch := TouchArea { clicked => { root.close(t.id); } }
                }
            }
            tab-touch := TouchArea { clicked => { root.select(t.id); } }
        }
    }
}

// Botón de la barra de herramientas: etiqueta de texto (el renderizador por software no
// dibuja glifos Unicode raros, así que usamos texto legible) + tooltip al pasar el mouse.
component ToolBtn inherits Rectangle {
    in property <string> label;
    in property <string> tip;
    in property <length> btn-width: 34px;
    in property <bool> highlight: false;
    // Ícono del set activo para este botón. Vacío = solo texto. Lo rellena Rust (Task 7).
    // La imagen llega ya tintada desde IconCache, así que NO se aplica colorize aquí.
    in property <image> icon;
    // Si false, el botón se ve atenuado y no dispara `clicked` (Atrás/Adelante sin historial).
    in property <bool> enabled: true;
    // Si true, se oculta el texto y queda solo el ícono (Settings.icon_only).
    in property <bool> icon-only: false;
    callback clicked();
    width: root.btn-width;
    background: (touch.has-hover || root.highlight) ? Theme.selection-bg : Theme.row-bg;
    border-radius: 7px;
    // Contenido centrado por geometría (no por layout, que dejaba el ícono descentrado):
    // ícono + texto juntos, centrados en el botón. En icon-only solo va el ícono.
    content-row := HorizontalLayout {
        spacing: 5px;
        x: max(0px, (parent.width - self.preferred-width) / 2);
        y: max(0px, (parent.height - self.preferred-height) / 2);
        width: self.preferred-width;
        height: self.preferred-height;
        if root.icon.width > 0: Image {
            source: root.icon;
            width: 16px;
            height: 16px;
            image-rendering: smooth;
        }
        if (!root.icon-only || root.icon.width == 0): Text {
            text: root.label;
            color: white;
            font-size: 12px;
            vertical-alignment: center;
        }
    }
    // Publica el tooltip y su posición X (centro del botón) al pasar el mouse, para que la
    // AppWindow lo pinte ENCIMA del contenido (un tooltip anidado en la toolbar queda tapado
    // por los paneles, que se pintan después en el VerticalLayout).
    // (texto, x-centro, y-borde-inferior) en coords de ventana, para anclar el tooltip JUSTO
    // debajo del botón (no a una Y fija en la barra superior).
    callback hover-tip(string, length, length);
    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
        changed has-hover => {
            root.hover-tip(self.has-hover ? root.tip : "",
                root.absolute-position.x + root.width / 2,
                root.absolute-position.y + root.height);
        }
    }
}

// Separador vertical entre grupos de la toolbar: una línea fina centrada con aire a los lados,
// para agrupar visualmente (navegación / paneles / acciones / unidades) sin recargar.
component ToolSep inherits Rectangle {
    width: 9px;
    Rectangle {
        width: 1px;
        height: 20px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: Theme.border;
    }
}

// Botón compacto de unidad de disco para la tira de la toolbar: ícono + letra (p. ej. "C:").
// Clic navega el panel activo a la raíz. Tooltip con la ruta. Si la unidad es extraíble
// (USB), a la derecha aparece un triángulo ▾ (estilo combobox) que abre un menú con
// "Expulsar"; el clic derecho sobre el botón abre ese mismo menú.
component DriveBtn inherits Rectangle {
    in property <string> label;
    in property <string> tip;
    in property <image> icon;
    in property <bool> removable: false;
    in property <string> eject-tip;
    callback clicked();
    // El ▾ (o el clic derecho) pide abrir el menú de expulsión; pasa la x de anclaje (centro
    // del ▾, en coords de ventana) para que la AppWindow posicione el menú flotante.
    callback eject-menu(length);
    width: drive-row.preferred-width + 10px;
    background: dtouch.has-hover ? Theme.selection-bg : Theme.row-bg;
    border-radius: 4px;
    drive-row := HorizontalLayout {
        alignment: center;
        spacing: 3px;
        padding-left: 5px;
        padding-right: 5px;
        // Unidad FIJA/red: ícono de disco del set. Unidad EXTRAÍBLE (USB): ícono propio dibujado
        // con Path (un pendrive), para distinguir a simple vista cuáles se pueden expulsar.
        if !root.removable: Image {
            source: root.icon;
            width: 15px;
            height: 15px;
            vertical-alignment: center;
            image-rendering: smooth;
        }
        if root.removable: Rectangle {
            width: 15px;
            height: 15px;
            // Pendrive: cuerpo + conector. Dibujado con Path (el render por software no pinta
            // glifos de fuente para íconos).
            Path {
                width: 15px;
                height: 15px;
                stroke: Theme.accent;
                stroke-width: 1.3px;
                fill: transparent;
                viewbox-width: 15;
                viewbox-height: 15;
                // Cuerpo del pendrive (rectángulo vertical redondeado, parte de abajo).
                MoveTo { x: 5; y: 5.5; }
                LineTo { x: 10; y: 5.5; }
                LineTo { x: 10; y: 13.5; }
                LineTo { x: 5; y: 13.5; }
                Close { }
                // Conector metálico (arriba).
                MoveTo { x: 6.5; y: 5.5; }
                LineTo { x: 6.5; y: 2; }
                LineTo { x: 8.5; y: 2; }
                LineTo { x: 8.5; y: 5.5; }
            }
        }
        Text {
            text: root.label;
            color: white;
            font-size: 12px;
            vertical-alignment: center;
        }
        // Triángulo ▾ (estilo combobox): solo en unidades extraíbles. Abre un menú
        // ("Expulsar") en vez de expulsar directo. Su TouchArea atrapa el clic antes
        // que el de navegación del botón. Emite la x de anclaje para el menú flotante.
        if root.removable: chevron := Rectangle {
            width: 14px;
            height: 16px;
            border-radius: 3px;
            background: etouch.has-hover ? Theme.accent : transparent;
            Path {
                width: 8px;
                height: 8px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                stroke: etouch.has-hover ? white : Theme.text-dim;
                stroke-width: 1.3px;
                fill: transparent;
                viewbox-width: 8;
                viewbox-height: 8;
                // Chevron hacia abajo.
                MoveTo { x: 1.5; y: 3; }
                LineTo { x: 4; y: 5.5; }
                LineTo { x: 6.5; y: 3; }
            }
            etouch := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    root.eject-menu(chevron.absolute-position.x + chevron.width / 2);
                }
                changed has-hover => {
                    root.hover-tip(self.has-hover ? root.eject-tip : "",
                        root.absolute-position.x + root.width / 2,
                        root.absolute-position.y + root.height);
                }
            }
        }
    }
    callback hover-tip(string, length, length);
    dtouch := TouchArea {
        // Clic-izquierdo navega; clic-derecho abre el menú de expulsión si es extraíble.
        pointer-event(ev) => {
            if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.right
                    && root.removable) {
                root.eject-menu(root.absolute-position.x + root.width / 2);
            }
        }
        clicked => { root.clicked(); }
        changed has-hover => {
            root.hover-tip(self.has-hover ? root.tip : "",
                root.absolute-position.x + root.width / 2,
                root.absolute-position.y + root.height);
        }
    }
}

// Un ítem del menú desplegable ▾.
component MenuItem inherits Rectangle {
    in property <string> label;
    callback clicked();
    height: 26px;
    background: mi-touch.has-hover ? Theme.selection-bg : transparent;
    border-radius: 4px;
    Text {
        text: root.label;
        color: Theme.text;
        vertical-alignment: center;
        x: 8px;
    }
    mi-touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

// Ítem de menú con CASILLA (check) a la izquierda + etiqueta. Para el menú del "ojo"
// (visibilidad): clic alterna el flag. La casilla se dibuja con Path (marco + tilde) porque el
// render por software no pinta glifos. `checked` lo controla la AppWindow (props in-out).
component CheckMenuItem inherits Rectangle {
    in property <string> label;
    in property <bool> checked;
    callback clicked();
    height: 26px;
    background: cmi-touch.has-hover ? Theme.selection-bg : transparent;
    border-radius: 4px;
    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 8px;
        // Casilla: marco siempre; tilde solo si está marcada.
        Rectangle {
            width: 16px;
            height: 16px;
            y: (parent.height - self.height) / 2;
            border-width: 1.2px;
            border-color: root.checked ? Theme.selection-bg : Theme.text-dim;
            border-radius: 3px;
            background: root.checked ? Theme.selection-bg : transparent;
            if root.checked: Path {
                width: 12px;
                height: 12px;
                x: 2px;
                y: 2px;
                stroke: white;
                stroke-width: 1.6px;
                fill: transparent;
                viewbox-width: 12;
                viewbox-height: 12;
                MoveTo { x: 2.5; y: 6.5; }
                LineTo { x: 5; y: 9; }
                LineTo { x: 9.5; y: 3.5; }
            }
        }
        Text {
            text: root.label;
            color: Theme.text;
            font-size: 13px;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }
    cmi-touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

// Ítem de dos líneas para los menús ▾ de historial de Atrás/Adelante: nombre de la carpeta arriba
// (normal) y ruta completa abajo (atenuada, fuente menor). Clic ↦ saltar a esa carpeta.
component HistoryMenuItem inherits Rectangle {
    in property <string> name;
    in property <string> path;
    callback clicked();
    height: 38px;
    background: hmi-touch.has-hover ? Theme.selection-bg : transparent;
    border-radius: 4px;
    VerticalLayout {
        padding-left: 8px;
        padding-right: 8px;
        padding-top: 4px;
        padding-bottom: 4px;
        spacing: 1px;
        Text {
            text: root.name;
            color: Theme.text;
            font-size: 13px;
            overflow: elide;
            vertical-alignment: center;
        }
        Text {
            text: root.path;
            color: Theme.text-dim;
            font-size: 11px;
            overflow: elide;
            vertical-alignment: center;
        }
    }
    hmi-touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

// Triángulo ▾ angosto junto a los botones Atrás/Adelante: abre el menú de historial en esa
// dirección. Se atenúa y no responde cuando no hay historial (mismo gesto visual que el botón).
// El ▾ se dibuja con Path (el render por software no pinta glifos de fuente). Publica `clicked`
// con la x absoluta de su centro para anclar el menú flotante.
component HistoryCaret inherits Rectangle {
    in property <bool> enabled: true;
    in property <string> tip;
    callback clicked(length);
    callback hover-tip(string, length, length);
    property <color> tint: root.enabled ? white : Theme.text-dim;
    width: 14px;
    border-radius: 7px;
    background: (hc-touch.has-hover && root.enabled) ? Theme.selection-bg : Theme.row-bg;
    Path {
        width: 10px;
        height: 10px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        stroke: root.tint;
        stroke-width: 1.4px;
        fill: transparent;
        viewbox-width: 10;
        viewbox-height: 10;
        MoveTo { x: 2; y: 4; }
        LineTo { x: 5; y: 7; }
        LineTo { x: 8; y: 4; }
    }
    hc-touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(root.absolute-position.x + root.width / 2); }
        changed has-hover => {
            root.hover-tip(self.has-hover ? root.tip : "",
                root.absolute-position.x + root.width / 2,
                root.absolute-position.y + root.height);
        }
    }
}

export component AppWindow inherits Window {
    title: "Naygo";
    preferred-width: 1000px;
    preferred-height: 640px;
    // Tope de tamaño explícito y amplio: sin esto, el max-width que Slint computa del árbol de
    // layout (toolbar + paneles) terminaba acotando el ancho de la ventana y Windows no dejaba
    // ensancharla más allá de ~600px. Forzar un max grande deja crecer libremente.
    max-width: 6000px;
    max-height: 4000px;

    in property <string> active-path;
    in property <[PaneVm]> panes;
    in property <[SplitVm]> splits;
    callback go-up();
    // Navegación tipo navegador: atrás/adelante en el historial del panel activo + ir al inicio.
    callback go-back();
    callback go-forward();
    callback go-home();
    // Estado de los botones Atrás/Adelante (Rust los actualiza tras cada navegación).
    in property <bool> can-go-back: false;
    in property <bool> can-go-forward: false;
    // Menús ▾ de historial de los botones Atrás/Adelante: cada ▾ abre la lista de carpetas en SU
    // dirección y permite saltar a una. Rust arma `history-items` según el menú que se abra y luego
    // setea las x/open de ese menú. Los índices del menú van de la carpeta más cercana a la lejana.
    callback open-back-history(length);    // x de anclaje del ▾ de Atrás
    callback open-forward-history(length); // x de anclaje del ▾ de Adelante
    callback go-back-history(int);         // saltar a la entrada N del menú de Atrás
    callback go-forward-history(int);      // saltar a la entrada N del menú de Adelante
    in property <[HistoryItemVm]> history-items;
    in-out property <length> back-history-menu-x: 0;
    in-out property <bool> back-history-menu-open: false;
    in-out property <length> fwd-history-menu-x: 0;
    in-out property <bool> fwd-history-menu-open: false;
    // --- Menú del "ojo" (visibilidad de archivos) ---
    // Flags de visibilidad (espejo de Settings; los alimenta main.rs al iniciar y al alternar).
    in-out property <bool> show-hidden: true;
    in-out property <bool> show-system: true;
    in-out property <bool> hide-dotfiles: false;
    in-out property <length> view-menu-x: 0;
    in-out property <bool> view-menu-open: false;
    callback open-view-menu(length);     // x de anclaje del menú del ojo
    callback toggle-show-hidden();       // alternar mostrar ocultos → Rust persiste + re-arma
    callback toggle-show-system();       // alternar mostrar de sistema
    callback toggle-hide-dotfiles();     // alternar esconder dotfiles
    callback add-pane();
    callback add-pane-dir(int);       // divide el panel activo en una dirección: 0=derecha
                                      // 1=abajo 2=izquierda 3=arriba (menú del botón "+")
    callback add-pane-of(int);        // agrega un panel del purpose dado (menú ▾)
    callback row-clicked(int, int);
    callback row-double-clicked(int, int);
    callback toggle-deep(int);            // (pane-id) alterna la vista profunda del panel
    callback row-drag-out(int);           // inicia el arrastre OLE de los archivos seleccionados
    callback rubber-band(int, int, int);  // (pane, from, to) selección por rectángulo (6F)
    // --- Barra de ruta (breadcrumbs + edición + autocompletado) ---
    // El panel que está editando su ruta (-1 = ninguno), su texto y sus candidatos. Rust los
    // controla; el FilePanel correspondiente muestra el editor.
    in-out property <int> edit-pane: -1;
    in property <string> edit-text;
    in property <[string]> edit-suggestions;
    // --- Rename inline (6D): la fila `rename-pos` del panel `rename-pane` muestra un editor. ---
    in-out property <int> rename-pane: -1;
    in-out property <int> rename-pos: -1;
    in property <string> rename-text;          // texto inicial del editor (lo fija Rust)
    callback rename-commit(int, int, string);  // (pane, pos, nombre) Enter → renombrar y cerrar
    callback rename-chain(int, int, string, int); // (pane, pos, nombre, dir) ↑/↓ → encadenar
    callback rename-cancel();                   // Esc → cerrar sin renombrar
    callback path-segment-clicked(int, string);
    callback path-edit-start(int);
    callback path-edit-changed(int, string);
    callback path-edit-commit(int, string);
    callback path-edit-cancel(int);
    callback path-suggestion-clicked(int, string);
    callback fav-toggle(int);             // (pane-id) ★ anclar/quitar favorito de la carpeta
    callback copy-path(int);              // (pane-id) 📋 copiar la ruta al portapapeles
    callback sort-by(int, string);
    callback sort-by-kind(int, int);      // (pane-id, kind) ordenar por columna dinámica
    callback column-toggle(int, int);     // (pane-id, kind) mostrar/ocultar columna
    callback column-move(int, int, int);  // (pane-id, from, to) reordenar columnas
    callback column-resize(int, int, length); // (pane-id, kind, ancho) redimensionar
    // Menú/editor de columna (clic derecho en el header, F2).
    callback column-context(int, int, length, length); // (pane-id, kind, x, y) abrir menú
    in property <ColumnMenuVm> column-menu;
    callback colmenu-sort-asc();
    callback colmenu-sort-desc();
    callback colmenu-open-filter();
    callback colmenu-clear-filter();
    callback colmenu-hide();
    callback colmenu-move-left();
    callback colmenu-move-right();
    callback colfilter-set-text(string);
    callback colfilter-toggle-case();
    callback colfilter-set-min(string);
    callback colfilter-set-max(string);
    callback colfilter-toggle-ext(string);
    callback colfilter-apply();
    callback colmenu-dismiss();
    callback activate(int);
    callback key(string, bool, bool, bool);
    // Soltado de tecla: modificadores vigentes tras el release, para resetear ctrl_down/shift_down.
    callback key-release(bool, bool, bool);  // (ctrl, shift, alt)
    // Botones laterales del mouse (atrás/adelante) sobre un panel: navegan su historial.
    callback nav-back(int);
    callback nav-forward(int);
    // Arrastre de splitter (resize de paneles). `split-drag` pide a Rust la posición ACOTADA
    // del borde para pintar la barra-fantasma EN VIVO (Rust setea splitpreview-*); `split-commit`
    // (al soltar) aplica la fraction de verdad. Se separa porque reflowar todo el layout en cada
    // `moved` no repinta bajo el render por software (solo tras un input) y se ve distorsionado;
    // la barra-fantasma (un único Rectangle por escalares) sí repinta al instante.
    callback split-drag(int, length, length);
    callback split-commit(int, length, length);
    // Barra-fantasma del splitter en curso (rect en coords de contenido; w/h 0 = oculta).
    in property <length> splitpreview-x;
    in property <length> splitpreview-y;
    in property <length> splitpreview-w;
    in property <length> splitpreview-h;
    // Paneles especiales:
    callback tree-toggle(int, string);   // (pane-id, ruta) expandir/colapsar rama
    callback tree-navigate(string);      // navegar el Files activo a esa carpeta
    callback tree-key(int, string);      // (pane-id, dir) navegación por teclado del árbol
    callback nav-navigate(string);       // favorito/reciente → navegar Files activo
    callback fav-remove(string);         // quitar favorito por ruta
    callback fav-pin-current();          // anclar la carpeta del Files activo
    // Árbol de favoritos editable (panel + menú ▾ del toolbar):
    in property <[FavTreeRow]> fav-tree;          // árbol de favoritos aplanado (menú ▾ del toolbar)
    in property <[PathSeg]> fav-group-options;    // grupos para "Mover a…" (label=ruta, path=group-id)
    // Destinos VÁLIDOS para "Mover a…" del nodo seleccionado: igual que fav-group-options pero ya
    // filtrado por Rust para excluir el propio grupo y sus descendientes. El panel pide recalcularlo
    // (fav-build-move-targets) justo al abrir el submenú con el nodo que se va a mover.
    in property <[PathSeg]> fav-move-targets;
    callback fav-build-move-targets(bool, string); // (is-group, src-group-id) → rellena fav-move-targets
    callback fav-toggle-expand(string);           // expandir/colapsar un grupo (ruta de nombres)
    callback fav-new-group(string, string);       // crear grupo: (parent-group-id, nombre)
    callback fav-rename-group(string, string);    // renombrar grupo: (group-id, nombre)
    callback fav-delete-node(bool, string, string);       // eliminar: (is-group, group-id, path)
    callback fav-move-node(bool, string, string, string); // mover: (is-group, src-gid, src-path, dest-gid)
    callback preview-open(string);       // abrir el archivo previsualizado con el programa por defecto
    callback undo-entry(int);            // deshacer la entrada del historial
    // Acciones multi-panel (toolbar):
    callback swap-panes();               // intercambiar el activo con el otro panel
    callback clone-pane();               // clonar la carpeta del activo en otro panel
    callback stack-pane();               // apilar el activo como pestaña sobre otro panel
    // Pestañas (grupos):
    callback tab-select(int);            // activar la pestaña (PaneId)
    callback tab-close(int);             // cerrar la pestaña (PaneId)
    // Reacomodo por arrastre (drag-to-rearrange):
    callback pane-drag-move(int, length, length); // (PaneId, x, y) en coords de contenido
    callback pane-drag-drop(int, length, length); // soltar: recompone el layout
    callback close-pane(int);                      // (PaneId) cerrar/quitar el panel
    // Vista previa de la zona de drop activa (rect en coords de contenido; w/h 0 = oculta).
    in property <length> drop-x;
    in property <length> drop-y;
    in property <length> drop-w;
    in property <length> drop-h;
    // La zona es el CENTRO (apilar como pestaña): la UI lo pinta como una pestaña, no como
    // un relleno de borde, para que se entienda que va a agrupar en tabs.
    in property <bool> drop-is-tab;
    // Selector numérico de panel destino (overlay 1..9):
    in property <[PickVm]> picks;        // candidatos con su rect + número (vacío = sin selector)
    callback pick-resolve(int);          // elige el panel número N (clic)
    callback pick-cancel();              // cancelar (clic fuera)
    // Texto de la barra de estado (carpeta activa + recuento de ítems/selección).
    in property <string> status;
    // Operaciones de archivo (Fase 3): modal activo + filas de progreso.
    in property <OpDialogVm> op-dialog;
    in property <MessageVm> message;
    callback message-confirm();
    callback message-cancel();
    // Filas del panel de operaciones, ya separadas por zona en Rust.
    in property <[OpRowVm]> op-running-rows;
    in property <[OpRowVm]> op-queued-rows;
    in property <[OpRowVm]> op-history-rows;
    in property <[OpRowVm]> op-planning-rows;
    // Recuentos por kind (calculados en Rust) para el resumen del panel rico de operaciones.
    in property <int> op-running-count;
    in property <int> op-queued-count;
    in property <int> op-history-count;
    in property <int> op-planning-count;
    callback op-cancel(int);
    callback op-pause(int);
    callback op-resume(int);
    callback op-skip(int);
    // Cancelar TODAS las operaciones en curso de un golpe (botón "Cancelar todo" del panel
    // Operaciones). Rust abre primero un modal de confirmación; este callback solo PIDE cancelar.
    callback op-cancel-all();
    // Un arrastre OLE (DoDragDrop) está corriendo su bucle modal: los paneles Files desmontan su
    // TouchArea exterior mientras es true para evitar la captura de puntero huérfana (ver
    // file-panel.slint `drag-in-progress`). Rust lo pone en true al lanzar el arrastre y en false al
    // terminar (drop procesado o cancelado).
    in property <bool> drag-in-progress: false;
    // Popup "Archivos de la operación": el enlace "Ver N archivos" de una fila del historial pide
    // a Rust la lista completa (op-show-files con el id de la op); Rust llena `op-file-list` +
    // `op-file-list-label` y abre el modal poniendo `op-file-list-open`.
    callback op-show-files(int);
    in property <[OpFileVm]> op-file-list;
    in property <string> op-file-list-label;
    // Encabezado enriquecido del popup (PUNTO 3): tipo + origen + destino + estadísticas.
    in property <OpFileContextVm> op-file-context;
    in-out property <bool> op-file-list-open;
    in property <[ResumeRowVm]> resume-rows;
    callback resume-decide(string, int);
    callback delete-confirm();
    callback delete-cancel();
    callback conflict-decide(int, bool);   // (action, apply-all)
    callback conflict-cancel();            // cancelar toda la operación desde el conflicto
    callback conflict-rename();            // "Renombrar" pidiendo el nombre nuevo (BUG 1)
    callback folder-conflict-decide(int, bool); // (decision, apply-all) conflicto de carpeta (P3)
    callback folder-conflict-cancel();          // cancelar toda la operación desde el conflicto de carpeta
    callback name-changed(string);
    callback name-confirm();
    callback name-cancel();
    callback paste-confirm();
    callback paste-cancel();
    // Menú contextual (clic derecho).
    callback row-context(int, int, length, length);  // (pane-id, pos, x, y)
    in property <ContextMenuVm> ctx-menu;
    callback ctx-open();
    callback ctx-open-with();
    callback ctx-copy();
    callback ctx-cut();
    callback ctx-paste();
    callback ctx-rename();
    callback ctx-delete();
    callback ctx-copy-names();
    callback ctx-copy-path();
    callback ctx-terminal-ps();
    callback ctx-terminal-cmd();
    callback ctx-terminal-wt();
    callback ctx-explorer();
    callback ctx-new-folder();
    callback ctx-native();
    callback ctx-dismiss();
    // Clic derecho en la zona vacía del panel → menú contextual de la carpeta (modo carpeta).
    callback empty-context(int, length, length);  // (pane-id, x, y)
    // Estado del menú ▾ (desplegable de "agregar panel"). x: centro del botón Panel que lo abre.
    property <bool> add-menu-open: false;
    property <length> add-menu-x: 0;
    // Estado del menú del botón "+" (elegir dirección de la división). x: centro del botón Dividir.
    property <bool> dir-menu-open: false;
    property <length> dir-menu-x: 0;
    // Menú ▾ de expulsión de un disco extraíble: raíz del disco (vacío = cerrado) + x de anclaje.
    // in-out para que Rust pueda cerrarlo (setearlo a "") al abrir el menú de historial.
    in-out property <string> drive-menu-path: "";
    property <length> drive-menu-x: 0;
    // Menú flotante del historial de carpetas recientes.
    callback history-open(length);       // abre el menú anclado en la x dada
    callback history-pick(string);       // (ruta) navegar a la carpeta elegida
    in property <[NavRow]> history-rows;
    in-out property <length> history-menu-x: 0;
    in-out property <bool> history-menu-open: false;
    // Menú flotante ▾ de favoritos (toolbar): muestra el árbol jerárquico, solo navega.
    in-out property <length> fav-menu-x: 0;
    in-out property <bool> fav-menu-open: false;
    // Posición REAL (x de centro, coords de ventana) de los botones de Favoritos y Layouts,
    // siempre al día. Cuando estos menús se abren por ATAJO de teclado (Rust no sabe dónde está el
    // botón), Rust lee estas props para anclar el menú al botón en vez de a un x proporcional.
    out property <length> fav-btn-x: fav-btn.absolute-position.x + fav-btn.width / 2;
    out property <length> layouts-btn-x: layouts-btn.absolute-position.x + layouts-btn.width / 2;
    // Paleta de comandos (Ctrl+P): overlay con búsqueda difusa de acciones/archivos/recientes/etc.
    in-out property <bool> palette-open: false;
    in-out property <string> palette-query: "";
    in property <[PaletteItemVm]> palette-results;
    in-out property <int> palette-selected: 0;
    callback palette-query-changed(string);  // se escribió en el campo: re-filtrar (Rust)
    callback palette-run(int);               // ejecutar el resultado de índice i (Rust)
    callback palette-dismiss();              // cerrar la paleta sin ejecutar (Esc / clic fuera)
    // Menú de Layouts (F4): plantillas de disposición. `layout-rows` lo llena Rust.
    // in-out para que el atajo de teclado (Ctrl+Shift+L) pueda abrirlo desde Rust.
    in-out property <bool> layout-menu-open: false;
    // x de centro del botón de Layouts, capturada al abrir para anclar el menú flotante
    // (mismo patrón que el menú de historial / discos). in-out: la fija el botón o el atajo.
    in-out property <length> layout-menu-x: 0;
    // Menú de terminales de la toolbar (PS/CMD/WSL/Win Terminal) en el panel activo. x: centro
    // del botón Terminal que lo abre.
    property <bool> term-menu-open: false;
    property <length> term-menu-x: 0;
    // ¿WSL / Windows Terminal disponibles? Rust lo setea para mostrar u ocultar esas entradas.
    in property <bool> has-wsl;
    in property <bool> has-wt;
    callback new-folder-toolbar();      // abrir el modal de nueva carpeta en el panel activo
    callback toolbar-terminal(int);     // 0=PS, 1=CMD, 2=Win Terminal, 3=WSL — en el panel activo
    in property <[LayoutRow]> layout-rows;
    callback apply-layout(string);      // aplicar la plantilla `name`
    callback delete-layout(string);     // borrar una plantilla de usuario `name`
    callback save-layout(string);       // guardar la disposición actual como plantilla `name`
    // Renombrado por lotes (F5):
    in property <BatchRenameVm> batch;
    callback batch-set-template(string);
    callback batch-set-find(string);
    callback batch-set-replace(string);
    callback batch-set-regex(bool);
    callback batch-set-include-ext(bool);
    callback batch-set-case(int);
    callback batch-set-counter-start(string);
    callback batch-set-counter-step(string);
    callback batch-apply();
    callback batch-close();
    // Modal "nueva(s) carpeta(s)":
    in property <NewFolderVm> new-folder-vm;
    callback new-folder-set-text(string);
    callback new-folder-create();
    callback new-folder-close();
    // "Carpeta no encontrada" IN-PLACE (aviso dentro del panel): cada acción trae el pane-id.
    callback missing-retry(int);
    callback missing-ancestor(int);
    callback missing-choose(int);
    callback missing-close-pane(int);
    // Búsqueda recursiva (Ctrl+F / lupa):
    in property <SearchVm> search-vm;
    callback search-run(string);   // lanzar búsqueda con el texto dado
    callback search-close();       // cerrar el panel (✕ / Esc / velo)
    callback search-cancel();      // detener el worker sin cerrar
    callback search-open(int);     // abrir la coincidencia de índice i
    callback search-toggle();      // abrir/cerrar desde la lupa de la toolbar
    // Ayuda (F1):
    in property <bool> help-open;
    in property <[HelpRowVm]> help-shortcuts;
    callback help-close();
    // Modal para nombrar la plantilla al guardar la disposición actual.
    property <bool> layout-save-open: false;
    property <string> layout-save-name: "";

    // (add-pane / layouts / terminal / refresh / eject vuelven a dibujarse con Path —modelo
    //  flat—, así que ya no hay propiedades de imagen para esos botones.)
    // Tira de unidades de disco de la toolbar (6-fix): label = letra, icon = ícono de disco,
    // path = raíz. Clic navega el panel activo. Rust la rellena al arrancar y al cambiar de USB.
    in property <[NavRow]> drives;
    callback nav-drive(string);
    // Expulsar de forma segura la unidad extraíble cuya raíz es el argumento (botón ⏏ o clic
    // derecho sobre una unidad USB). Rust desmonta+expulsa y muestra un toast del resultado.
    callback eject-drive(string);
    // Re-escanear las unidades manualmente (las de red no disparan WM_DEVICECHANGE, así que un
    // botón explícito las refresca). Rust reconstruye la tira de discos.
    callback refresh-drives();

    // --- Ventana de configuración (Fase 4) ---
    // La ventana de config es ahora una ventana nativa propia (ConfigWindow); su wiring vive en
    // Rust contra esa instancia. La AppWindow solo conserva `settings-vm` (la toolbar lo usa para
    // icon-only y el alto de fila) y emite `open-config` cuando se pulsa el engranaje.
    in property <SettingsVm> settings-vm;
    callback open-config();
    // Emitido cuando cambia el tamaño del área de contenido (resize de ventana) para que
    // Rust reparta los paneles aun en reposo (con el timer apagado).
    callback content-resized();
    // Despertar el bucle de la UI desde un hilo worker (watcher de carpeta/dispositivos): el
    // waker lo invoca vía invoke_from_event_loop para re-arrancar el timer si estaba dormido.
    callback wake();

    // Íconos del set activo para cada botón de la toolbar (los rellena Rust al iniciar y al
    // cambiar de set). Vacíos hasta que Task 7 los llene; la imagen vacía no se muestra.
    in property <image> tb-back;
    in property <image> tb-forward;
    in property <image> tb-up;
    in property <image> tb-refresh;
    in property <image> tb-home;
    in property <image> tb-search;
    in property <image> tb-show-hidden;
    in property <image> tb-history;
    in property <image> tb-favorites;
    in property <image> tb-split;
    in property <image> tb-panel;
    in property <image> tb-tabs;
    in property <image> tb-swap;
    in property <image> tb-clone;
    in property <image> tb-new-folder;
    in property <image> tb-terminal;
    in property <image> tb-layouts;
    in property <image> tb-settings;

    // Alto de la barra superior (path-bar + botones). El área de contenido es el resto.
    property <length> top-bar-h: 34px;
    // Tooltip de la toolbar (texto + X del centro del botón). Lo publican los ToolBtn/DriveBtn
    // al pasar el mouse; se pinta como overlay al FINAL de la AppWindow (encima del contenido).
    property <string> hovered-tip: "";
    property <length> hovered-tip-x: 0;
    // Y del borde inferior del elemento que disparó el tooltip (coords de ventana): el overlay se
    // dibuja justo debajo de ahí, de modo que el tooltip salga JUNTO al ícono y no en una Y fija.
    property <length> hovered-tip-y: 0;
    // Toast transitorio (aviso breve, p. ej. "Ruta copiada"). `show-toast(texto)` lo muestra y un
    // Timer lo apaga a los ~1.5s. Reusable para otras confirmaciones.
    property <string> toast-text: "";
    public function show-toast(msg: string) {
        root.toast-text = msg;
        toast-timer.running = false;
        toast-timer.running = true;
    }
    toast-timer := Timer {
        interval: 1500ms;
        running: false;
        triggered => { root.toast-text = ""; self.running = false; }
    }
    // Área de contenido que Rust usa para repartir los paneles (sin padding global aquí:
    // el contenido empieza en 0,0 dentro de `content`).
    out property <length> content-w: content.width;
    out property <length> content-h: content.height;
    // Avisa a Rust cuando cambia el tamaño del área de contenido (resize de ventana).
    changed content-w => { root.content-resized(); }
    changed content-h => { root.content-resized(); }

    VerticalLayout {
        padding: 0px;
        // Barra superior: path del panel activo + subir + agregar panel.
        Rectangle {
            height: root.top-bar-h;
            background: Theme.panel-bg;
            HorizontalLayout {
                padding: 4px;
                spacing: 6px;
                // --- Grupo NAVEGACIÓN ---
                // Atrás / Adelante / Inicio / Subir: navegación tipo navegador. Íconos dibujados
                // con Path (el render por software no pinta glifos de fuente). Atrás/Adelante se
                // atenúan y no responden cuando no hay historial en esa dirección.
                ToolBtn {
                    icon: root.tb-back;
                    icon-only: true;
                    enabled: root.can-go-back;
                    tip: Tr.nav-back-tip;
                    btn-width: 34px;
                    clicked => { root.go-back(); }
                    hover-tip(t, x, y) => { root.hovered-tip = t; root.hovered-tip-x = x; root.hovered-tip-y = y; }
                }
                // ▾ del historial hacia atrás (lista las carpetas anteriores del panel activo).
                HistoryCaret {
                    enabled: root.can-go-back;
                    tip: Tr.nav-back-history-tip;
                    clicked(x) => { root.open-back-history(x); }
                    hover-tip(t, x, y) => { root.hovered-tip = t; root.hovered-tip-x = x; root.hovered-tip-y = y; }
                }
                ToolBtn {
                    icon: root.tb-forward;
                    icon-only: true;
                    enabled: root.can-go-forward;
                    tip: Tr.nav-forward-tip;
                    btn-width: 34px;
                    clicked => { root.go-forward(); }
                    hover-tip(t, x, y) => { root.hovered-tip = t; root.hovered-tip-x = x; root.hovered-tip-y = y; }
                }
                // ▾ del historial hacia adelante (lista las carpetas posteriores del panel activo).
                HistoryCaret {
                    enabled: root.can-go-forward;
                    tip: Tr.nav-forward-history-tip;
                    clicked(x) => { root.open-forward-history(x); }
                    hover-tip(t, x, y) => { root.hovered-tip = t; root.hovered-tip-x = x; root.hovered-tip-y = y; }
                }
                ToolBtn {
                    icon: root.tb-home;
                    icon-only: true;
                    tip: Tr.nav-home-tip;
                    btn-width: 34px;
                    clicked => { root.go-home(); }
                    hover-tip(t, x, y) => { root.hovered-tip = t; root.hovered-tip-x = x; root.hovered-tip-y = y; }
                }
                // Subir un nivel (carpeta padre). Flecha hacia arriba dibujada con Path.
                ToolBtn {
                    label: Tr.toolbar-up;
                    tip: Tr.toolbar-up-tip;
                    icon: root.tb-up;
                    icon-only: root.settings-vm.icon-only;
                    btn-width: root.settings-vm.icon-only ? 34px : 64px;
                    clicked => { root.go-up(); }
                    hover-tip(t, x, y) => { root.hovered-tip = t; root.hovered-tip-x = x; root.hovered-tip-y = y; }
                }
                ToolSep { }
                // --- Grupo VISTA / BUSCAR ---
                // Herramientas para ver y encontrar: buscar, visibilidad de archivos, recientes,
                // favoritos. Todas operan sobre lo que se muestra; van juntas (Buscar ya no está
                // junto a Config).
                // Buscar en la carpeta y subcarpetas (Ctrl+F). La lupa abre/cierra el panel.
                ToolBtn {
                    icon: root.tb-search;
                    icon-only: true;
                    tip: Tr.search-tip;
                    btn-width: 34px;
                    clicked => { root.search-toggle(); }
                    hover-tip(t, x, y) => { root.hovered-tip = t; root.hovered-tip-x = x; root.hovered-tip-y = y; }
                }
                // Visibilidad: el ojo abre un menú flotante con 3 casillas (ocultos / sistema /
                // dotfiles). Se ancla al botón (su x de centro). Estilo combobox: resalta abierto.
                view-btn := ToolBtn {
                    icon: root.tb-show-hidden;
                    icon-only: true;
                    tip: Tr.view-hidden-tip;
                    btn-width: 34px;
                    highlight: root.view-menu-open;
                    clicked => {
                        root.open-view-menu(view-btn.absolute-position.x + view-btn.width / 2);
                    }
                    hover-tip(t, x, y) => { root.hovered-tip = t; root.hovered-tip-x = x; root.hovered-tip-y = y; }
                }
                // Historial de carpetas recientes: ícono de reloj abre menú flotante.
                history-btn := ToolBtn {
                    icon: root.tb-history;
                    icon-only: true;
                    tip: Tr.history;
                    btn-width: 34px;
                    highlight: root.history-menu-open;
                    clicked => {
                        root.history-open(history-btn.absolute-position.x + history-btn.width / 2);
                    }
                    hover-tip(t, x, y) => { root.hovered-tip = t; root.hovered-tip-x = x; root.hovered-tip-y = y; }
                }
                // Favoritos: estrella ▾ abre menú flotante con el ÁRBOL de favoritos (solo navega).
                fav-btn := ToolBtn {
                    icon: root.tb-favorites;
                    icon-only: true;
                    tip: Tr.fav-menu-tip;
                    btn-width: 40px;
                    highlight: root.fav-menu-open;
                    clicked => {
                        // Cerrar otros menús flotantes para no tener dos abiertos a la vez.
                        root.history-menu-open = false;
                        root.back-history-menu-open = false;
                        root.fwd-history-menu-open = false;
                        root.drive-menu-path = "";
                        root.view-menu-open = false;
                        root.fav-menu-x = fav-btn.absolute-position.x + fav-btn.width / 2;
                        root.fav-menu-open = !root.fav-menu-open;
                    }
                    hover-tip(t, x, y) => { root.hovered-tip = t; root.hovered-tip-x = x; root.hovered-tip-y = y; }
                }
                ToolSep { }
                // --- Grupo PANELES ---
                // Todo lo que manipula la disposición de paneles, junto: dividir, panel auxiliar,
                // intercambiar, clonar, apilar en pestañas, plantillas de disposición.
                split-btn := ToolBtn {
                    // Dividir el panel en dos: nuevo panel de archivos. Ícono "panel partido"
                    // dibujado con Path (antes era un "+" ambiguo que parecía "nuevo").
                    label: "";
                    icon: root.tb-split;
                    tip: Tr.toolbar-add-tip;
                    highlight: root.dir-menu-open;
                    btn-width: 34px;
                    clicked => {
                        // Anclar el menú al botón: capturar su x de centro antes de abrir.
                        root.dir-menu-x = split-btn.absolute-position.x + split-btn.width / 2;
                        root.dir-menu-open = !root.dir-menu-open;
                    }
                    hover-tip(t, x, y) => { root.hovered-tip = t; root.hovered-tip-x = x; root.hovered-tip-y = y; }
                }
                // Panel auxiliar (árbol / propiedades / etc.): ícono "panel con columna lateral".
                panel-btn := ToolBtn {
                    label: Tr.toolbar-panel;
                    tip: Tr.toolbar-panel-tip;
                    icon: root.tb-panel;
                    icon-only: root.settings-vm.icon-only;
                    btn-width: root.settings-vm.icon-only ? 34px : 68px;
                    highlight: root.add-menu-open;
                    clicked => {
                        root.add-menu-x = panel-btn.absolute-position.x + panel-btn.width / 2;
                        root.add-menu-open = !root.add-menu-open;
                    }
                    hover-tip(t, x, y) => { root.hovered-tip = t; root.hovered-tip-x = x; root.hovered-tip-y = y; }
                }
                // Intercambiar paneles: ícono de dos flechas opuestas (⇄) dibujado con Path.
                ToolBtn {
                    label: Tr.toolbar-swap;
                    tip: Tr.toolbar-swap-tip;
                    icon: root.tb-swap;
                    icon-only: root.settings-vm.icon-only;
                    btn-width: root.settings-vm.icon-only ? 34px : 68px;
                    clicked => { root.swap-panes(); }
                    hover-tip(t, x, y) => { root.hovered-tip = t; root.hovered-tip-x = x; root.hovered-tip-y = y; }
                }
                // Clonar el panel: ícono de dos rectángulos con offset (duplicar) dibujado con Path.
                ToolBtn {
                    label: Tr.toolbar-clone;
                    tip: Tr.toolbar-clone-tip;
                    icon: root.tb-clone;
                    icon-only: root.settings-vm.icon-only;
                    btn-width: root.settings-vm.icon-only ? 34px : 72px;
                    clicked => { root.clone-pane(); }
                    hover-tip(t, x, y) => { root.hovered-tip = t; root.hovered-tip-x = x; root.hovered-tip-y = y; }
                }
                // Apilar en pestañas: ícono de dos rectángulos escalonados (pestañas) con Path.
                ToolBtn {
                    label: Tr.toolbar-tabs;
                    tip: Tr.toolbar-tabs-tip;
                    icon: root.tb-tabs;
                    icon-only: root.settings-vm.icon-only;
                    btn-width: root.settings-vm.icon-only ? 34px : 68px;
                    clicked => { root.stack-pane(); }
                    hover-tip(t, x, y) => { root.hovered-tip = t; root.hovered-tip-x = x; root.hovered-tip-y = y; }
                }
                // Menú de plantillas de disposición (F4). Ícono propio (grilla 2x2) para no
                // confundirse con "Tabs".
                layouts-btn := ToolBtn {
                    label: Tr.toolbar-layouts;
                    tip: Tr.toolbar-layouts-tip;
                    icon: root.tb-layouts;
                    icon-only: root.settings-vm.icon-only;
                    btn-width: root.settings-vm.icon-only ? 34px : 84px;
                    highlight: root.layout-menu-open;
                    clicked => {
                        // Anclar el menú al botón: capturar su x de centro antes de abrir.
                        root.layout-menu-x = layouts-btn.absolute-position.x + layouts-btn.width / 2;
                        root.layout-menu-open = !root.layout-menu-open;
                    }
                    hover-tip(t, x, y) => { root.hovered-tip = t; root.hovered-tip-x = x; root.hovered-tip-y = y; }
                }
                ToolSep { }
                // --- Grupo ACCIONES ---
                // Nueva carpeta en el panel activo (abre el modal multilínea). Ícono "carpeta +"
                // dibujado con Path.
                ToolBtn {
                    label: Tr.toolbar-new-folder;
                    tip: Tr.toolbar-new-folder-tip;
                    icon: root.tb-new-folder;
                    icon-only: root.settings-vm.icon-only;
                    btn-width: root.settings-vm.icon-only ? 34px : 110px;
                    clicked => { root.new-folder-toolbar(); }
                    hover-tip(t, x, y) => { root.hovered-tip = t; root.hovered-tip-x = x; root.hovered-tip-y = y; }
                }
                // Terminales (PS/CMD/WSL/Win Terminal) en el panel activo: combo desplegable.
                // Ícono de terminal dibujado (no hay PNG de terminal en los sets).
                term-btn := ToolBtn {
                    label: Tr.toolbar-terminal;
                    tip: Tr.toolbar-terminal-tip;
                    icon: root.tb-terminal;
                    icon-only: root.settings-vm.icon-only;
                    btn-width: root.settings-vm.icon-only ? 34px : 94px;
                    highlight: root.term-menu-open;
                    clicked => {
                        root.term-menu-x = term-btn.absolute-position.x + term-btn.width / 2;
                        root.term-menu-open = !root.term-menu-open;
                    }
                    hover-tip(t, x, y) => { root.hovered-tip = t; root.hovered-tip-x = x; root.hovered-tip-y = y; }
                }
                ToolSep { }
                // --- Grupo SISTEMA ---
                // Configuración de la app. Ícono de engranaje dibujado con Path.
                ToolBtn {
                    label: Tr.cfg-title;
                    tip: Tr.toolbar-config-tip;
                    icon: root.tb-settings;
                    icon-only: root.settings-vm.icon-only;
                    btn-width: root.settings-vm.icon-only ? 34px : 94px;
                    clicked => { root.open-config(); }
                    hover-tip(t, x, y) => { root.hovered-tip = t; root.hovered-tip-x = x; root.hovered-tip-y = y; }
                }
                ToolSep { }
                // --- Grupo UNIDADES (tira de discos) ---
                // Refrescar unidades a mano (útil para unidades de red, que no avisan al SO).
                ToolBtn {
                    icon: root.tb-refresh;
                    icon-only: true;
                    tip: Tr.toolbar-refresh-drives;
                    btn-width: 30px;
                    clicked => { root.refresh-drives(); }
                    hover-tip(t, x, y) => { root.hovered-tip = t; root.hovered-tip-x = x; root.hovered-tip-y = y; }
                }
                // Tira de unidades de disco (paridad con egui): clic navega el panel activo.
                for d in root.drives: DriveBtn {
                    label: d.label;
                    tip: d.path;
                    icon: d.icon;
                    removable: d.removable;
                    eject-tip: Tr.drive-eject-tip;
                    clicked => { root.nav-drive(d.path); }
                    eject-menu(x) => {
                        // Abrir el menú flotante de expulsión anclado a este disco.
                        // Cerrar los demás menús para que nunca haya dos abiertos a la vez.
                        root.history-menu-open = false;
                        root.back-history-menu-open = false;
                        root.fwd-history-menu-open = false;
                        root.drive-menu-path = d.path;
                        root.drive-menu-x = x;
                    }
                    hover-tip(t, x, y) => { root.hovered-tip = t; root.hovered-tip-x = x; root.hovered-tip-y = y; }
                }
                Rectangle {
                    // Stretchy: ocupa el espacio sobrante de la toolbar. Sin esto, TODOS los
                    // hijos del HorizontalLayout tenían ancho finito, así que la fila (y por ende
                    // la ventana) heredaba un max-width finito y no se podía ensanchar la ventana.
                    horizontal-stretch: 1;
                    background: Theme.row-bg;
                    border-radius: 4px;
                    Text { text: root.active-path; color: Theme.text; vertical-alignment: center; x: 8px; }
                }
            }
        }
        // Zona de contenido: paneles posicionados absolutamente + barras de splitter.
        content := Rectangle {
            background: Theme.panel-bg;
            // Paneles (posición/tamaño calculados en Rust). El componente concreto se
            // elige por `p.purpose`: 0=Files 1=Tree 2=Inspector 3=History 4=Favorites
            // 5=Preview. Cada `if` instancia su componente en el mismo rect del panel.
            for p in root.panes: Rectangle {
                x: p.x;
                y: p.y;
                width: p.w;
                height: p.h;
                // Recortar el contenido al rect del panel: si no, en un panel chico el header
                // de columnas o la path-bar se desbordan y se mezclan con el panel vecino.
                clip: true;
                // Todo panel lleva una barra de título de 24px arriba: muestra su nombre y
                // sirve de ASA para arrastrarlo y reacomodar el layout. Si el panel es la
                // pestaña activa de un grupo, en su lugar va la barra de pestañas.
                property <length> bar-h: 24px;
                if p.tabs.length > 0: TabBar {
                    x: 0;
                    y: 0;
                    width: 100%;
                    height: parent.bar-h;
                    tabs: p.tabs;
                    select(id) => { root.tab-select(id); }
                    close(id) => { root.tab-close(id); }
                }
                if p.tabs.length == 0: title-bar := Rectangle {
                    x: 0;
                    y: 0;
                    width: 100%;
                    height: parent.bar-h;
                    // Título del panel activo con fondo de acento, para marcar el foco claramente.
                    // Si se está ARRASTRANDO un archivo sobre este panel (`drag-over`), el título se
                    // remarca con acento aunque el panel no sea el activo, para indicar dónde caerá
                    // el drop. drag-over manda sobre active (durante el arrastre es lo relevante).
                    background: (p.active || p.drag-over) ? Theme.accent : Theme.row-bg;
                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 6px;
                        spacing: 6px;
                        Text {
                            text: p.title;
                            color: (p.active || p.drag-over) ? white : Theme.text-dim;
                            font-weight: (p.active || p.drag-over) ? 800 : 600;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }
                        Text {
                            text: Tr.drag-move;
                            color: title-touch.pressed ? Theme.accent : Theme.text-dim;
                            font-size: 10px;
                            vertical-alignment: center;
                        }
                        // Hueco para que el texto no quede bajo la X de cerrar (que va encima).
                        Rectangle { width: 22px; }
                    }
                    title-touch := TouchArea {
                        mouse-cursor: move;
                        moved => {
                            root.pane-drag-move(p.id, p.x + self.mouse-x, p.y + self.mouse-y);
                        }
                        pointer-event(ev) => {
                            if (ev.kind == PointerEventKind.down) { root.activate(p.id); }
                            if (ev.button == PointerEventButton.left && ev.kind == PointerEventKind.up) {
                                root.pane-drag-drop(p.id, p.x + self.mouse-x, p.y + self.mouse-y);
                            }
                            // Clic derecho en el título: cerrar el panel (si no es el último).
                            if (ev.button == PointerEventButton.right && ev.kind == PointerEventKind.up) {
                                root.close-pane(p.id);
                            }
                        }
                    }
                    // Botón ✕ para cerrar el panel (arriba a la derecha de la barra de título).
                    // Va DESPUÉS de title-touch para recibir el clic. ✕ dibujada con Path.
                    if root.panes.length > 1: close-pane-btn := Rectangle {
                        width: 20px;
                        height: 20px;
                        x: parent.width - self.width - 4px;
                        y: (parent.height - self.height) / 2;
                        border-radius: 4px;
                        background: closex-touch.has-hover ? Theme.error : transparent;
                        Path {
                            width: 9px; height: 9px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            stroke: closex-touch.has-hover ? white : ((p.active || p.drag-over) ? white : Theme.text-dim);
                            stroke-width: 1.5px;
                            viewbox-width: 10; viewbox-height: 10;
                            MoveTo { x: 1; y: 1; }
                            LineTo { x: 9; y: 9; }
                            MoveTo { x: 9; y: 1; }
                            LineTo { x: 1; y: 9; }
                        }
                        closex-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.close-pane(p.id); }
                        }
                    }
                }
                // Contenido del panel, debajo de la barra (título o pestañas).
                pane-content := Rectangle {
                    x: 0;
                    y: parent.bar-h;
                    width: 100%;
                    height: parent.height - parent.bar-h;
                    if p.purpose == 0: FilePanel {
                        width: 100%;
                        height: 100%;
                        pane-id: p.id;
                        active: p.active;
                        drag-over: p.drag-over;
                        // Mientras haya un modal de operación (conflicto/eliminar/nombre/carpeta) o un
                        // aviso (USB/errores) abierto, el panel DESMONTA su TouchArea exterior para no
                        // robarle hover/clic al velo del modal (si no, el popup tiene el hover muerto
                        // hasta el primer clic y arrastrar resalta filas que no debería). > 0 = visible.
                        modal-open: root.op-dialog.kind > 0 || root.message.kind > 0;
                        // Mientras un arrastre OLE está en curso (DoDragDrop modal), el panel desmonta
                        // su TouchArea exterior para no quedar con la captura de puntero huérfana del
                        // bucle modal de Windows (fix de la "captura fantasma"). Rust lo togglea.
                        drag-in-progress: root.drag-in-progress;
                        rows: p.rows;
                        columns: p.columns;
                        col-menu: p.col-menu;
                        row-h: root.settings-vm.row-h;
                        segments: p.segments;
                        editing: root.edit-pane == p.id;
                        edit-text: root.edit-pane == p.id ? root.edit-text : "";
                        suggestions: root.edit-pane == p.id ? root.edit-suggestions : [];
                        is-favorite: p.is-favorite;
                        no-matches: p.no-matches;
                        missing: p.missing;
                        missing-path: p.missing-path;
                        missing-has-ancestor: p.missing-has-ancestor;
                        deep-active: p.deep-active;
                        footer-text: p.footer-text;
                        toggle-deep(id) => { root.toggle-deep(id); }
                        missing-retry(id) => { root.missing-retry(id); }
                        missing-ancestor(id) => { root.missing-ancestor(id); }
                        missing-choose(id) => { root.missing-choose(id); }
                        missing-close(id) => { root.missing-close-pane(id); }
                        fav-toggle(id) => { root.fav-toggle(id); }
                        copy-path(id) => { root.copy-path(id); root.show-toast(Tr.pathbar-copied); }
                        hover-tip(t, x, y) => { root.hovered-tip = t; root.hovered-tip-x = x; root.hovered-tip-y = y; }
                        rename-pos: root.rename-pane == p.id ? root.rename-pos : -1;
                        rename-text: root.rename-pane == p.id ? root.rename-text : "";
                        rename-commit(pos, name) => { root.rename-commit(p.id, pos, name); }
                        rename-chain(pos, name, dir) => { root.rename-chain(p.id, pos, name, dir); }
                        rename-cancel() => { root.rename-cancel(); }
                        segment-clicked(id, path) => { root.path-segment-clicked(id, path); }
                        path-edit-start(id) => { root.path-edit-start(id); }
                        path-edit-changed(id, t) => { root.path-edit-changed(id, t); }
                        path-edit-commit(id, t) => { root.path-edit-commit(id, t); }
                        path-edit-cancel(id) => { root.path-edit-cancel(id); }
                        suggestion-clicked(id, name) => { root.path-suggestion-clicked(id, name); }
                        row-clicked(id, pos) => { root.row-clicked(id, pos); }
                        row-double-clicked(id, pos) => { root.row-double-clicked(id, pos); }
                        row-drag-out(id) => { root.row-drag-out(id); }
                        rubber-band(id, from, to) => { root.rubber-band(id, from, to); }
                        row-context(id, pos, cx, cy) => { root.row-context(id, pos, cx, cy); }
                        empty-context(id, cx, cy) => { root.empty-context(id, cx, cy); }
                        sort-by(id, col) => { root.sort-by(id, col); }
                        sort-by-kind(id, kind) => { root.sort-by-kind(id, kind); }
                        column-toggle(id, kind) => { root.column-toggle(id, kind); }
                        column-move(id, from, to) => { root.column-move(id, from, to); }
                        column-resize(id, kind, w) => { root.column-resize(id, kind, w); }
                        column-context(id, kind, cx, cy) => { root.column-context(id, kind, cx, cy); }
                        activate(id) => { root.activate(id); }
                        key(t, c, s, a) => { root.key(t, c, s, a); }
                        key-release(c, s, a) => { root.key-release(c, s, a); }
                        nav-back(id) => { root.nav-back(id); }
                        nav-forward(id) => { root.nav-forward(id); }
                    }
                    if p.purpose == 1: TreePanel {
                        width: 100%;
                        height: 100%;
                        active: p.active;
                        rows: p.tree-rows;
                        row-h: root.settings-vm.row-h;
                        toggle(path) => { root.tree-toggle(p.id, path); }
                        navigate(path) => { root.tree-navigate(path); }
                        tree-key(k) => { root.tree-key(p.id, k); }
                        focus-pane() => { root.activate(p.id); }
                    }
                    if p.purpose == 2: InspectorPanel {
                        width: 100%;
                        height: 100%;
                        active: p.active;
                        info: p.inspector;
                        focus-pane() => { root.activate(p.id); }
                    }
                    if p.purpose == 3: HistoryPanel {
                        width: 100%;
                        height: 100%;
                        active: p.active;
                        rows: p.hist-rows;
                        undo(id) => { root.undo-entry(id); }
                        focus-pane() => { root.activate(p.id); }
                    }
                    if p.purpose == 4: FavoritesPanel {
                        width: 100%;
                        height: 100%;
                        active: p.active;
                        fav-tree: p.fav-tree;
                        recents: p.recents;
                        group-options: root.fav-group-options;
                        move-targets: root.fav-move-targets;
                        navigate(path) => { root.nav-navigate(path); }
                        toggle-expand(np) => { root.fav-toggle-expand(np); }
                        new-group(pid, name) => { root.fav-new-group(pid, name); }
                        rename-group(gid, name) => { root.fav-rename-group(gid, name); }
                        delete-node(g, gid, path) => { root.fav-delete-node(g, gid, path); }
                        request-move-targets(g, gid) => { root.fav-build-move-targets(g, gid); }
                        move-node(g, sgid, spath, dgid) => { root.fav-move-node(g, sgid, spath, dgid); }
                        pin-current() => { root.fav-pin-current(); }
                        focus-pane() => { root.activate(p.id); }
                    }
                    if p.purpose == 5: PreviewPanel {
                        width: 100%;
                        height: 100%;
                        active: p.active;
                        view: p.preview;
                        focus-pane() => { root.activate(p.id); }
                        open-in-system() => { root.preview-open(p.preview.path); }
                        hover-tip(t, x, y) => { root.hovered-tip = t; root.hovered-tip-x = x; root.hovered-tip-y = y; }
                    }
                    // Panel rico de operaciones montado como pane (Panel ▾ → Operaciones).
                    // Reusa el modelo de filas y los recuentos de nivel-ventana.
                    if p.purpose == 6: OpsPanel {
                        width: 100%;
                        height: 100%;
                        running-rows: root.op-running-rows;
                        queued-rows: root.op-queued-rows;
                        history-rows: root.op-history-rows;
                        planning-rows: root.op-planning-rows;
                        running-count: root.op-running-count;
                        queued-count: root.op-queued-count;
                        history-count: root.op-history-count;
                        planning-count: root.op-planning-count;
                        pause(i) => { root.op-pause(i); }
                        resume(i) => { root.op-resume(i); }
                        skip(i) => { root.op-skip(i); }
                        cancel(i) => { root.op-cancel(i); }
                        cancel-all() => { root.op-cancel-all(); }
                        show-files(i) => { root.op-show-files(i); }
                    }
                }
            }
            // Barras de splitter arrastrables. La barra VISIBLE es fina (4px), pero la zona de
            // agarre (TouchArea) se ENSANCHA ~5px a cada lado para que sea fácil de tomar con el
            // mouse (4px era casi imposible de pinchar). La barra visible va centrada en la zona.
            for s in root.splits: Rectangle {
                // Zona de agarre: el rect del handle expandido en el eje transversal.
                x: s.horizontal ? s.x - 5px : s.x;
                y: s.horizontal ? s.y : s.y - 5px;
                width: s.horizontal ? s.w + 10px : s.w;
                height: s.horizontal ? s.h : s.h + 10px;
                // Barra visible (fina), centrada en la zona de agarre.
                Rectangle {
                    x: s.horizontal ? (parent.width - s.w) / 2 : 0;
                    y: s.horizontal ? 0 : (parent.height - s.h) / 2;
                    width: s.w;
                    height: s.h;
                    background: sp-touch.has-hover || sp-touch.pressed ? Theme.accent : Theme.border;
                }
                sp-touch := TouchArea {
                    mouse-cursor: s.horizontal ? ew-resize : ns-resize;
                    // Posición ABSOLUTA del puntero en coords de contenido. `self.mouse-x` es
                    // relativo a la zona de agarre, cuyo origen es `s.x - 5px` (ver arriba).
                    // Mientras se arrastra: pedir la barra-fantasma (no reflowar). Al soltar:
                    // aplicar la fraction y limpiar la fantasma.
                    moved => {
                        root.split-drag(s.index, parent.x + self.mouse-x, parent.y + self.mouse-y);
                    }
                    pointer-event(ev) => {
                        if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left) {
                            root.split-commit(s.index, parent.x + self.mouse-x, parent.y + self.mouse-y);
                        }
                        if (ev.kind == PointerEventKind.cancel) {
                            root.split-commit(s.index, parent.x + self.mouse-x, parent.y + self.mouse-y);
                        }
                    }
                }
            }
            // Barra-fantasma del splitter en curso: un único Rectangle posicionado por escalares,
            // que repinta al instante (a diferencia del reflow completo del layout). Muestra
            // dónde quedará el borde al soltar. Visible solo durante el arrastre (w/h > 0).
            if root.splitpreview-w > 0 && root.splitpreview-h > 0: Rectangle {
                x: root.splitpreview-x;
                y: root.splitpreview-y;
                width: root.splitpreview-w;
                height: root.splitpreview-h;
                background: Theme.accent;
                border-radius: 2px;
                opacity: 0.7;
            }
            // Vista previa de la zona de drop durante un arrastre (resaltado translúcido).
            if root.drop-w > 0 && root.drop-h > 0: Rectangle {
                x: root.drop-x;
                y: root.drop-y;
                width: root.drop-w;
                height: root.drop-h;
                background: #4f8ae055;
                border-width: 2px;
                border-color: Theme.accent;
                border-radius: 4px;
                // Si la zona es el centro (apilar como pestaña), dibujar una "pestaña" arriba a
                // la izquierda con su etiqueta, para que se entienda que va a AGRUPAR en tabs
                // (no dividir). El borde discontinuo del relleno lo distingue de un split.
                if root.drop-is-tab: Rectangle {
                    x: 8px;
                    y: 6px;
                    width: tab-label.preferred-width + 18px;
                    height: 22px;
                    background: Theme.selection-bg;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: Theme.accent;
                    tab-label := Text {
                        text: "+ " + Tr.drop-as-tab;
                        color: white;
                        font-size: 12px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
        // (El antiguo overlay de progreso se reemplazó por el panel rico de Operaciones, que
        //  se monta como pane —Panel ▾ → Operaciones— y aparece solo al iniciar una operación.)
        // Barra de estado: carpeta activa + recuento de ítems y selección.
        Rectangle {
            height: 22px;
            background: Theme.panel-bg;
            Text {
                text: root.status;
                color: Theme.text-dim;
                font-size: 11px;
                vertical-alignment: center;
                x: 8px;
            }
        }
    }

    // NOTA: los modales de operaciones (OpDialogs) y el aviso (MessageModal) se montan como los
    // ÚLTIMOS hijos del componente raíz (al final del archivo), para que queden por DELANTE de
    // todos los demás overlays (menús, paleta, etc.) en el z-order de Slint. Ver el final.

    // Tooltip flotante: overlay al nivel de la AppWindow (se pinta DESPUÉS del contenido, así no
    // queda tapado por los paneles). Aparece JUNTO al elemento que lo disparó: centrado en su X y
    // justo bajo su borde inferior (hovered-tip-y). Si no cabe abajo (elemento cerca del borde
    // inferior, p. ej. la path-bar de un panel bajo), se voltea ARRIBA del elemento.
    if root.hovered-tip != "": Rectangle {
        property <length> tip-h: 22px;
        // Alto típico del elemento disparador (botón de toolbar / ícono de path-bar). Solo se usa
        // en el caso de volteo, para subir el tooltip por encima del elemento (hovered-tip-y es su
        // borde INFERIOR, así que restamos un alto aproximado para librar el elemento).
        property <length> src-h: 30px;
        // ¿El tooltip se saldría por abajo si lo dibujamos debajo del elemento? Entonces va arriba.
        property <bool> flip-up: root.hovered-tip-y + 2px + self.tip-h > root.height;
        x: min(max(root.hovered-tip-x - self.width / 2, 4px), max(4px, root.width - self.width - 4px));
        y: self.flip-up
            ? max(4px, root.hovered-tip-y - self.src-h - 2px - self.tip-h)
            : root.hovered-tip-y + 2px;
        width: htip.preferred-width + 14px;
        height: self.tip-h;
        background: Theme.panel-bg;
        border-color: Theme.selection-bg;
        border-width: 1px;
        border-radius: 4px;
        htip := Text {
            text: root.hovered-tip;
            color: Theme.text;
            font-size: 11px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // Toast transitorio (aviso breve, p. ej. "Ruta copiada"): centrado abajo, sobre la barra de
    // estado. Aparece al copiar y se apaga solo (toast-timer).
    if root.toast-text != "": Rectangle {
        x: (root.width - self.width) / 2;
        y: root.height - 56px;
        width: toast-label.preferred-width + 24px;
        height: 28px;
        background: Theme.accent;
        border-radius: 6px;
        opacity: 0.95;
        toast-label := Text {
            text: root.toast-text;
            color: white;
            font-size: 12px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // Menú contextual (clic derecho): acciones propias + nativo de Windows.
    ContextMenu {
        width: 100%;
        height: 100%;
        vm: root.ctx-menu;
        open() => { root.ctx-open(); }
        open-with() => { root.ctx-open-with(); }
        copy() => { root.ctx-copy(); }
        cut() => { root.ctx-cut(); }
        paste() => { root.ctx-paste(); }
        rename() => { root.ctx-rename(); }
        delete() => { root.ctx-delete(); }
        copy-names() => { root.ctx-copy-names(); }
        copy-path() => { root.ctx-copy-path(); }
        terminal-ps() => { root.ctx-terminal-ps(); }
        terminal-cmd() => { root.ctx-terminal-cmd(); }
        terminal-wt() => { root.ctx-terminal-wt(); }
        explorer() => { root.ctx-explorer(); }
        new-folder() => { root.ctx-new-folder(); }
        native() => { root.ctx-native(); }
        dismiss() => { root.ctx-dismiss(); }
    }

    // Menú/editor de columna (clic derecho en el encabezado, F2).
    ColumnMenu {
        width: 100%;
        height: 100%;
        vm: root.column-menu;
        sort-asc() => { root.colmenu-sort-asc(); }
        sort-desc() => { root.colmenu-sort-desc(); }
        open-filter() => { root.colmenu-open-filter(); }
        clear-filter() => { root.colmenu-clear-filter(); }
        hide-column() => { root.colmenu-hide(); }
        move-left() => { root.colmenu-move-left(); }
        move-right() => { root.colmenu-move-right(); }
        set-text(t) => { root.colfilter-set-text(t); }
        toggle-case() => { root.colfilter-toggle-case(); }
        set-min(t) => { root.colfilter-set-min(t); }
        set-max(t) => { root.colfilter-set-max(t); }
        toggle-ext(e) => { root.colfilter-toggle-ext(e); }
        apply() => { root.colfilter-apply(); }
        dismiss() => { root.colmenu-dismiss(); }
    }

    // La ventana de Configuración ya NO es un overlay: es una Window propia, instanciada y
    // manejada desde Rust (main.rs), independiente de esta ventana.

    // Ventana de renombrado por lotes (F5). Visible solo si batch.active.
    BatchRename {
        width: 100%;
        height: 100%;
        vm: root.batch;
        set-template(t) => { root.batch-set-template(t); }
        set-find(t) => { root.batch-set-find(t); }
        set-replace(t) => { root.batch-set-replace(t); }
        set-regex(v) => { root.batch-set-regex(v); }
        set-include-ext(v) => { root.batch-set-include-ext(v); }
        set-case(i) => { root.batch-set-case(i); }
        set-counter-start(t) => { root.batch-set-counter-start(t); }
        set-counter-step(t) => { root.batch-set-counter-step(t); }
        apply() => { root.batch-apply(); }
        close() => { root.batch-close(); }
    }

    // Modal "nueva(s) carpeta(s)".
    NewFolder {
        width: 100%;
        height: 100%;
        vm: root.new-folder-vm;
        set-text(t) => { root.new-folder-set-text(t); }
        create() => { root.new-folder-create(); }
        close() => { root.new-folder-close(); }
    }

    // (El aviso "carpeta no encontrada" ahora es IN-PLACE dentro de cada FilePanel; ya no hay
    //  modal global.)

    // Ayuda en pantalla (F1).
    Help {
        width: 100%;
        height: 100%;
        active: root.help-open;
        shortcuts: root.help-shortcuts;
        close() => { root.help-close(); }
    }

    // Panel de búsqueda recursiva (Ctrl+F / lupa).
    SearchPanel {
        width: 100%;
        height: 100%;
        vm: root.search-vm;
        run(t) => { root.search-run(t); }
        close() => { root.search-close(); }
        cancel() => { root.search-cancel(); }
        open(i) => { root.search-open(i); }
    }

    // Menú flotante ▾ de FAVORITOS (toolbar). Muestra el árbol jerárquico de favoritos: grupos
    // (negrita, clic expande/colapsa) y favoritos (clic navega el panel Files activo). Solo
    // navegación, sin edición (eso vive en el panel Favoritos). Velo cierra al clic afuera.
    if root.fav-menu-open: TouchArea {
        clicked => { root.fav-menu-open = false; }
    }
    if root.fav-menu-open: Rectangle {
        x: min(root.width - self.width - 4px, max(4px, root.fav-menu-x - self.width / 2));
        y: root.top-bar-h + 2px;
        width: 300px;
        height: min(420px, fav-menu-list.preferred-height + 8px);
        background: Theme.row-bg;
        border-color: Theme.selection-bg;
        border-width: 1px;
        border-radius: 6px;
        fav-menu-list := VerticalLayout {
            padding: 4px;
            spacing: 1px;
            if root.fav-tree.length == 0: Text {
                text: Tr.fav-empty;
                color: Theme.text-dim;
                font-size: 12px;
                x: 8px;
                height: 26px;
                vertical-alignment: center;
            }
            ListView {
                height: min(404px, root.fav-tree.length * 26px);
                for f[i] in root.fav-tree: Rectangle {
                    height: 26px;
                    background: fmrow-touch.has-hover ? Theme.selection-bg : transparent;
                    border-radius: 4px;
                    HorizontalLayout {
                        padding-left: 8px + f.depth * 14px;
                        spacing: 6px;
                        // Chevron ▸/▾ para grupos con hijos.
                        Rectangle {
                            width: 10px;
                            if f.is-group && f.has-children: Path {
                                width: 8px;
                                height: 8px;
                                y: (parent.height - self.height) / 2;
                                fill: Theme.text-dim;
                                viewbox-width: 8;
                                viewbox-height: 8;
                                commands: f.expanded
                                    ? "M 1 2.5 L 7 2.5 L 4 6.5 Z"
                                    : "M 2.5 1 L 6.5 4 L 2.5 7 Z";
                            }
                        }
                        Image {
                            source: f.icon;
                            width: 16px;
                            height: 16px;
                            vertical-alignment: center;
                            image-rendering: smooth;
                        }
                        Text {
                            text: f.name;
                            color: f.is-group ? Theme.text : Theme.highlight;
                            font-weight: f.is-group ? 700 : 400;
                            font-size: 13px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }
                    }
                    fmrow-touch := TouchArea {
                        clicked => {
                            if (f.is-group) {
                                root.fav-toggle-expand(f.name-path);
                            } else {
                                root.nav-navigate(f.path);
                                root.fav-menu-open = false;
                            }
                        }
                    }
                }
            }
        }
    }

    // Menú flotante del historial de carpetas recientes. Velo invisible cierra al clic afuera.
    if root.history-menu-open: TouchArea {
        clicked => { root.history-menu-open = false; }
    }
    if root.history-menu-open: Rectangle {
        // Anclado al botón de reloj (su x de centro), justo debajo de la barra de herramientas.
        x: min(root.width - self.width - 4px, max(4px, root.history-menu-x - self.width / 2));
        y: root.top-bar-h + 2px;
        width: 260px;
        height: history-menu-items.preferred-height + 8px;
        background: Theme.row-bg;
        border-color: Theme.selection-bg;
        border-width: 1px;
        border-radius: 6px;
        history-menu-items := VerticalLayout {
            padding: 4px;
            spacing: 1px;
            // Lista vacía: mostrar aviso.
            if root.history-rows.length == 0: Text {
                text: Tr.history-recent-empty;
                color: Theme.text-dim;
                font-size: 12px;
                x: 8px;
                height: 26px;
                vertical-alignment: center;
            }
            // Entradas de carpetas recientes.
            for r in root.history-rows: MenuItem {
                label: r.label;
                clicked => {
                    root.history-pick(r.path);
                    root.history-menu-open = false;
                }
            }
        }
    }

    // Menú ▾ del historial hacia ATRÁS del panel activo. Mismo patrón que el de recientes/USB:
    // velo invisible que cierra al clic afuera + Rectangle anclado al ▾. Cada ítem muestra el
    // nombre de la carpeta (normal) y su ruta completa (atenuada, fuente menor). Clic ↦ saltar.
    if root.back-history-menu-open: TouchArea {
        clicked => { root.back-history-menu-open = false; }
    }
    if root.back-history-menu-open: Rectangle {
        x: min(root.width - self.width - 4px, max(4px, root.back-history-menu-x - self.width / 2));
        y: root.top-bar-h + 2px;
        width: 300px;
        height: back-hist-items.preferred-height + 8px;
        background: Theme.row-bg;
        border-color: Theme.selection-bg;
        border-width: 1px;
        border-radius: 6px;
        back-hist-items := VerticalLayout {
            padding: 4px;
            spacing: 1px;
            for it[i] in root.history-items: HistoryMenuItem {
                name: it.name;
                path: it.path;
                clicked => {
                    root.go-back-history(i);
                    root.back-history-menu-open = false;
                }
            }
        }
    }

    // Menú ▾ del historial hacia ADELANTE del panel activo (espejo del de atrás).
    if root.fwd-history-menu-open: TouchArea {
        clicked => { root.fwd-history-menu-open = false; }
    }
    if root.fwd-history-menu-open: Rectangle {
        x: min(root.width - self.width - 4px, max(4px, root.fwd-history-menu-x - self.width / 2));
        y: root.top-bar-h + 2px;
        width: 300px;
        height: fwd-hist-items.preferred-height + 8px;
        background: Theme.row-bg;
        border-color: Theme.selection-bg;
        border-width: 1px;
        border-radius: 6px;
        fwd-hist-items := VerticalLayout {
            padding: 4px;
            spacing: 1px;
            for it[i] in root.history-items: HistoryMenuItem {
                name: it.name;
                path: it.path;
                clicked => {
                    root.go-forward-history(i);
                    root.fwd-history-menu-open = false;
                }
            }
        }
    }

    // Menú del "ojo" (visibilidad de archivos). Flota anclado al botón del ojo, justo debajo de
    // la barra. Un velo invisible lo cierra al clic afuera. Tres casillas (global, persistente):
    // mostrar ocultos / mostrar de sistema / esconder dotfiles. Clic en una fila alterna el flag
    // → callback a Rust (persiste y re-arma las vistas al instante).
    if root.view-menu-open: TouchArea {
        clicked => { root.view-menu-open = false; }
    }
    if root.view-menu-open: Rectangle {
        x: min(root.width - self.width - 4px, max(4px, root.view-menu-x - self.width / 2));
        y: root.top-bar-h + 2px;
        width: 320px;
        height: view-menu-items.preferred-height + 8px;
        background: Theme.row-bg;
        border-color: Theme.selection-bg;
        border-width: 1px;
        border-radius: 6px;
        view-menu-items := VerticalLayout {
            padding: 4px;
            spacing: 1px;
            CheckMenuItem {
                label: Tr.view-show-hidden;
                checked: root.show-hidden;
                clicked => { root.toggle-show-hidden(); }
            }
            CheckMenuItem {
                label: Tr.view-show-system;
                checked: root.show-system;
                clicked => { root.toggle-show-system(); }
            }
            CheckMenuItem {
                label: Tr.view-hide-dotfiles;
                checked: root.hide-dotfiles;
                clicked => { root.toggle-hide-dotfiles(); }
            }
        }
    }

    // Menú ▾ de expulsión de un disco extraíble (USB). Flota anclado al ▾ del disco. Un velo
    // invisible lo cierra al clic afuera. El ítem "Expulsar" desmonta la unidad con seguridad.
    if root.drive-menu-path != "": TouchArea {
        clicked => { root.drive-menu-path = ""; }
    }
    if root.drive-menu-path != "": Rectangle {
        // Anclado al ▾ (su x de centro), justo debajo de la barra de herramientas. Se mantiene
        // dentro de la ventana con un clamp simple en x.
        x: min(root.width - self.width - 4px, max(4px, root.drive-menu-x - self.width / 2));
        y: root.top-bar-h + 2px;
        width: 150px;
        height: eject-menu-items.preferred-height + 8px;
        background: Theme.row-bg;
        border-color: Theme.selection-bg;
        border-width: 1px;
        border-radius: 6px;
        eject-menu-items := VerticalLayout {
            padding: 4px;
            spacing: 1px;
            MenuItem {
                label: Tr.drive-eject;
                clicked => {
                    root.eject-drive(root.drive-menu-path);
                    root.drive-menu-path = "";
                }
            }
        }
    }

    // Desplegable ▾: agregar un panel del tipo elegido (divide el leaf activo). Flota
    // sobre todo. Un velo invisible cierra el menú al hacer clic fuera.
    if root.add-menu-open: TouchArea {
        clicked => { root.add-menu-open = false; }
    }
    if root.add-menu-open: Rectangle {
        // Anclado al botón Panel (su x de centro), con clamp para no salirse de la ventana.
        x: min(root.width - self.width - 4px, max(4px, root.add-menu-x - self.width / 2));
        y: root.top-bar-h + 2px;
        width: 160px;
        height: menu-items.preferred-height + 8px;
        background: Theme.row-bg;
        border-color: Theme.selection-bg;
        border-width: 1px;
        border-radius: 6px;
        menu-items := VerticalLayout {
            padding: 4px;
            spacing: 1px;
            MenuItem { label: Tr.add-files; clicked => { root.add-pane-of(0); root.add-menu-open = false; } }
            MenuItem { label: Tr.add-tree; clicked => { root.add-pane-of(1); root.add-menu-open = false; } }
            MenuItem { label: Tr.add-inspector; clicked => { root.add-pane-of(2); root.add-menu-open = false; } }
            MenuItem { label: Tr.add-history; clicked => { root.add-pane-of(3); root.add-menu-open = false; } }
            MenuItem { label: Tr.add-favorites; clicked => { root.add-pane-of(4); root.add-menu-open = false; } }
            MenuItem { label: Tr.add-preview; clicked => { root.add-pane-of(5); root.add-menu-open = false; } }
            MenuItem { label: Tr.add-operations; clicked => { root.add-pane-of(6); root.add-menu-open = false; } }
        }
    }

    // Menú de Layouts (F4): plantillas built-in + del usuario. Clic aplica; ✕ borra las de
    // usuario; al final, "Guardar disposición actual…" abre el modal de nombre.
    if root.layout-menu-open: TouchArea {
        clicked => { root.layout-menu-open = false; }
    }
    if root.layout-menu-open: Rectangle {
        // Anclado al botón de Layouts (su x de centro), justo debajo de la barra de
        // herramientas. Clamp en x para no salirse de la ventana.
        x: min(root.width - self.width - 4px, max(4px, root.layout-menu-x - self.width / 2));
        y: root.top-bar-h + 2px;
        width: 230px;
        height: layout-items.preferred-height + 8px;
        background: Theme.row-bg;
        border-color: Theme.selection-bg;
        border-width: 1px;
        border-radius: 6px;
        layout-items := VerticalLayout {
            padding: 4px;
            spacing: 1px;
            for row in root.layout-rows: Rectangle {
                height: 28px;
                background: lay-touch.has-hover ? Theme.selection-bg : transparent;
                border-radius: 3px;
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 4px;
                    spacing: 4px;
                    Text {
                        text: (row.builtin ? "▦ " : "★ ") + row.name;
                        color: Theme.text;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }
                    // ✕ para borrar plantillas de usuario (no las built-in).
                    if !row.builtin: Rectangle {
                        width: 22px;
                        background: del-touch.has-hover ? Theme.error : transparent;
                        border-radius: 3px;
                        Text { text: "✕"; color: Theme.text-dim; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                        del-touch := TouchArea {
                            clicked => { root.delete-layout(row.name); }
                        }
                    }
                }
                lay-touch := TouchArea {
                    clicked => { root.apply-layout(row.name); root.layout-menu-open = false; }
                }
            }
            Rectangle { height: 1px; background: Theme.border; }
            MenuItem {
                label: Tr.layout-save-current;
                clicked => {
                    root.layout-menu-open = false;
                    root.layout-save-name = "";
                    root.layout-save-open = true;
                }
            }
        }
    }

    // Modal para nombrar la plantilla al guardar la disposición actual.
    if root.layout-save-open: Rectangle {
        background: #000000aa;
        TouchArea { clicked => { root.layout-save-open = false; } }
        Rectangle {
            width: 360px;
            height: 130px;
            background: Theme.panel-bg;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.border;
            TouchArea {}
            VerticalLayout {
                padding: 16px;
                spacing: 10px;
                Text { text: Tr.layout-save-title; color: Theme.text; font-weight: 700; }
                name-edit := LineEdit {
                    placeholder-text: Tr.layout-save-placeholder;
                    text: root.layout-save-name;
                    init => { self.focus(); }
                    edited(t) => { root.layout-save-name = t; }
                    accepted(t) => {
                        root.save-layout(t);
                        root.layout-save-open = false;
                    }
                }
                HorizontalLayout {
                    alignment: end;
                    spacing: 8px;
                    Rectangle {
                        width: 90px; height: 28px;
                        background: cancel-t.has-hover ? Theme.row-alt-bg : Theme.row-bg;
                        border-radius: 4px;
                        Text { text: Tr.dlg-cancel; color: Theme.text; horizontal-alignment: center; vertical-alignment: center; }
                        cancel-t := TouchArea { clicked => { root.layout-save-open = false; } }
                    }
                    Rectangle {
                        width: 90px; height: 28px;
                        background: save-t.has-hover ? Theme.accent.darker(10%) : Theme.accent;
                        border-radius: 4px;
                        Text { text: Tr.dlg-accept; color: white; horizontal-alignment: center; vertical-alignment: center; }
                        save-t := TouchArea {
                            clicked => {
                                root.save-layout(name-edit.text);
                                root.layout-save-open = false;
                            }
                        }
                    }
                }
            }
        }
    }

    // Menú del botón "+": elegir la dirección de la división (derecha/abajo/izquierda/arriba).
    // Velo invisible cierra al hacer clic fuera.
    if root.dir-menu-open: TouchArea {
        clicked => { root.dir-menu-open = false; }
    }
    if root.dir-menu-open: Rectangle {
        // Anclado al botón Dividir (su x de centro), con clamp para no salirse de la ventana.
        x: min(root.width - self.width - 4px, max(4px, root.dir-menu-x - self.width / 2));
        y: root.top-bar-h + 2px;
        width: 170px;
        height: dir-items.preferred-height + 8px;
        background: Theme.row-bg;
        border-color: Theme.selection-bg;
        border-width: 1px;
        border-radius: 6px;
        dir-items := VerticalLayout {
            padding: 4px;
            spacing: 1px;
            MenuItem { label: Tr.split-right; clicked => { root.add-pane-dir(0); root.dir-menu-open = false; } }
            MenuItem { label: Tr.split-down; clicked => { root.add-pane-dir(1); root.dir-menu-open = false; } }
            MenuItem { label: Tr.split-left; clicked => { root.add-pane-dir(2); root.dir-menu-open = false; } }
            MenuItem { label: Tr.split-up; clicked => { root.add-pane-dir(3); root.dir-menu-open = false; } }
        }
    }

    // Menú de terminales de la toolbar (PS/CMD/WSL/Win Terminal) en el panel activo.
    if root.term-menu-open: TouchArea {
        clicked => { root.term-menu-open = false; }
    }
    if root.term-menu-open: Rectangle {
        // Anclado al botón Terminal (su x de centro), con clamp para no salirse de la ventana.
        x: min(root.width - self.width - 4px, max(4px, root.term-menu-x - self.width / 2));
        y: root.top-bar-h + 2px;
        width: 200px;
        height: term-items.preferred-height + 8px;
        background: Theme.row-bg;
        border-color: Theme.selection-bg;
        border-width: 1px;
        border-radius: 6px;
        term-items := VerticalLayout {
            padding: 4px;
            spacing: 1px;
            MenuItem { label: Tr.ctx-terminal-ps; clicked => { root.toolbar-terminal(0); root.term-menu-open = false; } }
            MenuItem { label: Tr.ctx-terminal-cmd; clicked => { root.toolbar-terminal(1); root.term-menu-open = false; } }
            if root.has-wt: MenuItem { label: Tr.ctx-terminal-wt; clicked => { root.toolbar-terminal(2); root.term-menu-open = false; } }
            if root.has-wsl: MenuItem { label: Tr.toolbar-terminal-wsl; clicked => { root.toolbar-terminal(3); root.term-menu-open = false; } }
        }
    }

    // Selector de panel destino (overlay 1..9): oscurece cada candidato y pinta su número.
    // Clic sobre un candidato lo elige; clic fuera (velo) cancela. Los rects llegan en
    // coordenadas del área de contenido → se desplazan por la altura de la barra superior.
    if root.picks.length > 0: TouchArea {
        clicked => { root.pick-cancel(); }
    }
    for p in root.picks: Rectangle {
        x: p.x;
        y: root.top-bar-h + p.y;
        width: p.w;
        height: p.h;
        background: #000000cc;
        border-width: 2px;
        border-color: Theme.accent;
        border-radius: 4px;
        Text {
            text: p.number;
            color: white;
            font-size: 48px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        pick-touch := TouchArea {
            clicked => { root.pick-resolve(p.number); }
        }
    }

    // Paleta de comandos (Ctrl+P): overlay por encima de todo. Solo se monta cuando está abierta
    // (su LineEdit toma el foco en `init`). Rust llena `palette-results` y consume los callbacks.
    if root.palette-open: CommandPalette {
        width: 100%;
        height: 100%;
        results: root.palette-results;
        query <=> root.palette-query;
        selected <=> root.palette-selected;
        query-changed(q) => { root.palette-query-changed(q); }
        run(i) => { root.palette-run(i); }
        dismiss => { root.palette-dismiss(); }
    }

    // Modales de operaciones (overlay sobre toda la ventana; visible solo si hay uno) y aviso
    // (USB/errores). Se montan COMO ÚLTIMOS HIJOS del raíz a propósito: en Slint el último hijo
    // queda al frente en el z-order, así estos modales tapan a TODOS los demás overlays (menús,
    // paleta, etc.). Cuando están abiertos, los paneles desmontan su `body-touch` (`modal-open`),
    // por lo que el velo recibe hover/clic de inmediato (sin clic de despertar).
    OpDialogs {
        width: 100%;
        height: 100%;
        vm: root.op-dialog;
        resume-rows: root.resume-rows;
        resume-decide(id, a) => { root.resume-decide(id, a); }
        delete-confirm() => { root.delete-confirm(); }
        delete-cancel() => { root.delete-cancel(); }
        conflict-decide(a, all) => { root.conflict-decide(a, all); }
        conflict-cancel() => { root.conflict-cancel(); }
        conflict-rename() => { root.conflict-rename(); }
        folder-conflict-decide(d, all) => { root.folder-conflict-decide(d, all); }
        folder-conflict-cancel() => { root.folder-conflict-cancel(); }
        name-changed(v) => { root.name-changed(v); }
        name-confirm() => { root.name-confirm(); }
        name-cancel() => { root.name-cancel(); }
        paste-confirm() => { root.paste-confirm(); }
        paste-cancel() => { root.paste-cancel(); }
    }

    MessageModal {
        vm: root.message;
        message-confirm() => { root.message-confirm(); }
        message-cancel() => { root.message-cancel(); }
    }

    // Popup con la lista completa de archivos de una op (lo abre "Ver N archivos" del historial).
    OpFileListModal {
        open: root.op-file-list-open;
        op-label: root.op-file-list-label;
        rows: root.op-file-list;
        context: root.op-file-context;
        close() => { root.op-file-list-open = false; }
    }
}
