// Naygo — ventana principal (Slint, Fase 2c: multi-panel + paneles especiales + acciones).
// Copyright (c) 2026 N. Groth / ISGroth. MIT.
import { RowData, PaneVm, SplitVm, PickVm, TabVm, OpDialogVm, OpRowVm, ResumeRowVm, ContextMenuVm } from "types.slint";
import { PathBar } from "path-bar.slint";
import { FilePanel } from "file-panel.slint";
import { TreePanel } from "tree-panel.slint";
import { InspectorPanel } from "inspector-panel.slint";
import { HistoryPanel } from "history-panel.slint";
import { FavoritesPanel } from "favorites-panel.slint";
import { PreviewPanel } from "preview-panel.slint";
import { OpDialogs } from "op-dialogs.slint";
import { OpsPanel } from "ops-panel.slint";
import { ContextMenu } from "context-menu.slint";
import { Tr } from "i18n.slint";
// Reexportar el global para que Slint genere su binding accesible desde Rust (i18n_keys).
export { Tr }

// Barra de pestañas de un grupo: una pestaña por miembro; la activa resaltada; cada una
// con su × para cerrarla. Clic en una pestaña la activa.
component TabBar inherits Rectangle {
    in property <[TabVm]> tabs;
    callback select(int);
    callback close(int);
    height: 24px;
    background: #0b1320;
    HorizontalLayout {
        padding: 2px;
        spacing: 2px;
        for t in root.tabs: Rectangle {
            background: t.active ? #2a4a7a : (tab-touch.has-hover ? #1f3350 : #16243a);
            border-radius: 4px;
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 4px;
                spacing: 4px;
                Text {
                    text: t.label;
                    color: t.active ? white : #9ab;
                    vertical-alignment: center;
                    overflow: elide;
                }
                Rectangle {
                    width: 16px;
                    background: x-touch.has-hover ? #5a2630 : transparent;
                    border-radius: 3px;
                    Text { text: "x"; color: #c99; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                    x-touch := TouchArea { clicked => { root.close(t.id); } }
                }
            }
            tab-touch := TouchArea { clicked => { root.select(t.id); } }
        }
    }
}

// Botón de la barra de herramientas: etiqueta de texto (el renderizador por software no
// dibuja glifos Unicode raros, así que usamos texto legible) + tooltip al pasar el mouse.
component ToolBtn inherits Rectangle {
    in property <string> label;
    in property <string> tip;
    in property <length> btn-width: 34px;
    in property <bool> highlight: false;
    callback clicked();
    width: root.btn-width;
    background: (touch.has-hover || root.highlight) ? #2a4a7a : #1b2838;
    border-radius: 4px;
    Text {
        text: root.label;
        color: white;
        font-size: 12px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    touch := TouchArea {
        clicked => { root.clicked(); }
    }
    // Tooltip flotante: aparece bajo el botón al pasar el mouse.
    if touch.has-hover && root.tip != "": Rectangle {
        x: 0;
        y: parent.height + 3px;
        width: tip-text.preferred-width + 12px;
        height: 22px;
        background: #0b1320;
        border-color: #2a4a7a;
        border-width: 1px;
        border-radius: 4px;
        tip-text := Text {
            text: root.tip;
            color: #dde;
            font-size: 11px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

// Un ítem del menú desplegable ▾.
component MenuItem inherits Rectangle {
    in property <string> label;
    callback clicked();
    height: 26px;
    background: mi-touch.has-hover ? #2a4a7a : transparent;
    border-radius: 4px;
    Text {
        text: root.label;
        color: #dde;
        vertical-alignment: center;
        x: 8px;
    }
    mi-touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component AppWindow inherits Window {
    title: "Naygo";
    preferred-width: 1000px;
    preferred-height: 640px;

    in property <string> active-path;
    in property <[PaneVm]> panes;
    in property <[SplitVm]> splits;
    callback go-up();
    callback add-pane();
    callback add-pane-of(int);        // agrega un panel del purpose dado (menú ▾)
    callback row-clicked(int, int);
    callback row-double-clicked(int, int);
    callback sort-by(int, string);
    callback activate(int);
    callback key(string, bool, bool, bool);
    callback split-drag(int, length, length);
    // Paneles especiales:
    callback tree-toggle(int, string);   // (pane-id, ruta) expandir/colapsar rama
    callback tree-navigate(string);      // navegar el Files activo a esa carpeta
    callback nav-navigate(string);       // favorito/reciente → navegar Files activo
    callback fav-remove(string);         // quitar favorito por ruta
    callback fav-pin-current();          // anclar la carpeta del Files activo
    callback undo-entry(int);            // deshacer la entrada del historial
    // Acciones multi-panel (toolbar):
    callback swap-panes();               // intercambiar el activo con el otro panel
    callback clone-pane();               // clonar la carpeta del activo en otro panel
    callback stack-pane();               // apilar el activo como pestaña sobre otro panel
    // Pestañas (grupos):
    callback tab-select(int);            // activar la pestaña (PaneId)
    callback tab-close(int);             // cerrar la pestaña (PaneId)
    // Reacomodo por arrastre (drag-to-rearrange):
    callback pane-drag-move(int, length, length); // (PaneId, x, y) en coords de contenido
    callback pane-drag-drop(int, length, length); // soltar: recompone el layout
    // Vista previa de la zona de drop activa (rect en coords de contenido; w/h 0 = oculta).
    in property <length> drop-x;
    in property <length> drop-y;
    in property <length> drop-w;
    in property <length> drop-h;
    // Selector numérico de panel destino (overlay 1..9):
    in property <[PickVm]> picks;        // candidatos con su rect + número (vacío = sin selector)
    callback pick-resolve(int);          // elegí el panel número N (clic)
    callback pick-cancel();              // cancelar (clic fuera)
    // Texto de la barra de estado (carpeta activa + recuento de ítems/selección).
    in property <string> status;
    // Operaciones de archivo (Fase 3): modal activo + filas de progreso.
    in property <OpDialogVm> op-dialog;
    in property <[OpRowVm]> op-rows;
    in property <[ResumeRowVm]> resume-rows;
    callback resume-decide(string, int);
    callback delete-confirm();
    callback delete-cancel();
    callback conflict-decide(int, bool);   // (action, apply-all)
    callback name-changed(string);
    callback name-confirm();
    callback name-cancel();
    callback paste-confirm();
    callback paste-cancel();
    callback op-cancel(int);
    // Menú contextual (clic derecho).
    callback row-context(int, int, length, length);  // (pane-id, pos, x, y)
    in property <ContextMenuVm> ctx-menu;
    callback ctx-open();
    callback ctx-open-with();
    callback ctx-copy();
    callback ctx-cut();
    callback ctx-paste();
    callback ctx-rename();
    callback ctx-delete();
    callback ctx-copy-path();
    callback ctx-native();
    callback ctx-dismiss();
    // Estado del menú ▾ (desplegable de "agregar panel").
    property <bool> add-menu-open: false;
    // Emitido cuando cambia el tamaño del área de contenido (resize de ventana) para que
    // Rust reparta los paneles aun en reposo (con el timer apagado).
    callback content-resized();

    // Alto de la barra superior (path-bar + botones). El área de contenido es el resto.
    property <length> top-bar-h: 34px;
    // Área de contenido que Rust usa para repartir los paneles (sin padding global aquí:
    // el contenido empieza en 0,0 dentro de `content`).
    out property <length> content-w: content.width;
    out property <length> content-h: content.height;
    // Avisa a Rust cuando cambia el tamaño del área de contenido (resize de ventana).
    changed content-w => { root.content-resized(); }
    changed content-h => { root.content-resized(); }

    VerticalLayout {
        padding: 0px;
        // Barra superior: path del panel activo + subir + agregar panel.
        Rectangle {
            height: root.top-bar-h;
            background: #141d2b;
            HorizontalLayout {
                padding: 4px;
                spacing: 6px;
                ToolBtn {
                    label: Tr.toolbar-up;
                    tip: Tr.toolbar-up-tip;
                    btn-width: 46px;
                    clicked => { root.go-up(); }
                }
                ToolBtn {
                    label: "+";
                    tip: Tr.toolbar-add-tip;
                    clicked => { root.add-pane(); }
                }
                ToolBtn {
                    label: Tr.toolbar-panel;
                    tip: Tr.toolbar-panel-tip;
                    btn-width: 50px;
                    highlight: root.add-menu-open;
                    clicked => { root.add-menu-open = !root.add-menu-open; }
                }
                ToolBtn {
                    label: Tr.toolbar-swap;
                    tip: Tr.toolbar-swap-tip;
                    btn-width: 50px;
                    clicked => { root.swap-panes(); }
                }
                ToolBtn {
                    label: Tr.toolbar-clone;
                    tip: Tr.toolbar-clone-tip;
                    btn-width: 54px;
                    clicked => { root.clone-pane(); }
                }
                ToolBtn {
                    label: Tr.toolbar-tabs;
                    tip: Tr.toolbar-tabs-tip;
                    btn-width: 50px;
                    clicked => { root.stack-pane(); }
                }
                Rectangle {
                    background: #1b2838;
                    border-radius: 4px;
                    Text { text: root.active-path; color: #cdd; vertical-alignment: center; x: 8px; }
                }
            }
        }
        // Zona de contenido: paneles posicionados absolutamente + barras de splitter.
        content := Rectangle {
            background: #0e1622;
            // Paneles (posición/tamaño calculados en Rust). El componente concreto se
            // elige por `p.purpose`: 0=Files 1=Tree 2=Inspector 3=History 4=Favorites
            // 5=Preview. Cada `if` instancia su componente en el mismo rect del panel.
            for p in root.panes: Rectangle {
                x: p.x;
                y: p.y;
                width: p.w;
                height: p.h;
                // Todo panel lleva una barra de título de 24px arriba: muestra su nombre y
                // sirve de ASA para arrastrarlo y reacomodar el layout. Si el panel es la
                // pestaña activa de un grupo, en su lugar va la barra de pestañas.
                property <length> bar-h: 24px;
                if p.tabs.length > 0: TabBar {
                    x: 0;
                    y: 0;
                    width: 100%;
                    height: parent.bar-h;
                    tabs: p.tabs;
                    select(id) => { root.tab-select(id); }
                    close(id) => { root.tab-close(id); }
                }
                if p.tabs.length == 0: title-bar := Rectangle {
                    x: 0;
                    y: 0;
                    width: 100%;
                    height: parent.bar-h;
                    background: p.active ? #1c2c44 : #16243a;
                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 6px;
                        spacing: 6px;
                        Text {
                            text: p.title;
                            color: p.active ? white : #9ab;
                            font-weight: 600;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }
                        Text {
                            text: Tr.drag-move;
                            color: title-touch.pressed ? #4f8ae0 : #678;
                            font-size: 10px;
                            vertical-alignment: center;
                        }
                    }
                    title-touch := TouchArea {
                        mouse-cursor: move;
                        moved => {
                            root.pane-drag-move(p.id, p.x + self.mouse-x, p.y + self.mouse-y);
                        }
                        pointer-event(ev) => {
                            if (ev.kind == PointerEventKind.down) { root.activate(p.id); }
                            if (ev.button == PointerEventButton.left && ev.kind == PointerEventKind.up) {
                                root.pane-drag-drop(p.id, p.x + self.mouse-x, p.y + self.mouse-y);
                            }
                        }
                    }
                }
                // Contenido del panel, debajo de la barra (título o pestañas).
                pane-content := Rectangle {
                    x: 0;
                    y: parent.bar-h;
                    width: 100%;
                    height: parent.height - parent.bar-h;
                    if p.purpose == 0: FilePanel {
                        width: 100%;
                        height: 100%;
                        pane-id: p.id;
                        active: p.active;
                        rows: p.rows;
                        row-clicked(id, pos) => { root.row-clicked(id, pos); }
                        row-double-clicked(id, pos) => { root.row-double-clicked(id, pos); }
                        row-context(id, pos, cx, cy) => { root.row-context(id, pos, cx, cy); }
                        sort-by(id, col) => { root.sort-by(id, col); }
                        activate(id) => { root.activate(id); }
                        key(t, c, s, a) => { root.key(t, c, s, a); }
                    }
                    if p.purpose == 1: TreePanel {
                        width: 100%;
                        height: 100%;
                        active: p.active;
                        rows: p.tree-rows;
                        toggle(path) => { root.tree-toggle(p.id, path); }
                        navigate(path) => { root.tree-navigate(path); }
                        focus-pane() => { root.activate(p.id); }
                    }
                    if p.purpose == 2: InspectorPanel {
                        width: 100%;
                        height: 100%;
                        active: p.active;
                        info: p.inspector;
                    }
                    if p.purpose == 3: HistoryPanel {
                        width: 100%;
                        height: 100%;
                        active: p.active;
                        rows: p.hist-rows;
                        undo(id) => { root.undo-entry(id); }
                        focus-pane() => { root.activate(p.id); }
                    }
                    if p.purpose == 4: FavoritesPanel {
                        width: 100%;
                        height: 100%;
                        active: p.active;
                        favs: p.favs;
                        recents: p.recents;
                        navigate(path) => { root.nav-navigate(path); }
                        remove(path) => { root.fav-remove(path); }
                        pin-current() => { root.fav-pin-current(); }
                        focus-pane() => { root.activate(p.id); }
                    }
                    if p.purpose == 5: PreviewPanel {
                        width: 100%;
                        height: 100%;
                        active: p.active;
                        view: p.preview;
                    }
                }
            }
            // Barras de splitter arrastrables.
            for s in root.splits: Rectangle {
                x: s.x;
                y: s.y;
                width: s.w;
                height: s.h;
                background: sp-touch.has-hover || sp-touch.pressed ? #4f8ae0 : #2a3a52;
                sp-touch := TouchArea {
                    mouse-cursor: s.horizontal ? ew-resize : ns-resize;
                    moved => {
                        root.split-drag(s.index, self.mouse-x - self.pressed-x, self.mouse-y - self.pressed-y);
                    }
                }
            }
            // Vista previa de la zona de drop durante un arrastre (resaltado translúcido).
            if root.drop-w > 0 && root.drop-h > 0: Rectangle {
                x: root.drop-x;
                y: root.drop-y;
                width: root.drop-w;
                height: root.drop-h;
                background: #4f8ae055;
                border-width: 2px;
                border-color: #4f8ae0;
                border-radius: 4px;
            }
        }
        // Panel de progreso de operaciones (sobre la barra de estado; oculto si no hay ops).
        OpsPanel {
            rows: root.op-rows;
            cancel(idx) => { root.op-cancel(idx); }
        }
        // Barra de estado: carpeta activa + recuento de ítems y selección.
        Rectangle {
            height: 22px;
            background: #141d2b;
            Text {
                text: root.status;
                color: #9ab;
                font-size: 11px;
                vertical-alignment: center;
                x: 8px;
            }
        }
    }

    // Modales de operaciones (overlay sobre toda la ventana; visible solo si hay uno).
    OpDialogs {
        width: 100%;
        height: 100%;
        vm: root.op-dialog;
        resume-rows: root.resume-rows;
        resume-decide(id, a) => { root.resume-decide(id, a); }
        delete-confirm() => { root.delete-confirm(); }
        delete-cancel() => { root.delete-cancel(); }
        conflict-decide(a, all) => { root.conflict-decide(a, all); }
        name-changed(v) => { root.name-changed(v); }
        name-confirm() => { root.name-confirm(); }
        name-cancel() => { root.name-cancel(); }
        paste-confirm() => { root.paste-confirm(); }
        paste-cancel() => { root.paste-cancel(); }
    }

    // Menú contextual (clic derecho): acciones propias + nativo de Windows.
    ContextMenu {
        width: 100%;
        height: 100%;
        vm: root.ctx-menu;
        open() => { root.ctx-open(); }
        open-with() => { root.ctx-open-with(); }
        copy() => { root.ctx-copy(); }
        cut() => { root.ctx-cut(); }
        paste() => { root.ctx-paste(); }
        rename() => { root.ctx-rename(); }
        delete() => { root.ctx-delete(); }
        copy-path() => { root.ctx-copy-path(); }
        native() => { root.ctx-native(); }
        dismiss() => { root.ctx-dismiss(); }
    }

    // Desplegable ▾: agregar un panel del tipo elegido (divide el leaf activo). Flota
    // sobre todo. Un velo invisible cierra el menú al hacer clic fuera.
    if root.add-menu-open: TouchArea {
        clicked => { root.add-menu-open = false; }
    }
    if root.add-menu-open: Rectangle {
        x: 70px;
        y: root.top-bar-h + 2px;
        width: 160px;
        height: menu-items.preferred-height + 8px;
        background: #1b2838;
        border-color: #2a4a7a;
        border-width: 1px;
        border-radius: 6px;
        menu-items := VerticalLayout {
            padding: 4px;
            spacing: 1px;
            MenuItem { label: Tr.add-files; clicked => { root.add-pane-of(0); root.add-menu-open = false; } }
            MenuItem { label: Tr.add-tree; clicked => { root.add-pane-of(1); root.add-menu-open = false; } }
            MenuItem { label: Tr.add-inspector; clicked => { root.add-pane-of(2); root.add-menu-open = false; } }
            MenuItem { label: Tr.add-history; clicked => { root.add-pane-of(3); root.add-menu-open = false; } }
            MenuItem { label: Tr.add-favorites; clicked => { root.add-pane-of(4); root.add-menu-open = false; } }
            MenuItem { label: Tr.add-preview; clicked => { root.add-pane-of(5); root.add-menu-open = false; } }
        }
    }

    // Selector de panel destino (overlay 1..9): oscurece cada candidato y pinta su número.
    // Clic sobre un candidato lo elige; clic fuera (velo) cancela. Los rects llegan en
    // coordenadas del área de contenido → se desplazan por la altura de la barra superior.
    if root.picks.length > 0: TouchArea {
        clicked => { root.pick-cancel(); }
    }
    for p in root.picks: Rectangle {
        x: p.x;
        y: root.top-bar-h + p.y;
        width: p.w;
        height: p.h;
        background: #000000cc;
        border-width: 2px;
        border-color: #4f8ae0;
        border-radius: 4px;
        Text {
            text: p.number;
            color: white;
            font-size: 48px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        pick-touch := TouchArea {
            clicked => { root.pick-resolve(p.number); }
        }
    }
}
