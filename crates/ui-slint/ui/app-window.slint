import { PathBar } from "path-bar.slint";
import { FilePanel } from "file-panel.slint";
import { ColumnMenu } from "column-menu.slint";
import { TreePanel } from "tree-panel.slint";
import { InspectorPanel } from "inspector-panel.slint";
import { HistoryPanel } from "history-panel.slint";
import { FavoritesPanel } from "favorites-panel.slint";
import { PreviewPanel } from "preview-panel.slint";
import { OpDialogs } from "op-dialogs.slint";
import { MessageModal } from "message-modal.slint";
import { OpsPanel } from "ops-panel.slint";
import { OpFileListModal } from "op-file-list-modal.slint";
import { ContextMenu } from "context-menu.slint";
import { ConfigWindow } from "config-window.slint";
import { BatchRename } from "batch-rename.slint";
import { NewFolder } from "new-folder.slint";
import { SearchPanel } from "search-panel.slint";
import { Help } from "help.slint";
import { CommandPalette } from "command-palette.slint";
import { BatchRenameVm, NewFolderVm, HelpRowVm, SearchVm } from "types.slint";
import { PaletteItemVm } from "types.slint";
import { HistoryItemVm } from "types.slint";
