import { RowData, PaneVm, SplitVm, PickVm, TabVm } from "types.slint";
import { PathBar } from "path-bar.slint";
import { FilePanel } from "file-panel.slint";
import { TreePanel } from "tree-panel.slint";
import { InspectorPanel } from "inspector-panel.slint";
import { HistoryPanel } from "history-panel.slint";
import { FavoritesPanel } from "favorites-panel.slint";
import { PreviewPanel } from "preview-panel.slint";

// Barra de pestañas de un grupo: una pestaña por miembro; la activa resaltada; cada una
// con su × para cerrarla. Clic en una pestaña la activa.
component TabBar inherits Rectangle {
    in property <[TabVm]> tabs;
    callback select(int);
    callback close(int);
    height: 24px;
    background: #0b1320;
    HorizontalLayout {
        padding: 2px;
        spacing: 2px;
        for t in root.tabs: Rectangle {
            background: t.active ? #2a4a7a : (tab-touch.has-hover ? #1f3350 : #16243a);
            border-radius: 4px;
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 4px;
                spacing: 4px;
                Text {
                    text: t.label;
                    color: t.active ? white : #9ab;
                    vertical-alignment: center;
                    overflow: elide;
                }
                Rectangle {
                    width: 16px;
                    background: x-touch.has-hover ? #5a2630 : transparent;
                    border-radius: 3px;
                    Text { text: "×"; color: #c99; horizontal-alignment: center; vertical-alignment: center; }
                    x-touch := TouchArea { clicked => { root.close(t.id); } }
                }
            }
            tab-touch := TouchArea { clicked => { root.select(t.id); } }
        }
    }
}

// Un ítem del menú desplegable ▾.
component MenuItem inherits Rectangle {
    in property <string> label;
    callback clicked();
    height: 26px;
    background: mi-touch.has-hover ? #2a4a7a : transparent;
    border-radius: 4px;
    Text {
        text: root.label;
        color: #dde;
        vertical-alignment: center;
        x: 8px;
    }
    mi-touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component AppWindow inherits Window {
    title: "Naygo";
    preferred-width: 1000px;
    preferred-height: 640px;

    in property <string> active-path;
    in property <[PaneVm]> panes;
    in property <[SplitVm]> splits;
    callback go-up();
    callback add-pane();
    callback add-pane-of(int);        // agrega un panel del purpose dado (menú ▾)
    callback row-clicked(int, int);
    callback row-double-clicked(int, int);
    callback sort-by(int, string);
    callback activate(int);
    callback key(string, bool, bool, bool);
    callback split-drag(int, length, length);
    // Paneles especiales:
    callback tree-toggle(int, string);   // (pane-id, ruta) expandir/colapsar rama
    callback tree-navigate(string);      // navegar el Files activo a esa carpeta
    callback nav-navigate(string);       // favorito/reciente → navegar Files activo
    callback fav-remove(string);         // quitar favorito por ruta
    callback fav-pin-current();          // anclar la carpeta del Files activo
    callback undo-entry(int);            // deshacer la entrada del historial
    // Acciones multi-panel (toolbar):
    callback swap-panes();               // intercambiar el activo con el otro panel
    callback clone-pane();               // clonar la carpeta del activo en otro panel
    callback stack-pane();               // apilar el activo como pestaña sobre otro panel
    // Pestañas (grupos):
    callback tab-select(int);            // activar la pestaña (PaneId)
    callback tab-close(int);             // cerrar la pestaña (PaneId)
    // Selector numérico de panel destino (overlay 1..9):
    in property <[PickVm]> picks;        // candidatos con su rect + número (vacío = sin selector)
    callback pick-resolve(int);          // elegí el panel número N (clic)
    callback pick-cancel();              // cancelar (clic fuera)
    // Estado del menú ▾ (desplegable de "agregar panel").
    property <bool> add-menu-open: false;
    // Emitido cuando cambia el tamaño del área de contenido (resize de ventana) para que
    // Rust reparta los paneles aun en reposo (con el timer apagado).
    callback content-resized();

    // Alto de la barra superior (path-bar + botones). El área de contenido es el resto.
    property <length> top-bar-h: 34px;
    // Área de contenido que Rust usa para repartir los paneles (sin padding global aquí:
    // el contenido empieza en 0,0 dentro de `content`).
    out property <length> content-w: content.width;
    out property <length> content-h: content.height;
    // Avisa a Rust cuando cambia el tamaño del área de contenido (resize de ventana).
    changed content-w => { root.content-resized(); }
    changed content-h => { root.content-resized(); }

    VerticalLayout {
        padding: 0px;
        // Barra superior: path del panel activo + subir + agregar panel.
        Rectangle {
            height: root.top-bar-h;
            background: #141d2b;
            HorizontalLayout {
                padding: 4px;
                spacing: 6px;
                Rectangle {
                    width: 30px;
                    background: up-touch.has-hover ? #2a4a7a : #1b2838;
                    border-radius: 4px;
                    Text { text: "↑"; color: white; horizontal-alignment: center; vertical-alignment: center; }
                    up-touch := TouchArea { clicked => { root.go-up(); } }
                }
                Rectangle {
                    width: 30px;
                    background: add-touch.has-hover ? #2a4a7a : #1b2838;
                    border-radius: 4px;
                    Text { text: "+"; color: white; horizontal-alignment: center; vertical-alignment: center; }
                    add-touch := TouchArea { clicked => { root.add-pane(); } }
                }
                Rectangle {
                    width: 30px;
                    background: (menu-touch.has-hover || root.add-menu-open) ? #2a4a7a : #1b2838;
                    border-radius: 4px;
                    Text { text: "▾"; color: white; horizontal-alignment: center; vertical-alignment: center; }
                    menu-touch := TouchArea { clicked => { root.add-menu-open = !root.add-menu-open; } }
                }
                // Acciones multi-panel: intercambiar ⇄ y clonar ⧉ la carpeta del activo.
                Rectangle {
                    width: 30px;
                    background: swap-touch.has-hover ? #2a4a7a : #1b2838;
                    border-radius: 4px;
                    Text { text: "⇄"; color: white; horizontal-alignment: center; vertical-alignment: center; }
                    swap-touch := TouchArea { clicked => { root.swap-panes(); } }
                }
                Rectangle {
                    width: 30px;
                    background: clone-touch.has-hover ? #2a4a7a : #1b2838;
                    border-radius: 4px;
                    Text { text: "⧉"; color: white; horizontal-alignment: center; vertical-alignment: center; }
                    clone-touch := TouchArea { clicked => { root.clone-pane(); } }
                }
                Rectangle {
                    width: 30px;
                    background: stack-touch.has-hover ? #2a4a7a : #1b2838;
                    border-radius: 4px;
                    Text { text: "⊞"; color: white; horizontal-alignment: center; vertical-alignment: center; }
                    stack-touch := TouchArea { clicked => { root.stack-pane(); } }
                }
                Rectangle {
                    background: #1b2838;
                    border-radius: 4px;
                    Text { text: root.active-path; color: #cdd; vertical-alignment: center; x: 8px; }
                }
            }
        }
        // Zona de contenido: paneles posicionados absolutamente + barras de splitter.
        content := Rectangle {
            background: #0e1622;
            // Paneles (posición/tamaño calculados en Rust). El componente concreto se
            // elige por `p.purpose`: 0=Files 1=Tree 2=Inspector 3=History 4=Favorites
            // 5=Preview. Cada `if` instancia su componente en el mismo rect del panel.
            for p in root.panes: Rectangle {
                x: p.x;
                y: p.y;
                width: p.w;
                height: p.h;
                // Si el panel es la pestaña activa de un grupo, reserva una barra arriba.
                property <length> bar-h: p.tabs.length > 0 ? 24px : 0px;
                if p.tabs.length > 0: TabBar {
                    x: 0;
                    y: 0;
                    width: 100%;
                    tabs: p.tabs;
                    select(id) => { root.tab-select(id); }
                    close(id) => { root.tab-close(id); }
                }
                // Contenido del panel, debajo de la barra de pestañas (o todo el alto).
                pane-content := Rectangle {
                    x: 0;
                    y: parent.bar-h;
                    width: 100%;
                    height: parent.height - parent.bar-h;
                    if p.purpose == 0: FilePanel {
                        width: 100%;
                        height: 100%;
                        pane-id: p.id;
                        active: p.active;
                        rows: p.rows;
                        row-clicked(id, pos) => { root.row-clicked(id, pos); }
                        row-double-clicked(id, pos) => { root.row-double-clicked(id, pos); }
                        sort-by(id, col) => { root.sort-by(id, col); }
                        activate(id) => { root.activate(id); }
                        key(t, c, s, a) => { root.key(t, c, s, a); }
                    }
                    if p.purpose == 1: TreePanel {
                        width: 100%;
                        height: 100%;
                        active: p.active;
                        rows: p.tree-rows;
                        toggle(path) => { root.tree-toggle(p.id, path); }
                        navigate(path) => { root.tree-navigate(path); }
                        focus-pane() => { root.activate(p.id); }
                    }
                    if p.purpose == 2: InspectorPanel {
                        width: 100%;
                        height: 100%;
                        active: p.active;
                        info: p.inspector;
                    }
                    if p.purpose == 3: HistoryPanel {
                        width: 100%;
                        height: 100%;
                        active: p.active;
                        rows: p.hist-rows;
                        undo(id) => { root.undo-entry(id); }
                        focus-pane() => { root.activate(p.id); }
                    }
                    if p.purpose == 4: FavoritesPanel {
                        width: 100%;
                        height: 100%;
                        active: p.active;
                        favs: p.favs;
                        recents: p.recents;
                        navigate(path) => { root.nav-navigate(path); }
                        remove(path) => { root.fav-remove(path); }
                        pin-current() => { root.fav-pin-current(); }
                        focus-pane() => { root.activate(p.id); }
                    }
                    if p.purpose == 5: PreviewPanel {
                        width: 100%;
                        height: 100%;
                        active: p.active;
                        view: p.preview;
                    }
                }
            }
            // Barras de splitter arrastrables.
            for s in root.splits: Rectangle {
                x: s.x;
                y: s.y;
                width: s.w;
                height: s.h;
                background: sp-touch.has-hover || sp-touch.pressed ? #4f8ae0 : #2a3a52;
                sp-touch := TouchArea {
                    mouse-cursor: s.horizontal ? ew-resize : ns-resize;
                    moved => {
                        root.split-drag(s.index, self.mouse-x - self.pressed-x, self.mouse-y - self.pressed-y);
                    }
                }
            }
        }
    }

    // Desplegable ▾: agregar un panel del tipo elegido (divide el leaf activo). Flota
    // sobre todo. Un velo invisible cierra el menú al hacer clic fuera.
    if root.add-menu-open: TouchArea {
        clicked => { root.add-menu-open = false; }
    }
    if root.add-menu-open: Rectangle {
        x: 70px;
        y: root.top-bar-h + 2px;
        width: 160px;
        height: menu-items.preferred-height + 8px;
        background: #1b2838;
        border-color: #2a4a7a;
        border-width: 1px;
        border-radius: 6px;
        menu-items := VerticalLayout {
            padding: 4px;
            spacing: 1px;
            MenuItem { label: "Panel de archivos"; clicked => { root.add-pane-of(0); root.add-menu-open = false; } }
            MenuItem { label: "Árbol de carpetas"; clicked => { root.add-pane-of(1); root.add-menu-open = false; } }
            MenuItem { label: "Propiedades"; clicked => { root.add-pane-of(2); root.add-menu-open = false; } }
            MenuItem { label: "Historial"; clicked => { root.add-pane-of(3); root.add-menu-open = false; } }
            MenuItem { label: "Favoritos"; clicked => { root.add-pane-of(4); root.add-menu-open = false; } }
            MenuItem { label: "Vista previa"; clicked => { root.add-pane-of(5); root.add-menu-open = false; } }
        }
    }

    // Selector de panel destino (overlay 1..9): oscurece cada candidato y pinta su número.
    // Clic sobre un candidato lo elige; clic fuera (velo) cancela. Los rects llegan en
    // coordenadas del área de contenido → se desplazan por la altura de la barra superior.
    if root.picks.length > 0: TouchArea {
        clicked => { root.pick-cancel(); }
    }
    for p in root.picks: Rectangle {
        x: p.x;
        y: root.top-bar-h + p.y;
        width: p.w;
        height: p.h;
        background: #000000cc;
        border-width: 2px;
        border-color: #4f8ae0;
        border-radius: 4px;
        Text {
            text: p.number;
            color: white;
            font-size: 48px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        pick-touch := TouchArea {
            clicked => { root.pick-resolve(p.number); }
        }
    }
}
