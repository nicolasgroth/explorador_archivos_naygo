    in property <string> add-tree: "Árbol de carpetas";
    in property <string> add-inspector: "Propiedades";
    in property <string> add-history: "Historial de acciones";
    in property <string> add-favorites: "Favoritos";
    in property <string> add-preview: "Vista previa";
    in property <string> add-operations: "Operaciones";

    // Panel rico de operaciones (en curso / en cola / historial).
    in property <string> ops-title: "Operaciones";
    in property <string> ops-in-progress: "En curso";
    in property <string> ops-queued: "En cola";
    in property <string> ops-history: "Historial reciente";
    in property <string> ops-pause: "Pausar";
    in property <string> ops-resume: "Reanudar";
    in property <string> ops-skip: "Saltar";
    in property <string> ops-cancel: "Cancelar";
    in property <string> ops-copied: "Copiado";
    in property <string> ops-speed: "Velocidad";
    in property <string> ops-peak: "pico";
    in property <string> ops-elapsed: "Transcurrido";
    in property <string> ops-remaining: "Restante";
    in property <string> ops-waiting: "en espera";
    in property <string> ops-calculating: "Calculando…";
    // Detalle de archivos de una op terminada (nombres inline + popup con la lista).
    in property <string> ops-view-files: "Ver";          // enlace "Ver N archivos"
    in property <string> ops-files-word: "archivos";       // sustantivo del enlace
    in property <string> ops-file-list-title: "Archivos de la operación";
    in property <string> ops-file-skipped: "saltado";
    in property <string> ops-file-failed: "fallido";
    in property <string> ops-close: "Cerrar";
    // Cancelar TODAS las operaciones en curso (botón del header + confirmación). PUNTO 2.
    in property <string> ops-cancel-all: "Cancelar todo";
    in property <string> ops-cancel-all-title: "Cancelar operaciones";
    in property <string> ops-cancel-all-q: "¿Cancelar todas las operaciones en curso?";
    in property <string> ops-cancel-all-yes: "Sí, cancelar todo";
    in property <string> ops-cancel-all-no: "No";
    // Encabezado enriquecido del popup "Archivos de la operación" (PUNTO 3): tipo + origen +
    // destino + estadísticas. Las etiquetas; los valores los compone Rust.
    in property <string> ops-file-origin: "Origen:";
    in property <string> ops-file-dest: "Destino:";
    in property <string> ops-file-total: "Total:";
    in property <string> ops-file-stats-done: "hechos";
    in property <string> ops-file-stats-skipped: "saltados";
    in property <string> ops-file-stats-failed: "fallidos";
    in property <string> ops-file-kind-copy: "Copiar";
    in property <string> ops-file-kind-move: "Mover";
    in property <string> ops-file-kind-other: "Operación";

    // Encabezados de columnas (file-panel).
    in property <string> col-name: "Nombre";
    in property <string> col-ext: "Extensión";
    in property <string> col-size: "Tamaño";
    in property <string> col-modified: "Modificado";

    // Diálogos de operaciones (op-dialogs).
    in property <string> dlg-no-undo: "Esta acción no se puede deshacer.";
    in property <string> dlg-cancel: "Cancelar";
    in property <string> dlg-delete: "Eliminar";
    in property <string> dlg-apply-all: "Aplicar a todos los conflictos";
    in property <string> dlg-skip: "Saltar";
    in property <string> dlg-rename: "Renombrar";
    in property <string> dlg-overwrite: "Sobrescribir";
    in property <string> dlg-conflict-cancel-all: "Cancelar todo";
    // Etiquetas del bloque "de dónde a dónde" en el conflicto de archivo/carpeta: la carpeta de
    // origen y la de destino de la operación, para que el usuario sepa qué se está copiando/moviendo.
    in property <string> dlg-conflict-from: "Origen:";
    in property <string> dlg-conflict-to: "Destino:";
    // Conflicto de archivo LADO A LADO (kind==2): encabezados de columna, pregunta, etiquetas de
    // tipo y las acciones extra del desplegable "Más opciones".
    in property <string> dlg-conflict-existing: "Existente";
    in property <string> dlg-conflict-incoming: "Nuevo";
    in property <string> dlg-conflict-question: "¿Qué quieres hacer?";
    in property <string> dlg-kind-folder: "Carpeta";
    in property <string> dlg-kind-file: "Archivo";
    in property <string> dlg-keep-both: "Mantener ambos";
    in property <string> dlg-more-options: "Más opciones";
    in property <string> dlg-fewer-options: "Menos opciones";
    in property <string> dlg-overwrite-all: "Sobrescribir todos";
    in property <string> dlg-skip-all: "Saltar todos";
    in property <string> dlg-skip-identical: "Saltar idénticos";
    in property <string> dlg-rename-existing: "Renombrar el existente";
    // Título del modal de nombre al renombrar un conflicto (BUG 1). El nombre original va entre
    // `pre` y `suf` (Slint no tiene replace).
    in property <string> dlg-rename-to-pre: "Nuevo nombre para «";
    in property <string> dlg-rename-to-suf: "»:";
    // Conflicto de carpeta (P3). El nombre va entre `pre` y `suf` (Slint no tiene replace).
    in property <string> dlg-folder-exists-pre: "La carpeta «";
    in property <string> dlg-folder-exists-suf: "» ya existe. ¿Qué hacer?";
    in property <string> dlg-folder-merge: "Fusionar";
    in property <string> dlg-folder-replace: "Reemplazar";
    in property <string> dlg-folder-skip: "Saltar";
    in property <string> dlg-folder-apply-all: "Aplicar a todas las carpetas";
    in property <string> dlg-invalid-name: "Nombre no válido.";
    in property <string> dlg-accept: "Aceptar";
    in property <string> dlg-create: "Crear";
    in property <string> dlg-resume-q: "Hay operaciones que no terminaron. ¿Retomarlas?";
    in property <string> dlg-resume: "Retomar";
    in property <string> dlg-discard: "Descartar";
    // Botones de verbo para el modal de confirmar drop entre paneles (PUNTO 1b).
    in property <string> dlg-copy: "Copiar";
    in property <string> dlg-move: "Mover";
    // Confirmar al soltar archivos en otro panel (PUNTO 1b). El cuerpo lleva {count} y {dest} que
