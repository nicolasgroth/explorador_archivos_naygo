// Naygo — textos de la UI (i18n). El global `Tr` expone una propiedad por cada texto visible.
// Rust las rellena según el idioma activo (ver i18n_keys.rs). El valor por defecto de cada
// propiedad es el texto en español, así que si Rust no setea nada la UI igual se ve en ES.
// Copyright (c) 2026 Nicolás Groth / ISGroth. MIT License.
export global Tr {
    // Barra de herramientas.
    in property <string> toolbar-up: "Subir";
    in property <string> toolbar-up-tip: "Subir un nivel (Backspace)";
    // Tooltips de los botones de navegación tipo navegador (Atrás / Adelante / Inicio).
    in property <string> nav-back-tip: "Atrás (Alt+←)";
    in property <string> nav-forward-tip: "Adelante (Alt+→)";
    in property <string> nav-home-tip: "Ir al inicio (Alt+Inicio)";
    // Tooltips de los ▾ que despliegan el historial de carpetas hacia atrás / adelante.
    in property <string> nav-back-history-tip: "Historial hacia atrás";
    in property <string> nav-forward-history-tip: "Historial hacia adelante";
    in property <string> toolbar-add-tip: "Dividir: nuevo panel de archivos";
    in property <string> toolbar-panel: "Panel";
    in property <string> toolbar-panel-tip: "Agregar panel especial…";
    in property <string> toolbar-swap: "Swap";
    in property <string> toolbar-swap-tip: "Intercambiar las carpetas de dos paneles";
    in property <string> toolbar-clone: "Clonar";
    in property <string> toolbar-clone-tip: "Abrir esta carpeta en otro panel";
    in property <string> toolbar-tabs: "Tabs";
    in property <string> toolbar-tabs-tip: "Apilar este panel como pestaña sobre otro";
    // Tooltips de los íconos de la barra de ruta + aviso de copiado.
    in property <string> pathbar-fav-tip: "Anclar/quitar esta carpeta de favoritos";
    in property <string> pathbar-copy-tip: "Copiar la ruta al portapapeles";
    in property <string> pathbar-copied: "Ruta copiada";
    // Expulsión segura de unidades extraíbles (USB).
    in property <string> drive-eject-tip: "Expulsar de forma segura";
    in property <string> drive-eject: "Expulsar";
    in property <string> drive-eject-confirm-title: "Expulsar unidad";
    in property <string> drive-eject-confirm: "¿Seguro que quieres expulsar {drive}? Asegúrate de que no haya archivos en uso.";
    in property <string> toolbar-refresh-drives: "Refrescar unidades";
    in property <string> drive-eject-ok: "Unidad expulsada, ya puedes quitarla";
    in property <string> drive-eject-in-use: "No se pudo expulsar: hay archivos en uso";
    in property <string> drive-eject-failed: "No se pudo expulsar la unidad";
    in property <string> toolbar-config-tip: "Abrir la ventana de configuración (temas, idioma, atajos…)";
    in property <string> toolbar-layouts: "Layouts";
    in property <string> toolbar-layouts-tip: "Plantillas de disposición de paneles";
