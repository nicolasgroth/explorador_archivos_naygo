// Naygo — textos de la UI (i18n). El global `Tr` expone una propiedad por cada texto visible.
// Rust las rellena según el idioma activo (ver i18n_keys.rs). El valor por defecto de cada
// propiedad es el texto en español, así que si Rust no setea nada la UI igual se ve en ES.
// Copyright (c) 2026 Nicolás Groth / ISGroth. MIT License.
export global Tr {
    // Barra de herramientas.
    in property <string> toolbar-up: "Subir";
    in property <string> toolbar-up-tip: "Subir un nivel (Backspace)";
    in property <string> toolbar-add-tip: "Dividir: nuevo panel de archivos";
    in property <string> toolbar-panel: "Panel";
    in property <string> toolbar-panel-tip: "Agregar panel especial…";
    in property <string> toolbar-swap: "Swap";
    in property <string> toolbar-swap-tip: "Intercambiar las carpetas de dos paneles";
    in property <string> toolbar-clone: "Clonar";
    in property <string> toolbar-clone-tip: "Abrir esta carpeta en otro panel";
    in property <string> toolbar-tabs: "Tabs";
    in property <string> toolbar-tabs-tip: "Apilar este panel como pestaña sobre otro";

    // Menú desplegable "agregar panel" (▾).
    in property <string> add-files: "Panel de archivos";
    in property <string> add-tree: "Árbol de carpetas";
    in property <string> add-inspector: "Propiedades";
    in property <string> add-history: "Historial";
    in property <string> add-favorites: "Favoritos";
    in property <string> add-preview: "Vista previa";

    // Encabezados de columnas (file-panel).
    in property <string> col-name: "Nombre";
    in property <string> col-ext: "Extensión";
    in property <string> col-size: "Tamaño";
    in property <string> col-modified: "Modificado";

    // Diálogos de operaciones (op-dialogs).
    in property <string> dlg-no-undo: "Esta acción no se puede deshacer.";
    in property <string> dlg-cancel: "Cancelar";
    in property <string> dlg-delete: "Eliminar";
    in property <string> dlg-apply-all: "Aplicar a todos los conflictos";
    in property <string> dlg-skip: "Saltar";
    in property <string> dlg-rename: "Renombrar";
    in property <string> dlg-overwrite: "Sobrescribir";
    in property <string> dlg-invalid-name: "Nombre no válido.";
    in property <string> dlg-accept: "Aceptar";
    in property <string> dlg-create: "Crear";
    in property <string> dlg-resume-q: "Hay operaciones que no terminaron. ¿Retomarlas?";
    in property <string> dlg-resume: "Retomar";
    in property <string> dlg-discard: "Descartar";

    // Menú contextual (context-menu).
    in property <string> ctx-open: "Abrir";
    in property <string> ctx-open-with: "Abrir con…";
    in property <string> ctx-copy: "Copiar";
    in property <string> ctx-cut: "Cortar";
    in property <string> ctx-paste: "Pegar";
    in property <string> ctx-rename: "Renombrar";
    in property <string> ctx-delete: "Eliminar";
    in property <string> ctx-copy-path: "Copiar ruta";
    in property <string> ctx-more-windows: "Más opciones de Windows…";

    // Paneles especiales (títulos + estados vacíos).
    in property <string> tree-title: "Carpetas";
    in property <string> inspector-title: "Propiedades";
    in property <string> inspector-no-selection: "Sin selección";
    in property <string> inspector-name: "Nombre";
    in property <string> inspector-kind: "Tipo";
    in property <string> inspector-size: "Tamaño";
    in property <string> inspector-modified: "Modificado";
    in property <string> inspector-created: "Creado";
    in property <string> inspector-path: "Ruta";
    in property <string> history-title: "Historial";
    in property <string> history-empty: "Sin operaciones todavía";
    in property <string> history-undo: "Deshacer";
    in property <string> fav-title: "Favoritos";
    in property <string> fav-empty: "Sin favoritos (Ctrl+D)";
    in property <string> fav-recents: "Recientes";
    in property <string> preview-title: "Vista previa";
    in property <string> preview-select: "Selecciona un archivo";
    in property <string> preview-truncated: "… (recortado)";

    // Otros.
    in property <string> fav-pin: "Anclar";
    in property <string> drag-move: "mover";
}
