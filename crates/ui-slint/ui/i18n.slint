    in property <string> drop-confirm-title: "Confirmar";
    in property <string> drop-confirm-copy: "¿Copiar {count} elemento(s) a «{dest}»?";
    in property <string> drop-confirm-move: "¿Mover {count} elemento(s) a «{dest}»?";

    // Menú contextual (context-menu).
    in property <string> ctx-open: "Abrir";
    in property <string> ctx-open-with: "Abrir con…";
    in property <string> ctx-copy: "Copiar";
    in property <string> ctx-cut: "Cortar";
