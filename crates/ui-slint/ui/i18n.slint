    in property <string> toolbar-terminal-wsl: "Abrir WSL aquí";
    in property <string> layout-save-current: "Guardar disposición actual…";
    in property <string> layout-save-title: "Guardar disposición como plantilla";
    in property <string> layout-save-placeholder: "Nombre de la plantilla";

    // Menú desplegable "agregar panel" (▾).
