// Naygo — modal con la lista completa de archivos de una operación terminada.
// Lo abre el enlace "Ver N archivos" de una fila del historial del panel Operaciones
// cuando la op procesó muchos archivos (3+). Mismo look que los demás modales:
// velo + tarjeta centrada con scroll.
//
// PUNTO 3 (popup enriquecido): además de la lista, muestra un ENCABEZADO con el contexto de la
// operación (tipo Copiar/Mover, carpetas de origen y destino, y estadísticas: total / hechos /
// saltados / fallidos + tamaño total). Cada fila muestra la RUTA RELATIVA al destino (no solo el
// nombre), su tamaño y su estado con color.
//
// TAMAÑO: el modal es RELATIVO al de la ventana (≈80% ancho / 78% alto, con topes), no fijo. Es una
// lista que necesita espacio y aprovecha la altura disponible con buen scroll. Se eligió tamaño
// relativo en vez de redimensionar-arrastrando: con el render por software un drag-resize es frágil
// (hit-testing del borde, repintado) y un modal proporcional cumple el espíritu del pedido (más
// grande, aprovecha la pantalla) con mucho menos riesgo. Si en el futuro se quiere drag-resize, este
// es el lugar.
// Copyright (c) 2026 Nicolás Groth / ISGroth. MIT License.
import { ListView } from "std-widgets.slint";
import { OpFileVm, OpFileContextVm } from "types.slint";
import { Tr } from "i18n.slint";
import { Theme } from "theme.slint";

component DlgBtn inherits Rectangle {
    in property <string> label;
    callback clicked();
    width: txt.preferred-width + 24px;
    height: 28px;
    border-radius: 4px;
    background: touch.has-hover ? Theme.selection-bg : Theme.row-bg;
    txt := Text {
        text: root.label;
        color: white;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

// Par etiqueta:valor en una línea (para las filas del encabezado: Origen/Destino/Total).
component InfoLine inherits HorizontalLayout {
    in property <string> caption;
    in property <string> value;
    spacing: 6px;
    Text {
        text: root.caption;
        color: Theme.text-dim;
        font-size: 11px;
        vertical-alignment: center;
    }
    Text {
        text: root.value;
        color: Theme.text;
        font-size: 11px;
        vertical-alignment: center;
        overflow: elide;
        horizontal-stretch: 1;
    }
}

export component OpFileListModal inherits Rectangle {
    in property <bool> open;
    in property <string> op-label;      // etiqueta de la op (subtítulo), p. ej. "Mover → D:\x"
    in property <[OpFileVm]> rows;
    in property <OpFileContextVm> context;  // contexto del encabezado (tipo/origen/destino/stats)
    callback close();

    visible: root.open;
    background: #000000aa;

    // Velo: clic fuera de la tarjeta = cerrar.
    TouchArea {
        clicked => { root.close(); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        // Tamaño RELATIVO a la ventana (con topes), no fijo: la lista aprovecha la pantalla.
        width: clamp(parent.width * 0.8, 360px, 820px);
        height: clamp(parent.height * 0.78, 280px, 720px);
        background: Theme.row-bg;
        border-color: Theme.selection-bg;
        border-width: 1px;
        border-radius: 8px;
        // Captura los clics dentro de la tarjeta (no propaga al velo).
        TouchArea {}
        VerticalLayout {
            padding: 16px;
            spacing: 12px;

            // Título + subtítulo (la etiqueta de la op).
            HorizontalLayout {
                spacing: 10px;
                Rectangle {
                    width: 3px;
                    border-radius: 1.5px;
                    background: Theme.accent;
                }
                VerticalLayout {
                    spacing: 2px;
                    Text {
                        text: Tr.ops-file-list-title;
                        color: white;
                        font-size: 15px;
                        font-weight: 600;
                    }
                    if root.op-label != "": Text {
                        text: root.op-label;
                        color: Theme.text-dim;
                        font-size: 11px;
                        overflow: elide;
                    }
                }
            }

            // ENCABEZADO de contexto: tipo + origen + destino + estadísticas (PUNTO 3).
            Rectangle {
                background: Theme.panel-bg;
                border-radius: 6px;
                border-width: 1px;
                border-color: Theme.border;
                VerticalLayout {
                    padding: 10px;
                    spacing: 4px;
                    // Tipo de operación (Copiar/Mover/Operación) en negrita arriba.
                    Text {
                        text: root.context.kind == 0
                            ? Tr.ops-file-kind-copy
                            : (root.context.kind == 1 ? Tr.ops-file-kind-move : Tr.ops-file-kind-other);
                        color: Theme.accent;
                        font-size: 12px;
                        font-weight: 700;
                    }
                    if root.context.origin != "": InfoLine {
                        caption: Tr.ops-file-origin;
                        value: root.context.origin;
                    }
                    if root.context.dest != "": InfoLine {
                        caption: Tr.ops-file-dest;
                        value: root.context.dest;
                    }
                    // Estadísticas: "Total: N · X hechos · Y saltados · Z fallidos · tamaño".
                    Text {
                        text: Tr.ops-file-total + " " + root.context.total-files
                            + " · " + root.context.done + " " + Tr.ops-file-stats-done
                            + " · " + root.context.skipped + " " + Tr.ops-file-stats-skipped
                            + " · " + root.context.failed + " " + Tr.ops-file-stats-failed
                            + (root.context.total-size != "" ? " · " + root.context.total-size : "");
                        color: Theme.text-dim;
                        font-size: 11px;
                        wrap: word-wrap;
                    }
                }
            }

            // Lista con scroll: ruta relativa + tamaño + estado (+ motivo si falló).
            ListView {
                vertical-stretch: 1;
                for f in root.rows: Rectangle {
                    // Alto adaptable: 24px normal, 38px si hay un motivo de fallo (segunda línea).
                    height: (f.status == 2 && f.detail != "") ? 38px : 24px;
                    VerticalLayout {
                        padding-left: 4px;
                        padding-right: 4px;
                        padding-top: 2px;
                        padding-bottom: 2px;
                        spacing: 1px;
                        HorizontalLayout {
                            spacing: 8px;
                            // Ruta relativa (lo principal): cae al nombre si no hubo relativa.
                            Text {
                                text: f.rel-path != "" ? f.rel-path : f.name;
                                color: f.status == 2 ? Theme.error : Theme.text;
                                font-size: 12px;
                                vertical-alignment: center;
                                overflow: elide;
                                horizontal-stretch: 1;
                            }
                            // Tamaño (si se conoce).
                            if f.size != "": Text {
                                text: f.size;
                                color: Theme.text-dim;
                                font-size: 11px;
                                vertical-alignment: center;
                            }
                            // Etiqueta de estado a la derecha solo cuando NO fue "hecho".
                            if f.status != 0: Text {
                                text: f.status == 1 ? Tr.ops-file-skipped : Tr.ops-file-failed;
                                color: f.status == 1 ? Theme.text-dim : Theme.error;
                                font-size: 11px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }
                        }
                        // Motivo del fallo en una segunda línea atenuada.
                        if f.status == 2 && f.detail != "": Text {
                            text: f.detail;
                            color: Theme.error;
                            font-size: 10px;
                            overflow: elide;
                        }
                    }
                }
            }

            HorizontalLayout {
                alignment: end;
                DlgBtn {
                    label: Tr.ops-close;
                    clicked => { root.close(); }
                }
            }
        }
    }

    // Esc cierra.
    forward-focus: fl-focus;
    fl-focus := FocusScope {
        enabled: root.open;
        key-pressed(event) => {
            if (event.text == Key.Escape) { root.close(); }
            accept
        }
    }
}
