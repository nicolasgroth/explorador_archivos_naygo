assets/icons/*.zip

# Editor / OS
.vscode/
.idea/
*.swp
Thumbs.db
desktop.ini

# Artefactos de empaquetado generados (ZIP portable, setup.exe). No se versionan.
/dist

# Imágenes del asistente del instalador, generadas desde logo_naygo.png. No versionar.
installer/*.bmp
